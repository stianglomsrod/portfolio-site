# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# markdown docs (keep only README in the repo)
*.md
!README.md


# DNB workflow / agent documentation
# Keep most markdown ignored if desired, but explicitly track the DNB agent workflow docs.
!AGENTS.md
!FILE_TREE.md
!README_COPY_INSTRUCTIONS.md
!.github/
!.github/copilot-instructions.md
!docs/
!docs/dnb/
!docs/dnb/*.md
!docs/reports/
!docs/reports/*.md

# Raw source material — never track (contains PII e.g. national ID, and
# participant-sensitive thesis content). Keep as local-only evidence.
docs/dnb/sources/
*.pdf

# Track Skamlos planning docs
!docs/skamlos/
!docs/skamlos/*.md
