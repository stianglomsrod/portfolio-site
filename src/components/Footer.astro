---
import profil from '../data/profil.json';
---

<footer class="bunn">
  <div class="indre">
    <a class="merke" href="/" aria-label="stian glomsrød — til forsiden"
      >stian<span class="punktum">.</span></a
    >
    <p class="linje">
      Bygget i åpen dialog med Claude · ingen informasjonskapsler ·
      <a href="/kolofon">slik ble siden til</a> ·
      <a href="/kolofon#tilgjengelighet">tilgjengelighet</a> ·
      <a href={`mailto:${profil.kontakt.epost}`}>e-post</a> ·
      <a href={profil.kontakt.github} rel="me">GitHub</a> ·
      <a href={profil.kontakt.linkedin} rel="me">LinkedIn</a>
    </p>
  </div>
</footer>

<style>
  .bunn {
    border-top: 1px solid var(--linje);
    margin-top: var(--s-8);
  }

  .indre {
    max-width: 1060px;
    margin: 0 auto;
    padding: var(--s-4) var(--s-6) var(--s-5);
    display: flex;
    align-items: baseline;
    gap: var(--s-4);
    flex-wrap: wrap;
  }

  .merke {
    font-family: var(--font-navnetrekk);
    font-weight: 800;
    font-size: 15px;
    color: var(--tekst);
    text-decoration: none;
    text-transform: lowercase;
  }

  .punktum {
    color: var(--salvie);
  }

  .linje {
    margin: 0;
    font-size: 13px;
    color: var(--dempet);
  }
</style>
