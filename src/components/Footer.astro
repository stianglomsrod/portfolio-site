---
import profil from '../data/profil.json';
import Merke from './Merke.astro';
import { UI, type Spraak } from '../lib/i18n';

interface Props {
  lang?: Spraak;
}

const { lang = 'nb' } = Astro.props;
const t = UI[lang];
const kolofonSti = lang === 'nb' ? '/kolofon' : '/en/colophon';
---

<footer class="bunn">
  <div class="indre">
    <Merke storrelse={15} ariaLabel={t.merkeAria} href={lang === 'nb' ? '/' : '/en/'} />
    <p class="linje">
      {t.bunnLinje}
      <a href={kolofonSti}>{t.bunnKolofon}</a> ·
      <a href={`${kolofonSti}#tilgjengelighet`}>{t.bunnUu}</a> ·
      <a href={`mailto:${profil.kontakt.epost}`}>{t.bunnEpost}</a> ·
      <a href={profil.kontakt.github} rel="me">GitHub</a> ·
      <a href={profil.kontakt.linkedin} rel="me">LinkedIn</a>
    </p>
  </div>
</footer>

<style>
  .bunn {
    border-top: 1px solid var(--linje);
    margin-top: var(--s-8);
  }

  .indre {
    max-width: 1060px;
    margin: 0 auto;
    padding: var(--s-4) var(--s-6) var(--s-5);
    display: flex;
    align-items: baseline;
    gap: var(--s-4);
    flex-wrap: wrap;
  }

  .linje {
    margin: 0;
    font-size: 15px;
    color: var(--dempet);
  }
</style>
