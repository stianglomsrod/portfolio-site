---
/* Hemmelig kode-verktøyet (kryptogram): lærerens ord/setninger kodes
   tegn for tegn, og eleven bruker nøkkelen øverst til å dekode og
   skrive bokstavene under. To nøkkeltyper: tall (fast a=1…å=29 eller
   stokket) og symboler (29 egne SVG-glyfer, alltid stokket). Alt er
   ren algoritme på lærerens egen tekst — fasit er klarteksten. */

interface Props {
  lang?: 'nb' | 'en';
}

const { lang = 'nb' } = Astro.props;

const t =
  lang === 'nb'
    ? {
        tittelFelt: 'Tittel på arket',
        tittelEks: 'Skriv tittelen her',
        ordNavn: 'Ord eller setninger som skal kodes',
        ordEks: 'skriv et ord eller en setning',
        leggTil: '+ Legg til rad',
        noekkel: 'Kodenøkkel',
        noekkelTallFast: 'tall — fast (a=1, b=2 …)',
        noekkelTallStokket: 'tall — hemmelig (stokket)',
        noekkelSymbol: 'symboler (hemmelig)',
        omfang: 'Nøkkelen viser',
        omfangBrukte: 'bare bokstavene som brukes',
        omfangAlle: 'hele alfabetet',
        lag: 'Lag kodeark',
        skrivUt: 'Skriv ut',
        skrivUtFasit: 'Skriv ut fasit',
        visFasit: 'Vis fasit her',
        navnLinje: 'Navn: ____________________   Dato: ____________',
        noekkelTittel: 'Nøkkel',
        instruks: 'Bruk nøkkelen til å finne bokstavene, og skriv dem under tegnene.',
        fasit: 'FASIT',
        standardTittel: 'Hemmelig kode',
      }
    : {
        tittelFelt: 'Sheet title',
        tittelEks: 'Type the title here',
        ordNavn: 'Words or sentences to encode',
        ordEks: 'type a word or a sentence',
        leggTil: '+ Add row',
        noekkel: 'Code key',
        noekkelTallFast: 'numbers — fixed (a=1, b=2 …)',
        noekkelTallStokket: 'numbers — secret (shuffled)',
        noekkelSymbol: 'symbols (secret)',
        omfang: 'The key shows',
        omfangBrukte: 'only the letters that are used',
        omfangAlle: 'the whole alphabet',
        lag: 'Create code sheet',
        skrivUt: 'Print',
        skrivUtFasit: 'Print answer key',
        visFasit: 'Show answers here',
        navnLinje: 'Name: ____________________   Date: ____________',
        noekkelTittel: 'Key',
        instruks: 'Use the key to find the letters and write them under the signs.',
        fasit: 'KEY',
        standardTittel: 'Secret code',
      };
---

<div class="ko-verktoy" data-lang={lang} data-standardtittel={t.standardTittel}>
  <div class="ko-oppsett">
    <section class="ko-panel" aria-labelledby="ko-panel-tittel">
      <h2 id="ko-panel-tittel" class="sr-only">{lang === 'nb' ? 'Oppsett' : 'Setup'}</h2>

      <label class="ko-felt">
        <span class="ko-felt-navn">{t.tittelFelt}</span>
        <input type="text" id="ko-tittel" placeholder={t.tittelEks} maxlength="60" />
      </label>

      <div class="ko-felt">
        <span class="ko-felt-navn" id="ko-ord-navn">{t.ordNavn}</span>
        <ul id="ko-liste" aria-labelledby="ko-ord-navn"></ul>
        <button type="button" id="ko-legg-til" class="ko-sekundaer">{t.leggTil}</button>
      </div>

      <label class="ko-felt">
        <span class="ko-felt-navn">{t.noekkel}</span>
        <select id="ko-noekkel">
          <option value="tall-fast" selected>{t.noekkelTallFast}</option>
          <option value="tall-stokket">{t.noekkelTallStokket}</option>
          <option value="symbol">{t.noekkelSymbol}</option>
        </select>
      </label>

      <label class="ko-felt">
        <span class="ko-felt-navn">{t.omfang}</span>
        <select id="ko-omfang">
          <option value="brukte" selected>{t.omfangBrukte}</option>
          <option value="alle">{t.omfangAlle}</option>
        </select>
      </label>

      <button type="button" id="ko-lag" class="knapp ko-primaer">{t.lag}</button>
      <p id="ko-status" class="ko-status" role="status" aria-live="polite"></p>
    </section>

    <section class="ko-visning" id="ko-ark-seksjon" hidden aria-labelledby="ko-visning-tittel">
      <h2 id="ko-visning-tittel" class="sr-only">
        {lang === 'nb' ? 'Forhåndsvisning' : 'Preview'}
      </h2>
      <div class="ko-handlinger">
        <button type="button" id="ko-skriv-ut" class="knapp ko-primaer">{t.skrivUt}</button>
        <button type="button" id="ko-skriv-ut-fasit" class="ko-sekundaer">{t.skrivUtFasit}</button>
        <button type="button" id="ko-fasit-toggle" class="ko-sekundaer" aria-pressed="false">
          {t.visFasit}
        </button>
      </div>

      <div class="ko-sticky-print">
        <button type="button" id="ko-skriv-ut-sticky" class="ko-sticky-knapp" title="Skriv ut arket (Ctrl+P)" aria-label={t.skrivUt}>
          🖨
        </button>
      </div>

      <div class="ko-ark" id="ko-ark">
        <div class="ko-ark-hode">
          <h3 id="ko-overskrift">{t.standardTittel}</h3>
          <span class="ko-fasit-merke" aria-hidden="true">{t.fasit}</span>
        </div>
        <p class="ko-instruks">{t.instruks}</p>
        <p class="ko-navn-linje">{t.navnLinje}</p>
        <div class="ko-noekkelboks">
          <p class="ko-noekkel-tittel">{t.noekkelTittel}</p>
          <div id="ko-noekkel-grid" class="ko-noekkel-grid"></div>
        </div>
        <ol id="ko-meldinger" class="ko-meldinger"></ol>
      </div>
    </section>
  </div>
</div>

<style is:global>
  .ko-oppsett {
