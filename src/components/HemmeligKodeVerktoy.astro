  }

  .ko-noekkel-tittel {
    margin: 0 0 8px;
    font-weight: 700;
    font-size: 14.5px;
    text-decoration: underline;
    color: #111;
  }

  .ko-noekkel-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 14px;
  }

  .ko-noekkel-par {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    min-width: 26px;
  }

  .ko-noekkel-bokstav {
    font-size: 15px;
    font-weight: 700;
    color: #111;
  }

  .ko-tegn {
    font-size: 15px;
    font-weight: 600;
    color: #111;
    line-height: 1;
  }

  .ko-tegn svg {
    width: 16px;
    height: 16px;
    display: block;
  }

  .ko-meldinger {
    margin: 0;
    padding: 0 0 0 26px;
    display: flex;
    flex-direction: column;
    gap: 26px;
  }

  .ko-melding {
    display: flex;
    flex-wrap: wrap;
    gap: 14px 22px;
  }

  .ko-ord {
