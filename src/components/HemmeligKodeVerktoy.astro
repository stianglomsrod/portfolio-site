      max-width: none;
      min-height: 0;
      background: #fff;
    }

    .ko-oppsett {
      display: block;
      margin: 0;
    }

    .ko-ark {
      border: none;
      box-shadow: none;
      border-radius: 0;
      padding: 0;
      max-width: none;
    }

    .ko-noekkelboks {
      margin-bottom: 9mm;
      break-inside: avoid;
    }

    .ko-meldinger {
      gap: 12mm;
    }

    .ko-meldinger li {
      break-inside: avoid;
    }

    .ko-verktoy:not(.print-fasit) .ko-svar {
      display: none !important;
    }

    .ko-verktoy:not(.print-fasit) .ko-fasit-merke {
      display: none !important;
    }

    .ko-verktoy.print-fasit .ko-svar {
      display: inline !important;
      print-color-adjust: exact;
      -webkit-print-color-adjust: exact;
    }

    .ko-verktoy.print-fasit .ko-strek {
      display: none !important;
    }

    .ko-verktoy.print-fasit .ko-fasit-merke {
      display: inline-block !important;
      print-color-adjust: exact;
      -webkit-print-color-adjust: exact;
    }
  }
</style>

<script>
  import { ALFABET, normaliserOrd, ordErUpassende } from '../lib/ordkryss-kjerne';

  const rot = document.querySelector<HTMLElement>('.ko-verktoy');
  if (rot) {
    const lang = (rot.dataset.lang ?? 'nb') as 'nb' | 'en';
    const standardTittel = rot.dataset.standardtittel ?? 'Hemmelig kode';
    const LAGRINGSNOKKEL = `hemmelig-kode-${lang}`;
    const MAKS = 10;
    const NS = 'http://www.w3.org/2000/svg';
    const BOKSTAVER = ALFABET.toLowerCase().split(''); // a–å (29)

    const M =
      lang === 'nb'
        ? {
            minstEn: 'Skriv inn minst ett ord eller én setning.',
            upassende: (o: string) =>
              `«${o}» passer ikke på et skoleark. Bytt det ut, så lager vi arket.`,
            klart: (n: number, tegn: number) =>
              `Arket er klart: ${n} kodede ${n === 1 ? 'melding' : 'meldinger'} med ${tegn} tegn totalt.`,
            radAria: (i: number) => `Rad ${i}`,
            fjern: (i: number) => `Fjern rad ${i}`,
            radEks: 'skriv et ord eller en setning',
          }
        : {
            minstEn: 'Type at least one word or sentence.',
            upassende: (o: string) =>
              `“${o}” does not belong on a school sheet. Swap it and we will make the sheet.`,
            klart: (n: number, tegn: number) =>
              `The sheet is ready: ${n} coded ${n === 1 ? 'message' : 'messages'} with ${tegn} signs in total.`,
            radAria: (i: number) => `Row ${i}`,
            fjern: (i: number) => `Remove row ${i}`,
            radEks: 'type a word or a sentence',
          };

    interface Rad {
      id: number;
      tekst: string;
    }

    let rader: Rad[] = [];
    let nesteId = 1;
    let fasitSynlig = false;

    const el = <T extends HTMLElement = HTMLElement>(id: string): T =>
      document.getElementById(id) as T;

    /* 29 symbolglyfer: 6 grunnformer × 5 varianter, tegnet som små SVG-er.
       Rekkefølgen stokkes per generering, så nøkkelen er hemmelig. */
    const FORMER = ['sirkel', 'kvadrat', 'trekant', 'diamant', 'kors', 'bue'] as const;
    const VARIANTER = ['tom', 'fylt', 'prikk', 'strek', 'dobbel'] as const;

    function lagSymbol(indeks: number): SVGElement {
      const form = FORMER[indeks % FORMER.length];
      const variant = VARIANTER[Math.floor(indeks / FORMER.length) % VARIANTER.length];
      const svg = document.createElementNS(NS, 'svg');
      svg.setAttribute('viewBox', '0 0 12 12');
      svg.setAttribute('aria-hidden', 'true');
      const fylt = variant === 'fylt';
      const strekAttrs = { fill: fylt ? '#111' : 'none', stroke: '#111', 'stroke-width': '1.1' };
      const legg = (navn: string, attrs: Record<string, string>) => {
        const e = document.createElementNS(NS, navn);
        for (const [k, v] of Object.entries({ ...strekAttrs, ...attrs })) e.setAttribute(k, v);
        svg.appendChild(e);
        return e;
      };
      if (form === 'sirkel') legg('circle', { cx: '6', cy: '5.4', r: '3.6' });
      else if (form === 'kvadrat') legg('rect', { x: '2.6', y: '2', width: '6.8', height: '6.8' });
      else if (form === 'trekant') legg('path', { d: 'M6 1.8 L9.8 8.8 L2.2 8.8 Z' });
      else if (form === 'diamant') legg('path', { d: 'M6 1.6 L9.6 5.4 L6 9.2 L2.4 5.4 Z' });
      else if (form === 'kors') legg('path', { d: 'M6 1.8 V9 M2.4 5.4 H9.6', fill: 'none' });
      else legg('path', { d: 'M2.2 8 A3.9 3.9 0 0 1 9.8 8', fill: 'none' });
      if (variant === 'prikk') legg('circle', { cx: '6', cy: form === 'bue' ? '7' : '5.4', r: '0.9', fill: '#111', stroke: 'none' });
      if (variant === 'strek') legg('path', { d: 'M2.6 11.2 H9.4', fill: 'none' });
      if (variant === 'dobbel') legg('path', { d: 'M2.6 11.2 H9.4 M2.6 9.9 H9.4', fill: 'none', 'stroke-width': '0.85' });
      return svg;
    }

    function lagreUtkast() {
      try {
        localStorage.setItem(
          LAGRINGSNOKKEL,
          JSON.stringify({
            tittel: el<HTMLInputElement>('ko-tittel').value,
            noekkel: el<HTMLSelectElement>('ko-noekkel').value,
            omfang: el<HTMLSelectElement>('ko-omfang').value,
            rader: rader.map((r) => r.tekst),
          })
        );
      } catch {}
    }

    function lastUtkast(): boolean {
      try {
        const raa = localStorage.getItem(LAGRINGSNOKKEL);
        if (!raa) return false;
        const u = JSON.parse(raa);
        el<HTMLInputElement>('ko-tittel').value = u.tittel ?? '';
        (['noekkel', 'omfang'] as const).forEach((navn) => {
          const felt = el<HTMLSelectElement>(`ko-${navn}`);
          if ([...felt.options].some((o) => o.value === u[navn])) felt.value = u[navn];
        });
        (u.rader ?? []).forEach((r: unknown) => {
          if (typeof r === 'string') rader.push({ id: nesteId++, tekst: r });
        });
        return rader.length > 0;
      } catch {
        return false;
      }
    }

    function leggTil(tekst = '') {
      if (rader.length >= MAKS) return;
      rader.push({ id: nesteId++, tekst });
      tegnListe();
    }

    function tegnListe() {
      const liste = el('ko-liste');
      liste.replaceChildren();
      rader.forEach((rad, indeks) => {
        const li = document.createElement('li');
        li.className = 'ko-rad';
        const felt = document.createElement('input');
        felt.type = 'text';
        felt.value = rad.tekst.slice(0, 40);
        felt.maxLength = 40;
        felt.placeholder = M.radEks;
        felt.setAttribute('aria-label', M.radAria(indeks + 1));
        felt.addEventListener('input', () => {
          rad.tekst = felt.value;
          const stygt = felt.value.split(/\s+/).some((o) => ordErUpassende(o));
          li.classList.toggle('upassende', stygt);
          felt.setAttribute('aria-invalid', stygt ? 'true' : 'false');
          lagreUtkast();
        });
        const fjern = document.createElement('button');
        fjern.type = 'button';
        fjern.className = 'ko-ikonknapp';
        fjern.textContent = '✕';
        fjern.setAttribute('aria-label', M.fjern(indeks + 1));
        fjern.addEventListener('click', () => {
          rader = rader.filter((r) => r.id !== rad.id);
          if (rader.length === 0) leggTil();
          tegnListe();
          lagreUtkast();
        });
        li.append(felt, fjern);
        liste.appendChild(li);
      });
      el<HTMLButtonElement>('ko-legg-til').disabled = rader.length >= MAKS;
    }

    function siStatus(tekst: string, erFeil = false) {
      const status = el('ko-status');
      status.textContent = tekst;
      status.classList.toggle('feil', erFeil);
    }

    /* Tegnet for en bokstav, som DOM-element */
    function lagTegn(
      bokstav: string,
      noekkelType: string,
      tallkode: Map<string, number>,
      symbolkode: Map<string, number>
    ): HTMLElement {
      const holder = document.createElement('span');
      holder.className = 'ko-tegn';
      if (noekkelType === 'symbol') {
        holder.appendChild(lagSymbol(symbolkode.get(bokstav) ?? 0));
      } else {
        holder.textContent = String(tallkode.get(bokstav) ?? '?');
      }
      return holder;
    }

    function generer() {
      const rene = rader.map((r) => r.tekst.trim().replace(/\s+/g, ' ')).filter(Boolean);
      if (rene.length === 0) {
        siStatus(M.minstEn, true);
        return;
      }
      for (const tekst of rene) {
        for (const ord of tekst.split(' ')) {
          if (ordErUpassende(ord)) {
            siStatus(M.upassende(ord), true);
            return;
          }
        }
      }

      const noekkelType = el<HTMLSelectElement>('ko-noekkel').value;
      const omfang = el<HTMLSelectElement>('ko-omfang').value;

      // kodene: tall 1–29 (fast eller stokket) og symbolindeks (stokket)
      const tall = BOKSTAVER.map((_, i) => i + 1);
      const symboler = BOKSTAVER.map((_, i) => i);
      const stokk = (a: number[]) => {
        for (let i = a.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          [a[i], a[j]] = [a[j], a[i]];
        }
      };
      if (noekkelType === 'tall-stokket') stokk(tall);
      stokk(symboler);
      const tallkode = new Map(BOKSTAVER.map((b, i) => [b, tall[i]]));
      const symbolkode = new Map(BOKSTAVER.map((b, i) => [b, symboler[i]]));

      el('ko-overskrift').textContent =
        el<HTMLInputElement>('ko-tittel').value.trim() || standardTittel;

      // meldingene: normaliser hvert ord til a–å (annet strippes)
      const meldinger = rene
        .map((tekst) =>
          tekst
            .split(' ')
            .map((ord) => normaliserOrd(ord).toLowerCase())
            .filter(Boolean)
        )
        .filter((ord) => ord.length > 0);

      const brukte = new Set<string>();
      meldinger.forEach((ord) => ord.forEach((o) => o.split('').forEach((b) => brukte.add(b))));

      // nøkkelen
      const grid = el('ko-noekkel-grid');
      grid.replaceChildren();
      BOKSTAVER.filter((b) => omfang === 'alle' || brukte.has(b)).forEach((bokstav) => {
        const par = document.createElement('span');
        par.className = 'ko-noekkel-par';
        const bok = document.createElement('span');
        bok.className = 'ko-noekkel-bokstav';
        bok.textContent = bokstav;
        par.appendChild(bok);
        par.appendChild(lagTegn(bokstav, noekkelType, tallkode, symbolkode));
        grid.appendChild(par);
      });

      // meldingene som celler
      const liste = el('ko-meldinger');
      liste.replaceChildren();
      let antallTegn = 0;
      meldinger.forEach((ordListe) => {
        const li = document.createElement('li');
        const melding = document.createElement('span');
        melding.className = 'ko-melding';
        ordListe.forEach((ord) => {
          const ordEl = document.createElement('span');
          ordEl.className = 'ko-ord';
          ord.split('').forEach((bokstav) => {
            antallTegn++;
            const celle = document.createElement('span');
            celle.className = 'ko-celle';
            celle.appendChild(lagTegn(bokstav, noekkelType, tallkode, symbolkode));
            const strek = document.createElement('span');
            strek.className = 'ko-strek';
            strek.textContent = '__';
            const svar = document.createElement('span');
            svar.className = 'ko-svar';
            svar.textContent = bokstav;
            celle.append(strek, svar);
            ordEl.appendChild(celle);
          });
          melding.appendChild(ordEl);
        });
        li.appendChild(melding);
        liste.appendChild(li);
      });

      fasitSynlig = false;
      el('ko-fasit-toggle').setAttribute('aria-pressed', 'false');
      rot.classList.remove('fasit-paa');

      el('ko-ark-seksjon').removeAttribute('hidden');
      siStatus(M.klart(meldinger.length, antallTegn));
      lagreUtkast();
    }

    if (!lastUtkast()) {
      leggTil();
      leggTil();
      leggTil();
    }
    tegnListe();

    el('ko-legg-til').addEventListener('click', () => {
      leggTil();
      lagreUtkast();
    });

    el('ko-lag').addEventListener('click', generer);

    el('ko-fasit-toggle').addEventListener('click', () => {
      fasitSynlig = !fasitSynlig;
      el('ko-fasit-toggle').setAttribute('aria-pressed', String(fasitSynlig));
      rot.classList.toggle('fasit-paa', fasitSynlig);
    });

    const skrivUt = () => {
      rot.classList.remove('print-fasit');
      window.print();
    };
    el('ko-skriv-ut').addEventListener('click', skrivUt);
    el('ko-skriv-ut-sticky').addEventListener('click', skrivUt);
    el('ko-skriv-ut-fasit').addEventListener('click', () => {
      rot.classList.add('print-fasit');
      window.print();
    });
    window.addEventListener('afterprint', () => rot.classList.remove('print-fasit'));

    ['ko-tittel', 'ko-noekkel', 'ko-omfang'].forEach((id) =>
      el(id).addEventListener('change', lagreUtkast)
    );
  }
</script>
