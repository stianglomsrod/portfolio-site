---
import now from '../data/now.json';
import { hentHeatmap, hentSisteCommits } from '../lib/github';

/* Hero v3 («Åpningstider»): én levende setning i klartekst som skriver seg
   selv fra now.json, med beviset (aktivitetsmatrisen) rett under påstanden.
   Salvie-ordene er de levende (API-drevne). H1 = hele setningen — den ER
   semantisk. Ingen kode-estetikk. */

interface Props {
  lang?: 'nb' | 'en';
}

const { lang = 'nb' } = Astro.props;

const heatmap = await hentHeatmap();
const [sisteCommit] = await hentSisteCommits(1);

/* Matrisen viser siste 30 dager (året ble for glissent); summen oppgir
   begge tidsrom. Tooltip per dag er ren CSS (matrisen er dekorativ —
   skjermlesere får tallene i klartekst). */
const sisteDager = heatmap
  ? heatmap.uker.flatMap((u) => u.dager).slice(-30)
  : [];
const maanedTotal = sisteDager.reduce((sum, d) => sum + d.antall, 0);
const datoTekst = (iso: string) =>
  new Date(iso).toLocaleDateString(lang === 'nb' ? 'nb-NO' : 'en-GB', {
    day: 'numeric',
    month: 'long',
  });

const naa = Date.now();
const sistAktiv = sisteCommit ? new Date(sisteCommit.tidspunkt).getTime() : 0;
const dagerSiden = (naa - sistAktiv) / 86_400_000;

/* Tekster per språk; de levende verdiene kommer fra now.json */
const kursStatus = lang === 'nb' ? now.kursStatus : now.en.kursStatus;
const soker = lang === 'nb' ? now.soker : now.en.soker;
const notis = lang === 'nb' ? now.notis : now.en.notis;
const t =
  lang === 'nb'
    ? {
        label: 'Akkurat nå',
        jobberMed: 'Jobber med',
        i: 'i',
        bidragMnd: (n: number) => `${n} bidrag siste måneden`,
        bidragAar: (n: number) => `· ${n} siste år`,
        srOppsummering: (mnd: number, aar: number) =>
          `${mnd} bidrag siste måneden, ${aar} siste år.`,
        tipTekst: (antall: number, dato: string) => `${antall} bidrag ${dato}`,
        fallback: 'Aktivitetsmatrisen kobles på når GitHub-tokenet er satt.',
        aktivIdag: 'aktiv i dag',
        aktivUka: 'aktiv denne uka',
        sokerLinje: 'Søker',
        jobb: '-jobb',
        cta: 'ta kontakt',
      }
    : {
        label: 'Right now',
        jobberMed: 'Working through',
        i: 'of',
        bidragMnd: (n: number) => `${n} contributions in the last month`,
        bidragAar: (n: number) => `· ${n} in the last year`,
        srOppsummering: (mnd: number, aar: number) =>
          `${mnd} contributions in the last month, ${aar} in the last year.`,
        tipTekst: (antall: number, dato: string) =>
          `${antall} contributions on ${dato}`,
        fallback: 'The activity matrix connects once the GitHub token is set.',
        aktivIdag: 'active today',
        aktivUka: 'active this week',
        sokerLinje: 'Looking for a',
        jobb: ' role',
        cta: 'get in touch',
      };

const ferskhet =
  dagerSiden < 1 ? t.aktivIdag : dagerSiden < 7 ? t.aktivUka : null;

/* Notisen fra now.json går inn i selve setningen. «Fable 5» får
   levende-markering når det står i teksten. */
const notisDeler = notis ? notis.split('Fable 5') : null;
const ctaHref = lang === 'nb' ? '/om#kontakt' : '/en/about#kontakt';
---

<section class="hero" aria-labelledby="hero-h1">
  <p class="label">{t.label}</p>

  <h1 id="hero-h1" class="setning">
    {t.jobberMed} {kursStatus} {t.i} <span class="levende">{now.kurs}</span>.
    {notisDeler && notisDeler.length === 2 && (
      <>
        {notisDeler[0]}<span class="levende">Fable 5</span>{notisDeler[1]}.
      </>
    )}
    {notisDeler && notisDeler.length !== 2 && <>{notis}.</>}
  </h1>

  <div class="bevis">
    {heatmap && (
      <>
        <p class="sr-only">{t.srOppsummering(maanedTotal, heatmap.totalt)}</p>
        <div class="matrise-scroller">
          <div class="matrise" aria-hidden="true">
            {sisteDager.map((dag) => (
              <span
                class={`rute niv-${dag.nivaa}`}
                data-tip={t.tipTekst(dag.antall, datoTekst(dag.dato))}
              ></span>
            ))}
          </div>
        </div>
      </>
    )}
    <p class="bevis-linje">
      {heatmap ? (
        <>
          <span class="levende">{t.bidragMnd(maanedTotal)}</span>
          <span class="aarstall">{t.bidragAar(heatmap.totalt)}</span>
        </>
      ) : (
        <span class="dempet">{t.fallback}</span>
      )}
      {ferskhet && (
        <span class="fersk">
          <span class="puls-dot" aria-hidden="true"></span>
          {ferskhet}
        </span>
      )}
    </p>
  </div>

  <p class="cta-linje">
    {t.sokerLinje} {soker}{t.jobb}<span class="cta-pil" aria-hidden="true"> →</span>
    <a class="cta knapp" href={ctaHref}>{t.cta}</a>
  </p>
</section>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    gap: var(--s-5);
    padding-top: var(--s-8);
    max-width: 760px;
  }

  .setning {
    margin: 0;
    font-family: var(--font-hd);
    font-weight: 700;
    font-size: var(--tekst-hero);
    line-height: 1.18;
    letter-spacing: -0.01em;
    color: var(--tekst);
    max-width: 24ch;
  }

  /* Salvie kun om det levende: API-drevne ord, puls, CTA, aktivitet */
  .levende {
    color: var(--salvie);
  }

  .dempet {
    color: var(--dempet);
  }

  .bevis {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }

  /* Ingen scroll: rutene skalerer med plassen i stedet (aldri scrollbar).
     minmax(0, 18px) gir 18px-ruter når det er plass og jevnt krympende
     ruter når det ikke er det. */
  .matrise {
    display: grid;
    grid-template-columns: repeat(30, minmax(0, 18px));
    gap: 4px;
    padding: 3px;
  }

  .rute {
    width: auto;
    aspect-ratio: 1;
    border-radius: 4px;
    display: block;
    position: relative;
  }

  .rute:hover {
    outline: 1px solid var(--dempet);
    outline-offset: 1px;
  }

  .rute:hover::after {
    content: attr(data-tip);
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    background: var(--flate);
    color: var(--tekst);
    border: 1px solid var(--linje);
    border-radius: var(--radius-sm);
    padding: 4px 9px;
    font-size: 14px;
    white-space: nowrap;
    pointer-events: none;
    z-index: 2;
  }

  .matrise .rute:first-child:hover::after,
  .matrise .rute:nth-child(2):hover::after {
    left: 0;
    transform: none;
  }

  .matrise .rute:last-child:hover::after,
  .matrise .rute:nth-last-child(2):hover::after {
    left: auto;
    right: 0;
    transform: none;
  }

  .aarstall {
    color: var(--dempet);
    font-size: 16px;
  }

  .niv-0 { background: var(--heat-0); }
  .niv-1 { background: var(--heat-1); }
  .niv-2 { background: var(--heat-2); }
  .niv-3 { background: var(--heat-3); }
  .niv-4 { background: var(--heat-4); }

  .bevis-linje {
    margin: 0;
    font-size: 16px;
    display: flex;
    align-items: center;
    gap: var(--s-3);
    flex-wrap: wrap;
  }

  .fersk {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    color: var(--salvie);
    font-size: 16px;
  }

  /* Puls 2.6s, maks 8px — én puls synlig av gangen; statisk ved reduced motion */
  .puls-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--salvie);
    animation: puls 2.6s ease-out infinite;
    flex-shrink: 0;
  }

  @keyframes puls {
    0%,
    100% {
      box-shadow: 0 0 0 0 color-mix(in srgb, var(--salvie) 45%, transparent);
    }
    70% {
      box-shadow: 0 0 0 8px transparent;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .puls-dot {
      animation: none;
    }
  }

  .cta-linje {
    margin: 0;
    font-size: 17px;
    line-height: 1.6;
    color: var(--tekst);
    max-width: 46ch;
  }

  .cta {
    display: inline-block;
    font-family: var(--font-hd);
    font-weight: 700;
    font-size: 16px;
    background: var(--salvie);
    color: var(--salvie-kontrast);
    text-decoration: none;
    padding: 9px 18px;
    border-radius: var(--radius-sm);
    margin-left: var(--s-1);
  }

  .cta:hover {
    filter: brightness(1.06);
  }

  .cta:focus-visible {
    outline: 2px solid var(--tekst);
    outline-offset: 2px;
  }

  /* Mobil: heroen eier hele første skjermbilde — CTA-en nederst som
     naturlig endepunkt, og «Utvalgte prosjekter» først ved scroll.
     Pila droppes: den peker på knappen når de deler linje (desktop),
     men på mobil brekker knappen ned og pila pekte ut i lufta. */
  @media (max-width: 680px) {
    .hero {
      min-height: calc(100svh - 96px);
      padding-bottom: var(--s-5);
    }

    .cta-linje {
      margin-top: auto;
    }

    .cta-pil {
      display: none;
    }

    .cta {
      display: block;
      width: fit-content;
      margin: var(--s-4) 0 0;
      padding: 12px 26px;
    }
  }
</style>
