---
import now from '../../now.json';
import { hentHeatmap, hentSisteCommits } from '../lib/github';

/* Hero v3 («Åpningstider»): én levende setning i klartekst som skriver seg
   selv fra now.json, med beviset (aktivitetsmatrisen) rett under påstanden.
   Salvie-ordene er de levende (API-drevne). H1 = hele setningen — den ER
   semantisk. Ingen kode-estetikk. */

const heatmap = await hentHeatmap();
const [sisteCommit] = await hentSisteCommits(1);

/* Matrisen viser siste 30 dager (året ble for glissent); summen oppgir
   begge tidsrom. Tooltip per dag er ren CSS (matrisen er dekorativ —
   skjermlesere får tallene i klartekst). */
const sisteDager = heatmap
  ? heatmap.uker.flatMap((u) => u.dager).slice(-30)
  : [];
const maanedTotal = sisteDager.reduce((sum, d) => sum + d.antall, 0);
const datoTekst = (iso: string) =>
  new Date(iso).toLocaleDateString('nb-NO', { day: 'numeric', month: 'long' });

const naa = Date.now();
const sistAktiv = sisteCommit ? new Date(sisteCommit.tidspunkt).getTime() : 0;
const dagerSiden = (naa - sistAktiv) / 86_400_000;
const ferskhet =
  dagerSiden < 1 ? 'aktiv i dag' : dagerSiden < 7 ? 'aktiv denne uka' : null;
---

<section class="hero" aria-labelledby="hero-h1">
  <p class="label">Akkurat nå</p>

  <h1 id="hero-h1" class="setning">
    Tar {now.kursStatus} i <span class="levende">{now.kurs}</span>, og
    {now.ki} med <span class="levende">{now.kiVerktoy}</span>.
  </h1>

  <div class="bevis">
    {heatmap && (
      <>
        <p class="sr-only">
          {maanedTotal} bidrag siste måneden, {heatmap.totalt} siste år.
        </p>
        <div class="matrise-scroller">
          <div class="matrise" aria-hidden="true">
            {sisteDager.map((dag) => (
              <span
                class={`rute niv-${dag.nivaa}`}
                data-tip={`${dag.antall} bidrag ${datoTekst(dag.dato)}`}
              ></span>
            ))}
          </div>
        </div>
      </>
    )}
    <p class="bevis-linje">
      {heatmap ? (
        <>
          <span class="levende">{maanedTotal} bidrag siste måneden</span>
          <span class="aarstall">· {heatmap.totalt} siste år</span>
        </>
      ) : (
        <span class="dempet">
          Aktivitetsmatrisen kobles på når GitHub-tokenet er satt.
        </span>
      )}
      {ferskhet && (
        <span class="fersk">
          <span class="puls-dot" aria-hidden="true"></span>
          {ferskhet}
        </span>
      )}
    </p>
  </div>

  <p class="cta-linje">
    Søker {now.soker}-jobb —
    <a class="cta knapp" href="/om#kontakt">ta kontakt</a>
  </p>
</section>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    gap: var(--s-5);
    padding-top: var(--s-8);
    max-width: 760px;
  }

  .setning {
    margin: 0;
    font-family: var(--font-hd);
    font-weight: 700;
    font-size: var(--tekst-hero);
    line-height: 1.18;
    letter-spacing: -0.01em;
    color: var(--tekst);
    max-width: 18ch;
  }

  /* Salvie kun om det levende: API-drevne ord, puls, CTA, aktivitet */
  .levende {
    color: var(--salvie);
  }

  .dempet {
    color: var(--dempet);
  }

  .bevis {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }

  .matrise-scroller {
    overflow-x: auto;
  }

  @media (max-width: 680px) {
    .matrise-scroller {
      mask-image: linear-gradient(90deg, #000 calc(100% - 16px), transparent);
    }
  }

  .matrise {
    display: flex;
    gap: 4px;
    width: max-content;
    /* luft rundt rutene så tooltip (over) og hover-outline (under/sider)
       ikke klippes av scrollerens overflow */
    padding: 34px 3px 3px;
  }

  .rute {
    width: 18px;
    height: 18px;
    border-radius: 4px;
    display: block;
    position: relative;
  }

  .rute:hover {
    outline: 1px solid var(--dempet);
    outline-offset: 1px;
  }

  .rute:hover::after {
    content: attr(data-tip);
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    background: var(--flate);
    color: var(--tekst);
    border: 1px solid var(--linje);
    border-radius: var(--radius-sm);
    padding: 4px 9px;
    font-size: 12.5px;
    white-space: nowrap;
    pointer-events: none;
    z-index: 2;
  }

  .matrise .rute:first-child:hover::after,
  .matrise .rute:nth-child(2):hover::after {
    left: 0;
    transform: none;
  }

  .matrise .rute:last-child:hover::after,
  .matrise .rute:nth-last-child(2):hover::after {
    left: auto;
    right: 0;
    transform: none;
  }

  .aarstall {
    color: var(--dempet);
    font-size: 14px;
  }

  .niv-0 { background: var(--heat-0); }
  .niv-1 { background: var(--heat-1); }
  .niv-2 { background: var(--heat-2); }
  .niv-3 { background: var(--heat-3); }
  .niv-4 { background: var(--heat-4); }

  .bevis-linje {
    margin: 0;
    font-size: 15px;
    display: flex;
    align-items: center;
    gap: var(--s-3);
    flex-wrap: wrap;
  }

  .fersk {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    color: var(--salvie);
    font-size: 14px;
  }

  /* Puls 2.6s, maks 8px — én puls synlig av gangen; statisk ved reduced motion */
  .puls-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--salvie);
    animation: puls 2.6s ease-out infinite;
    flex-shrink: 0;
  }

  @keyframes puls {
    0%,
    100% {
      box-shadow: 0 0 0 0 color-mix(in srgb, var(--salvie) 45%, transparent);
    }
    70% {
      box-shadow: 0 0 0 8px transparent;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .puls-dot {
      animation: none;
    }
  }

  .cta-linje {
    margin: 0;
    font-size: 17px;
    line-height: 1.6;
    color: var(--tekst);
    max-width: 46ch;
  }

  .cta {
    display: inline-block;
    font-family: var(--font-hd);
    font-weight: 700;
    font-size: 15px;
    background: var(--salvie);
    color: var(--salvie-kontrast);
    text-decoration: none;
    padding: 9px 18px;
    border-radius: var(--radius-sm);
    margin-left: var(--s-1);
  }

  .cta:hover {
    filter: brightness(1.06);
  }

  .cta:focus-visible {
    outline: 2px solid var(--tekst);
    outline-offset: 2px;
  }
</style>
