---
import now from '../../now.json';
import { hentHeatmap, hentSisteCommits } from '../lib/github';

/* Hero v3 («Åpningstider»): én levende setning i klartekst som skriver seg
   selv fra now.json, med beviset (aktivitetsmatrisen) rett under påstanden.
   Salvie-ordene er de levende (API-drevne). H1 = hele setningen — den ER
   semantisk. Ingen kode-estetikk. */

const heatmap = await hentHeatmap();
const [sisteCommit] = await hentSisteCommits(1);

const naa = Date.now();
const sistAktiv = sisteCommit ? new Date(sisteCommit.tidspunkt).getTime() : 0;
const dagerSiden = (naa - sistAktiv) / 86_400_000;
const ferskhet =
  dagerSiden < 1 ? 'aktiv i dag' : dagerSiden < 7 ? 'aktiv denne uka' : null;
---

<section class="hero" aria-labelledby="hero-h1">
  <p class="label">Akkurat nå</p>

  <h1 id="hero-h1" class="setning">
    Tar <span class="levende">{now.kurs}</span>
    <span class="status">({now.kursStatus})</span>, og {now.ki} med
    <span class="levende">{now.kiVerktoy}</span>.
  </h1>

  <div class="bevis">
    {heatmap && (
      <>
        <p class="sr-only">{heatmap.totalt} bidrag siste år.</p>
        <div class="matrise-scroller">
          <div class="matrise" aria-hidden="true">
            {heatmap.uker.map((uke) => (
              <div class="uke">
                {uke.dager.map((dag) => (
                  <span class={`rute niv-${dag.nivaa}`}></span>
                ))}
              </div>
            ))}
          </div>
        </div>
      </>
    )}
    <p class="bevis-linje">
      {heatmap ? (
        <>
          <span class="levende">{heatmap.totalt} bidrag siste år</span>
          <span class="dempet"> — jevnt, ikke skippertak</span>
        </>
      ) : (
        <span class="dempet">
          Aktivitetsmatrisen kobles på når GitHub-tokenet er satt.
        </span>
      )}
      {ferskhet && (
        <span class="fersk">
          <span class="puls-dot" aria-hidden="true"></span>
          {ferskhet}
        </span>
      )}
    </p>
  </div>

  <p class="cta-linje">
    Søker {now.soker}-jobb —
    <a class="cta knapp" href="/om#kontakt">ta kontakt</a>
  </p>
</section>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    gap: var(--s-5);
    padding-top: var(--s-8);
    max-width: 760px;
  }

  .setning {
    margin: 0;
    font-family: var(--font-hd);
    font-weight: 700;
    font-size: var(--tekst-hero);
    line-height: 1.18;
    letter-spacing: -0.01em;
    color: var(--tekst);
    max-width: 18ch;
  }

  /* Salvie kun om det levende: API-drevne ord, puls, CTA, aktivitet */
  .levende {
    color: var(--salvie);
  }

  .status {
    color: var(--dempet);
    font-weight: 600;
    font-size: 0.62em;
  }

  .dempet {
    color: var(--dempet);
  }

  .bevis {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }

  .matrise-scroller {
    overflow-x: auto;
  }

  @media (max-width: 680px) {
    .matrise-scroller {
      mask-image: linear-gradient(90deg, #000 calc(100% - 16px), transparent);
    }
  }

  .matrise {
    display: flex;
    gap: 3px;
    width: max-content;
  }

  .uke {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .rute {
    width: 11px;
    height: 11px;
    border-radius: 2.5px;
    display: block;
  }

  .niv-0 { background: var(--heat-0); }
  .niv-1 { background: var(--heat-1); }
  .niv-2 { background: var(--heat-2); }
  .niv-3 { background: var(--heat-3); }
  .niv-4 { background: var(--heat-4); }

  .bevis-linje {
    margin: 0;
    font-size: 15px;
    display: flex;
    align-items: center;
    gap: var(--s-3);
    flex-wrap: wrap;
  }

  .fersk {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    color: var(--salvie);
    font-size: 14px;
  }

  /* Puls 2.6s, maks 8px — én puls synlig av gangen; statisk ved reduced motion */
  .puls-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--salvie);
    animation: puls 2.6s ease-out infinite;
    flex-shrink: 0;
  }

  @keyframes puls {
    0%,
    100% {
      box-shadow: 0 0 0 0 color-mix(in srgb, var(--salvie) 45%, transparent);
    }
    70% {
      box-shadow: 0 0 0 8px transparent;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .puls-dot {
      animation: none;
    }
  }

  .cta-linje {
    margin: 0;
    font-size: 17px;
    line-height: 1.6;
    color: var(--tekst);
    max-width: 46ch;
  }

  .cta {
    display: inline-block;
    font-family: var(--font-hd);
    font-weight: 700;
    font-size: 15px;
    background: var(--salvie);
    color: var(--salvie-kontrast);
    text-decoration: none;
    padding: 9px 18px;
    border-radius: var(--radius-sm);
    margin-left: var(--s-1);
  }

  .cta:hover {
    filter: brightness(1.06);
  }

  .cta:focus-visible {
    outline: 2px solid var(--tekst);
    outline-offset: 2px;
  }
</style>
