---
/* Hue-parametre: to oklch-vinkler styrer hele sidens palett. Grunnfarge
   styrer flater/tekst, aksent styrer salvie/overskrifter/heatmap — og
   følger grunnfargen til den løsnes. L og C er låst i tokens, så
   AA-kontrasten holder uansett tone. Persisteres i localStorage
   ('hue'/'hue2', cookiefritt) og leses inn før first paint på alle
   sider (Base.astro). Tilbakestill-knappen tar deg til guidens grønne. */

interface Props {
  lang?: 'nb' | 'en';
}

const { lang = 'nb' } = Astro.props;

const t =
  lang === 'nb'
    ? {
        grunnfarge: 'grunnfarge',
        aksent: 'aksent',
        tilbakestill: 'fabrikkinnstillinger',
        spec: 'to @property-registrerte oklch-vinkler · L/C låst så AA-kontrasten holder uansett tone · huskes i localStorage (cookiefritt) og følger deg på hele siden · grunnfargen flytter hele paletten; aksenten justerer avstanden mellom dem',
      }
    : {
        grunnfarge: 'base hue',
        aksent: 'accent',
        tilbakestill: 'factory settings',
        spec: 'two @property-registered oklch angles · L/C locked so AA contrast holds at any hue · remembered in localStorage (no cookies) and follows you across the site · the base hue moves the whole palette; the accent adjusts the distance between them',
      };
---

<div class="hue-modul">
  <div class="hue-topp">
    <span class="hue-label">MODUL C · HUE-PARAMETER</span>
  </div>

  <div class="hue-rad">
    <label class="hue-navn" for="hue-slider">{t.grunnfarge}</label>
    <input
      type="range"
      id="hue-slider"
      min="0"
      max="360"
      step="1"
      value="158"
    />
    <span class="hue-verdi" id="hue-verdi" aria-live="polite">#…</span>
  </div>

  <div class="hue-rad">
    <label class="hue-navn" for="hue2-slider">{t.aksent}</label>
    <input
      type="range"
      id="hue2-slider"
      min="0"
      max="360"
      step="1"
      value="158"
    />
    <span class="hue-verdi" id="hue2-verdi" aria-live="polite">#…</span>
  </div>


  <div class="hue-bunn">
    <div class="hue-chips" aria-hidden="true">
      <span class="hue-chip aksent"></span>
      <span class="hue-chip flate"></span>
    </div>
    <button type="button" id="hue-reset" class="hue-tilbakestill">
      {t.tilbakestill}
    </button>
  </div>

  <p class="hue-spec">{t.spec}</p>
</div>

<style>
  /* Ingen egen max-width: konteksten (grid-sporet) bestemmer bredden,
     så høyrekanten alltid flukter med naboene */
  .hue-modul {
    background: var(--flate);
    border: 1px solid var(--linje);
    border-radius: var(--radius-md);
    box-shadow: var(--kort-skygge);
    padding: var(--s-4);
  }

  .hue-topp {
    margin-bottom: var(--s-3);
  }

  .hue-label {
    font-family: var(--font-hd);
    font-size: 12px;
    letter-spacing: 0.1em;
    color: var(--hue-aksent);
  }

  .hue-rad {
    display: grid;
    grid-template-columns: 84px 1fr 72px;
    align-items: center;
    gap: var(--s-2);
  }


  .hue-navn {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: 13.5px;
    color: var(--dempet);
  }

  .hue-verdi {
    font-family: var(--font-hd);
    font-size: 13.5px;
    color: var(--hue-aksent);
    text-align: right;
  }

  input[type='range'] {
    width: 100%;
    accent-color: var(--hue-aksent);
    cursor: pointer;
    min-height: 44px; /* WCAG-målstørrelse */
    margin: 0;
  }

  input[type='range']:focus-visible {
    outline: 2px solid var(--hue-aksent);
    outline-offset: 2px;
  }

  .hue-bunn {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--s-3);
    margin-top: var(--s-2);
  }

  .hue-chips {
    display: flex;
    gap: var(--s-2);
  }

  .hue-chip {
    width: 28px;
    height: 16px;
    border-radius: 4px;
    border: 1px solid var(--linje);
  }

  .hue-chip.aksent {
    background: var(--hue-aksent);
  }

  .hue-chip.flate {
    background: var(--hue-flate);
  }

  .hue-tilbakestill {
    all: unset;
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: 13px;
    color: var(--dempet);
    border: 1px solid var(--linje);
    border-radius: var(--radius-sm);
    padding: 8px 12px;
    min-height: 44px; /* WCAG-målstørrelse */
    box-sizing: border-box;
    display: inline-flex;
    align-items: center;
    cursor: pointer;
    transition: color var(--dur-mikro), border-color var(--dur-mikro);
  }

  .hue-tilbakestill:hover {
    color: var(--tekst);
    border-color: var(--dempet);
  }

  .hue-tilbakestill:focus-visible {
    outline: 2px solid var(--hue-aksent);
    outline-offset: 2px;
  }

  .hue-spec {
    font-family: var(--font-hd);
    font-size: 13px;
    line-height: 1.7;
    color: var(--dempet);
    margin: var(--s-3) 0 0;
  }

  .hue-spec code {
    color: var(--dempet);
  }
</style>

<script>
  import {
    STANDARD_HUE,
    lesHue,
    lesHue2,
    gjeldendeHue2,
    settHue,
    settHue2,
    tilbakestillHue,
  } from '../lib/hue';

  const slider = document.getElementById('hue-slider') as HTMLInputElement | null;
  const slider2 = document.getElementById('hue2-slider') as HTMLInputElement | null;
  const verdi = document.getElementById('hue-verdi');
  const verdi2 = document.getElementById('hue2-verdi');
  const reset = document.getElementById('hue-reset');
  const chipFlate = document.querySelector<HTMLElement>('.hue-chip.flate');
  const chipAksent = document.querySelector<HTMLElement>('.hue-chip.aksent');

  /* Hex-visning: chipene VISER fargene, så vi leser dem derfra via canvas
     (computed-strengen kan være oklch() — piksellesing er eneste trygge
     vei til hex). Fargene glir i 650ms (.hue-glir), så vi oppdaterer både
     underveis og en gang til når gliden er ferdig. */
  const lerret = document.createElement('canvas');
  lerret.width = lerret.height = 1;
  const ctx = lerret.getContext('2d', { willReadFrequently: true });

  const tilHex = (cssFarge: string): string => {
    if (!ctx) return '';
    ctx.fillStyle = '#000000';
    ctx.fillStyle = cssFarge;
    ctx.fillRect(0, 0, 1, 1);
    const [r, g, b] = ctx.getImageData(0, 0, 1, 1).data;
    return (
      '#' +
      [r, g, b].map((v) => v.toString(16).padStart(2, '0')).join('').toUpperCase()
    );
  };

  let hexEtterGlid: ReturnType<typeof setTimeout> | undefined;

  const lesHexNaa = () => {
    if (verdi && chipFlate)
      verdi.textContent = tilHex(getComputedStyle(chipFlate).backgroundColor);
    if (verdi2 && chipAksent)
      verdi2.textContent = tilHex(getComputedStyle(chipAksent).backgroundColor);
  };

  const oppdaterHex = () => {
    lesHexNaa();
    clearTimeout(hexEtterGlid);
    hexEtterGlid = setTimeout(lesHexNaa, 720);
  };

  const visGrunn = (h: number) => {
    if (slider) slider.value = String(h);
  };

  const visAksent = (h: number) => {
    if (slider2) slider2.value = String(h);
  };

  // Init fra lagrede verdier; aksenten står der paletten faktisk står
  const lagret = lesHue();
  const lagret2 = lesHue2();
  if (lagret !== null) visGrunn(lagret);
  visAksent(lagret2 ?? lagret ?? STANDARD_HUE);
  oppdaterHex();

  slider?.addEventListener('input', () => {
    const h = Number(slider.value);
    settHue(h, true);
    visGrunn(h);
    // Aksenten følger alltid med (speiling eller bevart avstand)
    visAksent(gjeldendeHue2());
    oppdaterHex();
  });

  slider2?.addEventListener('input', () => {
    const h = Number(slider2.value);
    settHue2(h, true);
    visAksent(h);
    oppdaterHex();
  });

  reset?.addEventListener('click', () => {
    tilbakestillHue();
    visGrunn(STANDARD_HUE);
    visAksent(STANDARD_HUE);
    oppdaterHex();
  });

  // Hex-verdiene avhenger av temaets L/C — oppdater ved temabytte
  new MutationObserver(oppdaterHex).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-theme'],
  });
</script>
