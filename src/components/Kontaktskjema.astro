---
import profil from '../data/profil.json';

/* Kontaktskjema (Done 8): klarspråkvalidering med ikon (aldri farge alene),
   feil koblet via aria-describedby, honeypot + tidsstempel. JS sender som
   JSON til /api/kontakt; uten JS står mailto-lenken under som fullverdig vei.
   Skjermtekster følger sidens språk; JS-meldingene leser <html lang>. */

interface Props {
  lang?: 'nb' | 'en';
}

const { lang = 'nb' } = Astro.props;

const t =
  lang === 'nb'
    ? {
        kicker: 'Kontaktskjema',
        navn: 'navn',
        valgfri: '(valgfri)',
        navnEks: 'Kari Nordmann',
        epost: 'e-post',
        epostEks: 'kari@nordmann.no',
        melding: 'melding',
        meldingEks: 'Hei Stian, vi ser etter …',
        send: 'Send melding',
        alternativ: 'Foretrekker du innboksen?',
        gaarRettFram: 'går rett fram.',
      }
    : {
        kicker: 'Contact form',
        navn: 'name',
        valgfri: '(optional)',
        navnEks: 'Jane Doe',
        epost: 'email',
        epostEks: 'jane@doe.com',
        melding: 'message',
        meldingEks: 'Hi Stian, we are looking for …',
        send: 'Send message',
        alternativ: 'Prefer your inbox?',
        gaarRettFram: 'goes straight through.',
      };
---

<form class="skjema" data-kontakt novalidate>
  <p class="skjema-kicker">{t.kicker}</p>

  <div class="felt">
    <label for="kontakt-navn">{t.navn} <span class="valgfri">{t.valgfri}</span></label>
    <input
      id="kontakt-navn"
      name="navn"
      type="text"
      maxlength="100"
      autocomplete="name"
      placeholder={t.navnEks}
    />
  </div>

  <div class="felt">
    <label for="kontakt-epost">{t.epost}</label>
    <input
      id="kontakt-epost"
      name="epost"
      type="email"
      maxlength="254"
      autocomplete="email"
      required
      aria-describedby="feil-epost"
      placeholder={t.epostEks}
    />
    <p class="feilmelding" id="feil-epost" hidden></p>
  </div>

  <div class="felt">
    <label for="kontakt-melding">{t.melding}</label>
    <textarea
      id="kontakt-melding"
      name="melding"
      rows="5"
      maxlength="5000"
      required
      aria-describedby="feil-melding"
      placeholder={t.meldingEks}></textarea>
    <p class="feilmelding" id="feil-melding" hidden></p>
  </div>

  <div class="hp" aria-hidden="true">
    <label for="kontakt-hjemmeside">hjemmeside</label>
    <input
      id="kontakt-hjemmeside"
      name="hjemmeside"
      type="text"
      tabindex="-1"
      autocomplete="off"
    />
  </div>

  <button type="submit" class="send knapp">{t.send}</button>

  <p class="status" data-status aria-live="polite"></p>

  <p class="alternativ">
    {t.alternativ}
    <a href={`mailto:${profil.kontakt.epost}`}>{profil.kontakt.epost}</a>
    {t.gaarRettFram}
  </p>
</form>

<style>
  .skjema {
    background: var(--flate);
    border: 1px solid var(--linje);
    border-radius: var(--radius-md);
    box-shadow: var(--kort-skygge);
    padding: var(--s-4) var(--s-4) var(--s-5);
    max-width: 480px;
  }

  .skjema-kicker {
    font-family: var(--font-hd);
    font-weight: 600;
    text-transform: uppercase;
    font-size: 12.5px;
    letter-spacing: 0.1em;
    color: var(--salvie);
    margin: 0 0 var(--s-3);
  }

  .felt {
    margin-bottom: var(--s-3);
  }

  label {
    display: block;
    font-family: var(--font-hd);
    font-size: 15px;
    color: var(--dempet);
    margin-bottom: var(--s-1);
  }

  .valgfri {
    color: var(--dempet);
  }

  input[type='text'],
  input[type='email'],
  textarea {
    width: 100%;
    box-sizing: border-box;
    background: var(--bg);
    border: 1px solid var(--linje);
    border-radius: var(--radius-sm);
    padding: 10px 12px;
    font-family: var(--font-sans);
    font-size: 16px;
    color: var(--tekst);
    resize: vertical;
  }

  input:focus-visible,
  textarea:focus-visible {
    outline: 2px solid var(--salvie);
    outline-offset: 1px;
    border-color: var(--salvie);
  }

  .felt[data-ugyldig] input,
  .felt[data-ugyldig] textarea {
    border-color: var(--feil);
  }

  .felt[data-ugyldig] input:focus-visible,
  .felt[data-ugyldig] textarea:focus-visible {
    outline-color: var(--feil);
  }

  .feilmelding {
    font-size: 15px;
    color: var(--feil);
    margin: var(--s-1) 0 0;
  }

  .hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .send {
    all: unset;
    box-sizing: border-box;
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 700;
    background: var(--salvie);
    color: var(--salvie-kontrast);
    border-radius: 9px;
    padding: 11px 20px;
    min-height: 44px;
    cursor: pointer;
    display: inline-block;
  }

  .send:hover {
    filter: brightness(1.08);
  }

  .send:focus-visible {
    outline: 2px solid var(--tekst);
    outline-offset: 2px;
  }

  .send[disabled] {
    opacity: 0.6;
    cursor: wait;
  }

  .status {
    font-family: var(--font-hd);
    font-size: 15px;
    margin: var(--s-3) 0 0;
    color: var(--tekst);
  }

  .status:empty {
    display: none;
  }

  .alternativ {
    font-size: 15px;
    color: var(--dempet);
    margin: var(--s-3) 0 0;
  }
</style>

<script>
  const skjema = document.querySelector<HTMLFormElement>('[data-kontakt]');

  // JS-meldingene følger sidens språk (html lang settes per side)
  const paaEngelsk = document.documentElement.lang === 'en';
  const M = paaEngelsk
    ? {
        epostMangler: 'The email address is missing.',
        epostUgyldig: 'The email address needs a valid domain, like jane@doe.com.',
        meldingTom: 'The message is empty.',
        sender: 'sending …',
        sendt: 'Message sent. I reply within a day.',
        ikkeKonfigurert:
          'The form is not connected to email delivery yet. Use the address below; it goes straight through.',
        forMange: 'Too many attempts in a short time. Wait a few minutes and try again.',
        noeGaltFeil: 'Something went wrong. Try again, or use the email address below.',
        ikkeKontakt: 'Could not reach the server. Try again, or use the email address below.',
      }
    : {
        epostMangler: 'E-postadressen mangler.',
        epostUgyldig: 'E-postadressen mangler et gyldig domene — f.eks. kari@nordmann.no.',
        meldingTom: 'Meldingen er tom.',
        sender: 'sender …',
        sendt: 'Meldingen er sendt. Jeg svarer innen et døgn.',
        ikkeKonfigurert:
          'Skjemaet er ikke koblet til e-postutsending ennå — bruk adressen under, den går rett fram.',
        forMange: 'For mange forsøk på kort tid. Vent noen minutter og prøv igjen.',
        noeGaltFeil: 'Noe gikk galt. Prøv igjen — eller bruk e-postadressen under.',
        ikkeKontakt: 'Fikk ikke kontakt med serveren. Prøv igjen — eller bruk e-postadressen under.',
      };

  if (skjema) {
    const lastet = Date.now();
    const status = skjema.querySelector<HTMLElement>('[data-status]')!;
    const knapp = skjema.querySelector<HTMLButtonElement>('.send')!;

    const visFeil = (feltId: string, melding: string | null) => {
      const input = document.getElementById(feltId)!;
      const felt = input.closest('.felt') as HTMLElement;
      const boks = document.getElementById(
        feltId.replace('kontakt-', 'feil-')
      ) as HTMLElement;
      if (melding) {
        felt.dataset.ugyldig = 'true';
        boks.hidden = false;
        boks.textContent = `⚠ ${melding}`;
        input.setAttribute('aria-invalid', 'true');
      } else {
        delete felt.dataset.ugyldig;
        boks.hidden = true;
        boks.textContent = '';
        input.removeAttribute('aria-invalid');
      }
    };

    skjema.addEventListener('submit', async (e) => {
      e.preventDefault();

      const navn = (document.getElementById('kontakt-navn') as HTMLInputElement).value;
      const epost = (document.getElementById('kontakt-epost') as HTMLInputElement).value.trim();
      const melding = (document.getElementById('kontakt-melding') as HTMLTextAreaElement).value.trim();
      const hjemmeside = (document.getElementById('kontakt-hjemmeside') as HTMLInputElement).value;

      // Klarspråkvalidering klient-side — serveren validerer uansett på nytt.
      let harFeil = false;
      if (!epost) {
        visFeil('kontakt-epost', M.epostMangler);
        harFeil = true;
      } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(epost)) {
        visFeil('kontakt-epost', M.epostUgyldig);
        harFeil = true;
      } else {
        visFeil('kontakt-epost', null);
      }
      if (!melding) {
        visFeil('kontakt-melding', M.meldingTom);
        harFeil = true;
      } else {
        visFeil('kontakt-melding', null);
      }
      if (harFeil) {
        status.textContent = '';
        (skjema.querySelector('[aria-invalid]') as HTMLElement | null)?.focus();
        return;
      }

      knapp.disabled = true;
      status.textContent = M.sender;

      try {
        const res = await fetch('/api/kontakt', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ navn, epost, melding, hjemmeside, ts: lastet }),
        });
        const data = await res.json().catch(() => ({}));

        if (res.ok && data.ok) {
          skjema.querySelectorAll('.felt, .send, .skjema-kicker').forEach((el) => {
            (el as HTMLElement).hidden = true;
          });
          status.textContent = M.sendt;
        } else if (data.grunn === 'ikke-konfigurert') {
          status.textContent = M.ikkeKonfigurert;
          knapp.disabled = false;
        } else if (res.status === 429) {
          status.textContent = M.forMange;
          knapp.disabled = false;
        } else if (data.feil) {
          if (data.feil.epost) visFeil('kontakt-epost', data.feil.epost);
          if (data.feil.melding) visFeil('kontakt-melding', data.feil.melding);
          status.textContent = '';
          knapp.disabled = false;
        } else {
          status.textContent = M.noeGaltFeil;
          knapp.disabled = false;
        }
      } catch {
        status.textContent = M.ikkeKontakt;
        knapp.disabled = false;
      }
    });
  }
</script>
