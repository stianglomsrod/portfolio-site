---
/* Navnetrekket «stiglo» — eneste sted Anybody finnes. Kinetisk per
   bokstav (300 ms): bokstaven under pekeren vides ut alene og får en
   tilfeldig farge som aldri er lik naboenes forrige/nåværende.
   På berøringsskjerm: dra fingeren bortover navnet («strumming») for
   samme effekt — en drag er ikke et tapp, så lenka navigerer fortsatt.
   En ankomstbølge (én gang per merke per sidelast, av ved reduced
   motion) viser at navnet lever. Tastaturfokus på lenka gir hele ordet
   den faste paletten. Boksen har fast bredde målt for utvidet tilstand,
   så navnet aldri dytter på naboelementene. */

interface Props {
  storrelse?: number;
  ariaLabel?: string;
  href?: string;
}

const {
  storrelse = 17,
  ariaLabel = 'Stian Glomsrød, til forsiden',
  href = '/',
} = Astro.props;

/* «sti» er fet (800), «glo» er lettere (400) — men begge i Anybody, så begge
   har bredde-aksen og vokser likt på hover. */
const bokstaver = [
  { c: 's', w: 100, vekt: 800, farge: '#8fc9a8' },
  { c: 't', w: 104, vekt: 800, farge: '#c9b08a' },
  { c: 'i', w: 98, vekt: 800, farge: '#8ab8c9' },
  { c: 'g', w: 104, vekt: 400, farge: '#c98a8f' },
  { c: 'l', w: 100, vekt: 400, farge: '#a5c98a' },
  { c: 'o', w: 104, vekt: 400, farge: '#8fc9a8' },
];
---

<a
  class="merke"
  href={href}
  aria-label={ariaLabel}
  style={`font-size: ${storrelse}px`}
>
  {bokstaver.map((b) => (
    <span class="bokstav" data-merke-bokstav style={`--w: ${b.w}; --vekt: ${b.vekt}; --hovc: ${b.farge}`}>{b.c}</span>
  ))}
</a>

<style>
  .merke {
    font-family: var(--font-navnetrekk);
    color: var(--tekst);
    text-decoration: none;
    text-transform: lowercase;
    display: inline-flex;
    align-items: baseline;
    width: 4.6em;
    flex-shrink: 0;
    padding: var(--s-2) 0;
    /* Vertikal sveip scroller som normalt; horisontal drag over merket
       er strumming (håndteres i scriptet). Selection/callout skrus av så
       Android ikke kaprer gesten til tekstmarkering eller lenke-meny. */
    touch-action: pan-y;
    -webkit-tap-highlight-color: transparent;
    user-select: none;
    -webkit-user-select: none;
    -webkit-touch-callout: none;
  }

  /* Driver akslene direkte (mer pålitelig enn font-stretch %): «sti» er
     vekt 800, «glo» vekt 400, alle utvider bredden fra --w til 145 på hover. */
  .bokstav {
    display: inline-block;
    font-variation-settings: 'wght' var(--vekt), 'wdth' var(--w);
    transition:
      font-variation-settings var(--dur-kinetikk) var(--ease),
      color var(--dur-kinetikk) var(--ease);
  }

  .bokstav:hover,
  .bokstav.tent {
    font-variation-settings: 'wght' var(--vekt), 'wdth' 145;
  }

  .merke:focus-visible .bokstav {
    font-variation-settings: 'wght' var(--vekt), 'wdth' 145;
    color: var(--hovc);
  }

  @media (prefers-reduced-motion: reduce) {
    .bokstav {
      transition: none;
    }
  }
</style>

<script>
  // Helt tilfeldig fargetone per bokstav (hele fargehjulet), med
  // nabo-regel som vinkelavstand: aldri nærmere enn 45° fra naboenes
  // forrige/nåværende tone eller bokstavens egen forrige. Lysstyrken
  // låses per tema så kontrasten mot bakgrunnen holder. Samme kinetikk
  // driver hover (mus), strumming (finger) og ankomstbølgen.
  const MIN_AVSTAND = 45;

  const hueAvstand = (a: number, b: number) => {
    const d = Math.abs(a - b) % 360;
    return Math.min(d, 360 - d);
  };

  const lystTema = () => {
    const satt = document.documentElement.dataset.theme;
    if (satt === 'light') return true;
    if (satt === 'dark') return false;
    return window.matchMedia('(prefers-color-scheme: light)').matches;
  };

  const tenn = (bokstav: HTMLElement) => {
    const unngaa = [
      bokstav.dataset.hue,
      (bokstav.previousElementSibling as HTMLElement | null)?.dataset.hue,
      (bokstav.nextElementSibling as HTMLElement | null)?.dataset.hue,
    ]
      .map(Number)
      .filter(Number.isFinite);

    let hue = Math.floor(Math.random() * 360);
    for (let i = 0; i < 40 && unngaa.some((u) => hueAvstand(hue, u) < MIN_AVSTAND); i++) {
      hue = Math.floor(Math.random() * 360);
    }

    bokstav.dataset.hue = String(hue);
    bokstav.style.color = `oklch(${lystTema() ? '46%' : '74%'} 0.15 ${hue})`;
    bokstav.classList.add('tent');
  };

  const slukk = (bokstav: HTMLElement) => {
    bokstav.style.color = '';
    bokstav.classList.remove('tent');
  };

  document.querySelectorAll<HTMLElement>('[data-merke-bokstav]').forEach((bokstav) => {
    bokstav.addEventListener('mouseenter', () => tenn(bokstav));
    bokstav.addEventListener('mouseleave', () => slukk(bokstav));
  });

  // Strumming: dra fingeren bortover navnet — bokstaven under fingeren
  // tennes, forrige slukkes. Rå touch-events, ikke pointer-events:
  // Chrome på Android kan sluke pointermove-strømmen på lenker (gest-
  // arbitrering mot scroll/selection/long-press) selv med pan-y. Første
  // bevegelse avgjør: mer vertikal → scrollen får gesten; mer horisontal
  // → preventDefault og strumming. En drag er ikke et tapp, så det
  // påfølgende klikket svelges og lenka navigerer bare ved tapp.
  document.querySelectorAll<HTMLElement>('.merke').forEach((merke) => {
    let aktiv: HTMLElement | null = null;
    let startX = 0;
    let startY = 0;
    let strummer = false;
    let dratt = false;

    merke.addEventListener(
      'touchstart',
      (e) => {
        const t = e.touches[0];
        startX = t.clientX;
        startY = t.clientY;
        strummer = false;
        dratt = false;
      },
      { passive: true }
    );

    merke.addEventListener(
      'touchmove',
      (e) => {
        const t = e.touches[0];
        if (!strummer) {
          const dx = Math.abs(t.clientX - startX);
          const dy = Math.abs(t.clientY - startY);
          if (dx < 6 && dy < 6) return; // uavklart ennå
          if (dx <= dy) return; // vertikal intensjon → scroll
          strummer = true;
          dratt = true;
        }
        e.preventDefault(); // gesten er vår: ingen scroll/selection/long-press
        const under = document
          .elementFromPoint(t.clientX, t.clientY)
          ?.closest?.('[data-merke-bokstav]') as HTMLElement | null;
        if (under !== aktiv) {
          if (aktiv) slukk(aktiv);
          aktiv = under && merke.contains(under) ? under : null;
          if (aktiv) tenn(aktiv);
        }
      },
      { passive: false }
    );

    const slutt = () => {
      if (aktiv) {
        slukk(aktiv);
        aktiv = null;
      }
      strummer = false;
    };
    merke.addEventListener('touchend', slutt, { passive: true });
    merke.addEventListener('touchcancel', slutt, { passive: true });

    merke.addEventListener('click', (e) => {
      if (dratt) {
        e.preventDefault();
        dratt = false;
      }
    });

    merke.addEventListener('contextmenu', (e) => {
      if (strummer) e.preventDefault();
    });
  });

  // Ankomstbølge: én gang per merke per sidelast, når merket er godt
  // synlig — viser at navnet lever (og at det tåler å bli tatt på).
  // Ren dekorasjon, så reduced motion skrur den helt av.
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const boelge = (merke: HTMLElement) => {
      const bokstaver = merke.querySelectorAll<HTMLElement>('[data-merke-bokstav]');
      bokstaver.forEach((b, i) => {
        setTimeout(() => {
          tenn(b);
          setTimeout(() => slukk(b), 380);
        }, 350 + i * 75);
      });
    };

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            boelge(e.target as HTMLElement);
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.6 }
    );

    document.querySelectorAll<HTMLElement>('.merke').forEach((m) => io.observe(m));
  }
</script>
