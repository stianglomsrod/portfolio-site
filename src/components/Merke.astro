---
/* Navnetrekket «stian.» — eneste sted Anybody finnes. Kinetisk per
   bokstav (300 ms): bokstaven under pekeren vides ut alene og får en
   tilfeldig farge som aldri er lik naboenes forrige/nåværende.
   Tastaturfokus på lenka gir hele ordet den faste paletten. Boksen har
   fast bredde målt for utvidet tilstand, så navnet aldri dytter på
   naboelementene. */

interface Props {
  storrelse?: number;
}

const { storrelse = 17 } = Astro.props;

const bokstaver = [
  { c: 's', w: 100, farge: '#8fc9a8' },
  { c: 't', w: 104, farge: '#c9b08a' },
  { c: 'i', w: 98, farge: '#8ab8c9' },
  { c: 'a', w: 106, farge: '#c98a8f' },
  { c: 'n', w: 100, farge: '#a5c98a' },
];
---

<a
  class="merke"
  href="/"
  aria-label="stian glomsrød — til forsiden"
  style={`font-size: ${storrelse}px`}
>
  {bokstaver.map((b) => (
    <span class="bokstav" data-merke-bokstav style={`--w: ${b.w}; --hovc: ${b.farge}`}>{b.c}</span>
  ))}<span class="punktum" data-farge="#8fc9a8">.</span>
</a>

<style>
  .merke {
    font-family: var(--font-navnetrekk);
    font-weight: 800;
    color: var(--tekst);
    text-decoration: none;
    text-transform: lowercase;
    display: inline-flex;
    align-items: baseline;
    width: 4.1em;
    flex-shrink: 0;
    padding: var(--s-2) 0;
  }

  .bokstav {
    display: inline-block;
    font-stretch: calc(var(--w) * 1%);
    transition:
      font-stretch var(--dur-kinetikk) var(--ease),
      color var(--dur-kinetikk) var(--ease);
  }

  .bokstav:hover {
    font-stretch: 135%;
  }

  .merke:focus-visible .bokstav {
    font-stretch: 135%;
    color: var(--hovc);
  }

  .punktum {
    color: var(--salvie);
  }

  @media (prefers-reduced-motion: reduce) {
    .bokstav {
      transition: none;
    }
  }
</style>

<script>
  // Tilfeldig farge per bokstav ved hover — aldri lik naboenes forrige/
  // nåværende farge (punktumet teller som salvie-nabo for n-en).
  const PALETT = [
    '#8fc9a8',
    '#c9b08a',
    '#8ab8c9',
    '#c98a8f',
    '#a5c98a',
    '#c9a8c2',
    '#9ac9c2',
    '#d9c08a',
  ];

  document.querySelectorAll<HTMLElement>('[data-merke-bokstav]').forEach((bokstav) => {
    bokstav.addEventListener('mouseenter', () => {
      const opptatt = [
        bokstav.dataset.farge,
        (bokstav.previousElementSibling as HTMLElement | null)?.dataset.farge,
        (bokstav.nextElementSibling as HTMLElement | null)?.dataset.farge,
      ];
      const kandidater = PALETT.filter((f) => !opptatt.includes(f));
      const farge = kandidater[Math.floor(Math.random() * kandidater.length)];
      bokstav.dataset.farge = farge;
      bokstav.style.color = farge;
    });

    bokstav.addEventListener('mouseleave', () => {
      bokstav.style.color = '';
    });
  });
</script>
