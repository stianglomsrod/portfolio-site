---
/* Navnetrekket «stian.» — eneste sted Anybody finnes. Kinetisk per
   bokstav (300 ms): bokstaven under pekeren vides ut alene og får en
   tilfeldig farge som aldri er lik naboenes forrige/nåværende.
   Tastaturfokus på lenka gir hele ordet den faste paletten. Boksen har
   fast bredde målt for utvidet tilstand, så navnet aldri dytter på
   naboelementene. */

interface Props {
  storrelse?: number;
}

const { storrelse = 17 } = Astro.props;

const bokstaver = [
  { c: 's', w: 100, farge: '#8fc9a8' },
  { c: 't', w: 104, farge: '#c9b08a' },
  { c: 'i', w: 98, farge: '#8ab8c9' },
  { c: 'a', w: 106, farge: '#c98a8f' },
  { c: 'n', w: 100, farge: '#a5c98a' },
];
---

<a
  class="merke"
  href="/"
  aria-label="stian glomsrød — til forsiden"
  style={`font-size: ${storrelse}px`}
>
  {bokstaver.map((b) => (
    <span class="bokstav" data-merke-bokstav style={`--w: ${b.w}; --hovc: ${b.farge}`}>{b.c}</span>
  ))}<span class="punktum" data-hue="155">.</span>
</a>

<style>
  .merke {
    font-family: var(--font-navnetrekk);
    font-weight: 800;
    color: var(--tekst);
    text-decoration: none;
    text-transform: lowercase;
    display: inline-flex;
    align-items: baseline;
    width: 4.1em;
    flex-shrink: 0;
    padding: var(--s-2) 0;
  }

  .bokstav {
    display: inline-block;
    font-stretch: calc(var(--w) * 1%);
    transition:
      font-stretch var(--dur-kinetikk) var(--ease),
      color var(--dur-kinetikk) var(--ease);
  }

  .bokstav:hover {
    font-stretch: 135%;
  }

  .merke:focus-visible .bokstav {
    font-stretch: 135%;
    color: var(--hovc);
  }

  .punktum {
    color: var(--salvie);
  }

  @media (prefers-reduced-motion: reduce) {
    .bokstav {
      transition: none;
    }
  }
</style>

<script>
  // Helt tilfeldig fargetone per bokstav ved hover (hele fargehjulet),
  // med nabo-regel som vinkelavstand: aldri nærmere enn 45° fra naboenes
  // forrige/nåværende tone eller bokstavens egen forrige. Lysstyrken
  // låses per tema så kontrasten mot bakgrunnen holder.
  const MIN_AVSTAND = 45;

  const hueAvstand = (a: number, b: number) => {
    const d = Math.abs(a - b) % 360;
    return Math.min(d, 360 - d);
  };

  const lystTema = () => {
    const satt = document.documentElement.dataset.theme;
    if (satt === 'light') return true;
    if (satt === 'dark') return false;
    return window.matchMedia('(prefers-color-scheme: light)').matches;
  };

  document.querySelectorAll<HTMLElement>('[data-merke-bokstav]').forEach((bokstav) => {
    bokstav.addEventListener('mouseenter', () => {
      const unngaa = [
        bokstav.dataset.hue,
        (bokstav.previousElementSibling as HTMLElement | null)?.dataset.hue,
        (bokstav.nextElementSibling as HTMLElement | null)?.dataset.hue,
      ]
        .map(Number)
        .filter(Number.isFinite);

      let hue = Math.floor(Math.random() * 360);
      for (let i = 0; i < 40 && unngaa.some((u) => hueAvstand(hue, u) < MIN_AVSTAND); i++) {
        hue = Math.floor(Math.random() * 360);
      }

      bokstav.dataset.hue = String(hue);
      bokstav.style.color = `oklch(${lystTema() ? '46%' : '74%'} 0.15 ${hue})`;
    });

    bokstav.addEventListener('mouseleave', () => {
      bokstav.style.color = '';
    });
  });
</script>
