---
/* Nav v3: synlig rad på alle flater, ingen hamburger. Aktiv side = salvie-dot.
   «/sandbox» beholder skråstreken — lekeplassens eneste tekniske blunk.
   Tema er en ekte switch (role="switch"), språkvelgeren er en lenke til
   tvillingsiden på det andre språket (URL-en er språkvalget). */

import Merke from './Merke.astro';
import { UI, type Spraak } from '../lib/i18n';

interface Props {
  lang?: Spraak;
  /** Sti til samme side på det andre språket */
  alternativ?: string;
}

const { lang = 'nb', alternativ = '/en/' } = Astro.props;
const t = UI[lang];

const sti = Astro.url.pathname.replace(/\/$/, '') || '/';
const erAktiv = (href: string) => {
  const mal = href.replace(/\/$/, '') || '/';
  return sti === mal;
};
---

<header class="topp" id="side-topp">
  <div class="topp-indre">
    <Merke storrelse={17} ariaLabel={t.merkeAria} href={lang === 'nb' ? '/' : '/en/'} />
    <nav aria-label={t.hovedmeny}>
      <ul class="meny">
        {t.meny.map((p) => (
          <li>
            <a
              href={p.href}
              class:list={['punkt', { aktiv: erAktiv(p.href) }]}
              aria-current={erAktiv(p.href) ? 'page' : undefined}
            >
              {erAktiv(p.href) && <span class="dot" aria-hidden="true"></span>}
              {p.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <div class="brytere">
      <a
        class="spraak"
        href={alternativ}
        hreflang={lang === 'nb' ? 'en' : 'nb'}
        aria-label={t.spraakAria}
        >{t.spraakLabel}</a
      >
      <button
        type="button"
        id="tema-toggle"
        class="tema"
        role="switch"
        aria-checked="true"
        aria-label={t.temaAria}
      >
        <span class="tema-spor" aria-hidden="true">
          <span class="tema-ikon sol">☀</span>
          <span class="tema-ikon maane">☾</span>
          <span class="tema-kule"></span>
        </span>
      </button>
    </div>
  </div>
</header>

<style>
  /* Auto-hide: sticky rad som glir vekk ved scroll ned og tilbake ved
     scroll opp. Skjules aldri mens noe i den har fokus (tastatur). */
  .topp {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-4);
    padding: var(--s-3) var(--s-6);
    background: var(--nav-bg);
    border-bottom: 1px solid var(--linje);
    transition: transform var(--dur-panel) var(--ease);
    /* Eget compositor-lag: uten dette kunne skjul/vis-transformen gi
       blanke felt og klippet innhold under scroll (Chromium) */
    will-change: transform;
  }

  .topp[data-skjult] {
    transform: translateY(-100%);
  }

  .topp:focus-within {
    transform: none;
  }

  .topp-indre {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-4);
    max-width: 1060px;
    margin: 0 auto;
    width: 100%;
  }

  /* Flex-elementet må få lov til å krympe, ellers presser menyen raden
     utover skjermen på mobil i stedet for å brekke */
  .topp-indre nav {
    min-width: 0;
    flex: 1;
  }

  .meny {
    display: flex;
    gap: var(--s-1);
    list-style: none;
    margin: 0;
    padding: 0;
    overflow-x: auto;
  }

  .punkt {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: 14px;
    color: var(--dempet);
    text-decoration: none;
    padding: 12px 10px;
    min-height: 44px; /* WCAG-målstørrelse på berøringsskjerm */
    box-sizing: border-box;
    border-radius: var(--radius-sm);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
    transition: color var(--dur-mikro), background var(--dur-mikro);
  }

  .punkt:hover {
    color: var(--tekst);
    background: var(--flate);
  }

  .punkt.aktiv {
    color: var(--tekst);
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--salvie);
    flex-shrink: 0;
  }

  .brytere {
    display: flex;
    align-items: center;
    gap: var(--s-2);
    flex-shrink: 0;
  }

  .spraak {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: 12.5px;
    letter-spacing: 0.06em;
    color: var(--dempet);
    text-decoration: none;
    border: 1px solid var(--linje);
    border-radius: var(--radius-sm);
    min-width: 44px;
    min-height: 44px;
    box-sizing: border-box;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color var(--dur-mikro), border-color var(--dur-mikro);
  }

  .spraak:hover {
    color: var(--tekst);
    border-color: var(--dempet);
  }

  .spraak:focus-visible {
    outline: 2px solid var(--salvie);
    outline-offset: 2px;
  }

  /* Tema-switch: spor med sol/måne og en kule som glir. aria-checked
     styrer posisjonen (true = mørkt). */
  .tema {
    all: unset;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    cursor: pointer;
    padding: 4px;
    box-sizing: border-box;
  }

  .tema-spor {
    position: relative;
    width: 56px;
    height: 28px;
    border: 1px solid var(--linje);
    border-radius: 999px;
    background: var(--flate);
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 7px;
    box-sizing: border-box;
    transition: border-color var(--dur-mikro);
  }

  .tema:hover .tema-spor {
    border-color: var(--dempet);
  }

  .tema:focus-visible .tema-spor {
    outline: 2px solid var(--salvie);
    outline-offset: 2px;
  }

  .tema-ikon {
    font-size: 12px;
    line-height: 1;
    color: var(--dempet);
  }

  .tema-kule {
    position: absolute;
    top: 3px;
    left: 3px;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--salvie);
    transition: transform var(--dur-panel) var(--ease);
  }

  .tema[aria-checked='true'] .tema-kule {
    transform: translateX(28px);
  }

  /* Mobil: menyen brekker til egen rad så alle seks punktene er synlige.
     Synlig navigasjon slår både hamburger (skjuler alt) og horisontal
     scroll (viser 1–2 punkter av gangen). */
  @media (max-width: 680px) {
    .topp {
      padding: var(--s-1) var(--s-4);
    }

    .topp-indre {
      flex-wrap: wrap;
    }

    .topp-indre nav {
      order: 3;
      flex-basis: 100%;
    }

    .meny {
      flex-wrap: wrap;
      overflow-x: visible;
      justify-content: flex-start;
    }
  }
</style>

<script>
  // Tema-switch: manuelt valg persisteres i localStorage 'data-theme'
  // (cookiefritt). Uten valg følges prefers-color-scheme via CSS.
  // aria-checked = «mørkt tema på».
  const knapp = document.getElementById('tema-toggle');

  const effektivt = (): 'dark' | 'light' => {
    const satt = document.documentElement.dataset.theme;
    if (satt === 'dark' || satt === 'light') return satt;
    return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
  };

  const oppdater = () => {
    knapp?.setAttribute('aria-checked', effektivt() === 'dark' ? 'true' : 'false');
  };

  knapp?.addEventListener('click', () => {
    const ny = effektivt() === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = ny;
    try {
      localStorage.setItem('data-theme', ny);
    } catch {}
    oppdater();
  });

  oppdater();

  // Auto-hide: skjul ved scroll ned, vis ved scroll opp. Slår først inn
  // godt under heltene på toppen (y > 160), og hysteresen på 16px hindrer
  // flimring ved småbevegelser.
  const topp = document.getElementById('side-topp');
  let forrigeY = window.scrollY;
  let ventet = false;

  window.addEventListener(
    'scroll',
    () => {
      if (ventet) return;
      ventet = true;
      requestAnimationFrame(() => {
        const y = window.scrollY;
        const delta = y - forrigeY;
        if (y < 160) {
          topp?.removeAttribute('data-skjult');
          forrigeY = y;
        } else if (delta > 16) {
          topp?.setAttribute('data-skjult', '');
          forrigeY = y;
        } else if (delta < -16) {
          topp?.removeAttribute('data-skjult');
          forrigeY = y;
        }
        ventet = false;
      });
    },
    { passive: true }
  );
</script>
