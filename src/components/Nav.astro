---
/* Nav v3: synlig rad på alle flater, ingen hamburger. Aktiv side = salvie-dot.
   «/sandbox» beholder skråstreken — lekeplassens eneste tekniske blunk.
   Navnetrekket «stian.» i Anybody er kinetisk ved hover/fokus (300 ms) —
   eneste sted den fonten finnes, sammen med footeren. */

import Merke from './Merke.astro';

const punkter = [
  { href: '/', label: 'hjem' },
  { href: '/prosjekter', label: 'prosjekter' },
  { href: '/reisen', label: 'reisen' },
  { href: '/sandbox', label: '/sandbox' },
  { href: '/slik-jobber-jeg', label: 'slik jobber jeg' },
  { href: '/om', label: 'om meg' },
];

const sti = Astro.url.pathname.replace(/\/$/, '') || '/';
const erAktiv = (href: string) => sti === (href === '/' ? '/' : href);
---

<header class="topp" id="side-topp">
  <div class="topp-indre">
    <Merke storrelse={17} />
    <nav aria-label="Hovedmeny">
      <ul class="meny">
        {punkter.map((p) => (
          <li>
            <a
              href={p.href}
              class:list={['punkt', { aktiv: erAktiv(p.href) }]}
              aria-current={erAktiv(p.href) ? 'page' : undefined}
            >
              {erAktiv(p.href) && <span class="dot" aria-hidden="true"></span>}
              {p.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <button type="button" id="tema-toggle" class="tema">
      <span id="tema-tekst">tema</span>
    </button>
  </div>
</header>

<style>
  /* Auto-hide: sticky rad som glir vekk ved scroll ned og tilbake ved
     scroll opp. Skjules aldri mens noe i den har fokus (tastatur). */
  .topp {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-4);
    padding: var(--s-3) var(--s-6);
    background: var(--nav-bg);
    border-bottom: 1px solid var(--linje);
    transition: transform var(--dur-panel) var(--ease);
  }

  .topp[data-skjult] {
    transform: translateY(-100%);
  }

  .topp:focus-within {
    transform: none;
  }

  .topp-indre {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-4);
    max-width: 1060px;
    margin: 0 auto;
    width: 100%;
  }

  .meny {
    display: flex;
    gap: var(--s-1);
    list-style: none;
    margin: 0;
    padding: 0;
    overflow-x: auto;
  }

  .punkt {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: 14px;
    color: var(--dempet);
    text-decoration: none;
    padding: 10px;
    border-radius: var(--radius-sm);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
    transition: color var(--dur-mikro), background var(--dur-mikro);
  }

  .punkt:hover {
    color: var(--tekst);
    background: var(--flate);
  }

  .punkt.aktiv {
    color: var(--tekst);
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--salvie);
    flex-shrink: 0;
  }

  .tema {
    all: unset;
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: 12.5px;
    color: var(--dempet);
    border: 1px solid var(--linje);
    border-radius: var(--radius-sm);
    padding: 12px;
    min-width: 44px;
    box-sizing: border-box;
    text-align: center;
    cursor: pointer;
    flex-shrink: 0;
    transition: color var(--dur-mikro), border-color var(--dur-mikro);
  }

  .tema:hover {
    color: var(--tekst);
    border-color: var(--dempet);
  }

  .tema:focus-visible {
    outline: 2px solid var(--salvie);
    outline-offset: 2px;
  }

  @media (max-width: 680px) {
    .topp {
      padding: var(--s-2) var(--s-4);
    }

    .meny {
      mask-image: linear-gradient(
        90deg,
        transparent 0,
        #000 12px,
        #000 calc(100% - 12px),
        transparent
      );
      padding-inline: 12px;
    }
  }
</style>

<script>
  // Tema-toggle: manuelt valg persisteres i localStorage 'data-theme'
  // (cookiefritt). Uten valg følges prefers-color-scheme via CSS.
  const knapp = document.getElementById('tema-toggle');
  const tekst = document.getElementById('tema-tekst');

  const effektivt = (): 'dark' | 'light' => {
    const satt = document.documentElement.dataset.theme;
    if (satt === 'dark' || satt === 'light') return satt;
    return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
  };

  const oppdater = () => {
    if (!knapp || !tekst) return;
    const neste = effektivt() === 'dark' ? 'lyst' : 'mørkt';
    tekst.textContent = neste === 'lyst' ? '☀ lys' : '☾ mørk';
    knapp.setAttribute('aria-label', `Bytt til ${neste} tema`);
  };

  knapp?.addEventListener('click', () => {
    const ny = effektivt() === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = ny;
    try {
      localStorage.setItem('data-theme', ny);
    } catch {}
    oppdater();
  });

  oppdater();

  // Auto-hide: skjul ved scroll ned, vis ved scroll opp. Terskel på 10px
  // ignorerer småbevegelser; nær toppen er raden alltid synlig.
  const topp = document.getElementById('side-topp');
  let forrigeY = window.scrollY;
  let ventet = false;

  window.addEventListener(
    'scroll',
    () => {
      if (ventet) return;
      ventet = true;
      requestAnimationFrame(() => {
        const y = window.scrollY;
        const delta = y - forrigeY;
        if (y < 80) {
          topp?.removeAttribute('data-skjult');
        } else if (delta > 10) {
          topp?.setAttribute('data-skjult', '');
          forrigeY = y;
        } else if (delta < -10) {
          topp?.removeAttribute('data-skjult');
          forrigeY = y;
        }
        if (Math.abs(delta) > 10) forrigeY = y;
        ventet = false;
      });
    },
    { passive: true }
  );
</script>
