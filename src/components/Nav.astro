---
/* Nav v3: synlig rad på desktop (NN/g: aldri hamburger der). På mobil
   kostet den synlige menyen 20 % av førstevisningen, så der er den en
   hamburger MED tekstetikett («Meny» — ikon+tekst slår ikon alene) som
   åpner en nedtrekksliste. Uten JS vises full meny også på mobil.
   Aktiv side = salvie-dot. «/sandbox» beholder skråstreken. Tema er en
   ekte switch (role="switch"), språkvelgeren er en lenke til
   tvillingsiden på det andre språket (URL-en er språkvalget). */

import Merke from './Merke.astro';
import { UI, type Spraak } from '../lib/i18n';

interface Props {
  lang?: Spraak;
  /** Sti til samme side på det andre språket */
  alternativ?: string;
}

const { lang = 'nb', alternativ = '/en/' } = Astro.props;
const t = UI[lang];

const sti = Astro.url.pathname.replace(/\/$/, '') || '/';
const erAktiv = (href: string) => {
  const mal = href.replace(/\/$/, '') || '/';
  return sti === mal;
};
---

<header class="topp" id="side-topp">
  <div class="topp-indre">
    <Merke storrelse={17} ariaLabel={t.merkeAria} href={lang === 'nb' ? '/' : '/en/'} />
    <nav aria-label={t.hovedmeny} id="hovedmeny">
      <ul class="meny">
        {t.meny.map((p) => (
          <li>
            <a
              href={p.href}
              class:list={['punkt', { aktiv: erAktiv(p.href) }]}
              aria-current={erAktiv(p.href) ? 'page' : undefined}
            >
              {erAktiv(p.href) && <span class="dot" aria-hidden="true"></span>}
              {p.label}
            </a>
          </li>
        ))}
      </ul>
      <!-- Mobil: språk og tema bor i menyen som to selvstendige rader —
           språket som lenke med pil (navigasjon, endonym per W3C-praksis),
           temaet som switch med synlig etikett så det aldri leses som om
           switchen hører til språket -->
      <div class="meny-verktoy">
        <a
          class="meny-spraak"
          href={alternativ}
          hreflang={lang === 'nb' ? 'en' : 'nb'}
          aria-label={t.spraakAria}
          >{lang === 'nb' ? 'English' : 'Norsk'}
          <span class="meny-pil" aria-hidden="true">→</span></a
        >
        <button
          type="button"
          class="tema meny-tema"
          data-tema-toggle
          role="switch"
          aria-checked="true"
          aria-label={t.temaAria}
        >
          <span class="meny-tema-tekst">{lang === 'nb' ? 'Mørkt tema' : 'Dark theme'}</span>
          <span class="tema-spor" aria-hidden="true">
            <span class="tema-ikon sol">☀</span>
            <span class="tema-ikon maane">☾</span>
            <span class="tema-kule"></span>
          </span>
        </button>
      </div>
    </nav>
    <div class="brytere">
      <a
        class="spraak"
        href={alternativ}
        hreflang={lang === 'nb' ? 'en' : 'nb'}
        aria-label={t.spraakAria}
        >{t.spraakLabel}</a
      >
      <button
        type="button"
        id="tema-toggle"
        class="tema"
        data-tema-toggle
        role="switch"
        aria-checked="true"
        aria-label={t.temaAria}
      >
        <span class="tema-spor" aria-hidden="true">
          <span class="tema-ikon sol">☀</span>
          <span class="tema-ikon maane">☾</span>
          <span class="tema-kule"></span>
        </span>
      </button>
      <button
        type="button"
        id="meny-knapp"
        class="meny-knapp"
        aria-expanded="false"
        aria-controls="hovedmeny"
      >
        <svg class="meny-ikon" viewBox="0 0 16 14" width="16" height="14" aria-hidden="true">
          <path d="M1 1h14M1 7h14M1 13h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
        {lang === 'nb' ? 'Meny' : 'Menu'}
      </button>
    </div>
  </div>
</header>

<style>
  /* Auto-hide: sticky rad som glir med scrollen piksel for piksel (som om
     den lå i dokumentet) og snapper mykt helt inn/ut når scrollen stopper.
     Skjules aldri mens noe i den har fokus (tastatur).

     Flate-språket: øverst på siden er headeren USYNLIG (smelter inn i
     heroen) — ved scroll materialiserer den seg som tintet glass
     (gjennomskinnelig aksent + backdrop-blur) med myk skygge i stedet
     for hard kantlinje. Fallback uten backdrop-filter: opak tint. */
  .topp {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-4);
    padding: var(--s-3) var(--s-6);
    background: var(--nav-bg);
    border-bottom: 1px solid color-mix(in oklab, var(--linje) 65%, transparent);
    box-shadow: var(--nav-skygge);
    transition:
      background-color 280ms var(--ease),
      border-color 280ms var(--ease),
      box-shadow 280ms var(--ease);
    /* Eget compositor-lag: uten dette kunne skjul/vis-transformen gi
       blanke felt og klippet innhold under scroll (Chromium) */
    will-change: transform;
  }

  @supports (backdrop-filter: blur(1px)) {
    .topp {
      background: color-mix(in oklab, var(--nav-bg) 78%, transparent);
      -webkit-backdrop-filter: blur(14px) saturate(1.4);
      backdrop-filter: blur(14px) saturate(1.4);
    }
  }

  /* Øverst på siden: ingen plate — headeren ER siden */
  .topp[data-oppe] {
    background: transparent;
    border-bottom-color: transparent;
    box-shadow: none;
  }

  /* Transition kun når vi snapper (scroll i ro) — under aktiv scroll styrer
     JS transformen direkte, og en transition ville gitt gummistrikk-lag */
  .topp.glir {
    transition: transform 220ms var(--ease);
  }

  .topp:focus-within {
    transform: none !important;
  }

  .topp-indre {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-4);
    max-width: 1060px;
    margin: 0 auto;
    width: 100%;
  }

  /* Flex-elementet må få lov til å krympe, ellers presser menyen raden
     utover skjermen på mobil i stedet for å brekke */
  .topp-indre nav {
    min-width: 0;
    flex: 1;
  }

  .meny {
    display: flex;
    gap: var(--s-1);
    list-style: none;
    margin: 0;
    padding: 0;
    overflow-x: auto;
  }

  .punkt {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: 14px;
    color: var(--dempet);
    text-decoration: none;
    padding: 12px 10px;
    min-height: 44px; /* WCAG-målstørrelse på berøringsskjerm */
    box-sizing: border-box;
    border-radius: var(--radius-sm);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
    transition: color var(--dur-mikro), background var(--dur-mikro);
  }

  .punkt:hover {
    color: var(--tekst);
    background: var(--flate);
  }

  .punkt.aktiv {
    color: var(--tekst);
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--salvie);
    flex-shrink: 0;
  }

  .brytere {
    display: flex;
    align-items: center;
    gap: var(--s-2);
    flex-shrink: 0;
  }

  /* Verktøyraden i menyen finnes bare i mobil-nedtrekkslista */
  .meny-verktoy {
    display: none;
  }

  .meny-spraak {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: 14px;
    color: var(--dempet);
    text-decoration: none;
    padding: 12px 12px;
    min-height: 48px;
    width: 100%;
    box-sizing: border-box;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .meny-spraak:hover {
    color: var(--tekst);
    background: var(--flate);
  }

  .meny-pil {
    color: var(--salvie);
  }

  /* Tema-raden i menyen: synlig etikett + switch på samme rad — hele
     raden er knappen */
  /* .tema.meny-tema slår .tema sin all:unset i kaskaden */
  .tema.meny-tema {
    display: flex;
    width: 100%;
    box-sizing: border-box;
    justify-content: space-between;
    align-items: center;
    padding: 2px 12px;
    min-height: 48px;
    border-radius: var(--radius-sm);
  }

  .tema.meny-tema:hover {
    background: var(--flate);
  }

  .meny-tema-tekst {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: 14px;
    color: var(--dempet);
  }

  .meny-tema:hover .meny-tema-tekst {
    color: var(--tekst);
  }

  /* Hamburgeren finnes bare på mobil MED js — ellers vises full meny */
  .meny-knapp {
    all: unset;
    display: none;
    align-items: center;
    gap: 7px;
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--tekst);
    border: 1px solid var(--linje);
    border-radius: var(--radius-sm);
    padding: 0 12px;
    min-height: 44px;
    box-sizing: border-box;
    cursor: pointer;
  }

  .meny-knapp:focus-visible {
    outline: 2px solid var(--salvie);
    outline-offset: 2px;
  }

  .meny-ikon {
    flex-shrink: 0;
  }

  /* Åpen tilstand: midterste strek tones ut (rolig, ingen kryss-morphing) */
  .meny-knapp[aria-expanded='true'] {
    border-color: var(--salvie);
  }

  .spraak {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: 12.5px;
    letter-spacing: 0.06em;
    color: var(--dempet);
    text-decoration: none;
    border: 1px solid var(--linje);
    border-radius: var(--radius-sm);
    min-width: 44px;
    min-height: 44px;
    box-sizing: border-box;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color var(--dur-mikro), border-color var(--dur-mikro);
  }

  .spraak:hover {
    color: var(--tekst);
    border-color: var(--dempet);
  }

  .spraak:focus-visible {
    outline: 2px solid var(--salvie);
    outline-offset: 2px;
  }

  /* Tema-switch: spor med sol/måne og en kule som glir. aria-checked
     styrer posisjonen (true = mørkt). */
  .tema {
    all: unset;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    cursor: pointer;
    padding: 4px;
    box-sizing: border-box;
  }

  .tema-spor {
    position: relative;
    width: 56px;
    height: 28px;
    border: 1px solid var(--linje);
    border-radius: 999px;
    background: var(--flate);
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 7px;
    box-sizing: border-box;
    transition: border-color var(--dur-mikro);
  }

  .tema:hover .tema-spor {
    border-color: var(--dempet);
  }

  .tema:focus-visible .tema-spor {
    outline: 2px solid var(--salvie);
    outline-offset: 2px;
  }

  .tema-ikon {
    font-size: 12px;
    line-height: 1;
    color: var(--dempet);
  }

  .tema-kule {
    position: absolute;
    top: 3px;
    left: 3px;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--salvie);
    transition: transform var(--dur-panel) var(--ease);
  }

  .tema[aria-checked='true'] .tema-kule {
    transform: translateX(28px);
  }

  /* Mobil UTEN js: menyen brekker til egen rad så alle seks punktene er
     synlige — ingen hamburger å trykke på uten script. */
  @media (max-width: 680px) {
    .topp {
      padding: var(--s-1) var(--s-4);
    }

    .topp-indre {
      flex-wrap: wrap;
    }

    .topp-indre nav {
      order: 3;
      flex-basis: 100%;
    }

    .meny {
      flex-wrap: wrap;
      overflow-x: visible;
      justify-content: flex-start;
    }

    /* Mobil MED js: én rolig topplinje — menyen bor bak «Meny»-knappen
       som en nedtrekksliste under linja. Sparer ~100px av førstevisningen
       (menyradene kostet 20 % av skjermen). */
    :global(html.har-js) .meny-knapp {
      display: inline-flex;
    }

    /* Språk og tema flytter inn i menyen — topplinja er merke + Meny */
    :global(html.har-js) .brytere .spraak,
    :global(html.har-js) .brytere .tema {
      display: none;
    }

    :global(html.har-js) .meny-verktoy {
      display: block;
      margin-top: var(--s-2);
      padding-top: var(--s-1);
      border-top: 1px solid var(--linje);
    }

    :global(html.har-js) .topp-indre nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      order: initial;
      flex-basis: auto;
      background: var(--nav-bg);
      border-bottom: 1px solid color-mix(in oklab, var(--linje) 65%, transparent);
      box-shadow: var(--nav-skygge);
      padding: var(--s-2) var(--s-4) var(--s-3);
      display: none;
    }

    /* Nedtrekkslista er samme glass som headeren, men tettere (tekst
       skal være trygg å lese over hva som helst) */
    @supports (backdrop-filter: blur(1px)) {
      :global(html.har-js) .topp-indre nav {
        background: color-mix(in oklab, var(--nav-bg) 92%, transparent);
        -webkit-backdrop-filter: blur(18px) saturate(1.4);
        backdrop-filter: blur(18px) saturate(1.4);
      }
    }

    :global(html.har-js) .topp-indre nav[data-apen] {
      display: block;
    }

    :global(html.har-js) .meny {
      flex-direction: column;
      gap: 2px;
    }

    :global(html.har-js) .punkt {
      width: 100%;
      min-height: 48px;
      padding: 12px 12px;
    }
  }
</style>

<script>
  // Tema-switch: manuelt valg persisteres i localStorage 'data-theme'
  // (cookiefritt). Uten valg følges prefers-color-scheme via CSS.
  // aria-checked = «mørkt tema på». To switcher (topplinje + mobilmeny)
  // deler tilstand og holdes i synk.
  const temaKnapper = [...document.querySelectorAll<HTMLElement>('[data-tema-toggle]')];

  const effektivt = (): 'dark' | 'light' => {
    const satt = document.documentElement.dataset.theme;
    if (satt === 'dark' || satt === 'light') return satt;
    return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
  };

  const oppdater = () => {
    const verdi = effektivt() === 'dark' ? 'true' : 'false';
    temaKnapper.forEach((k) => k.setAttribute('aria-checked', verdi));
  };

  temaKnapper.forEach((knapp) =>
    knapp.addEventListener('click', () => {
      const ny = effektivt() === 'dark' ? 'light' : 'dark';
      document.documentElement.dataset.theme = ny;
      try {
        localStorage.setItem('data-theme', ny);
      } catch {}
      oppdater();
    })
  );

  oppdater();

  // Hamburgermeny (mobil): disclosure-mønsteret — åpne/lukk med knappen,
  // lukk ved lenkevalg, Escape (fokus tilbake til knappen), tapp utenfor
  // eller scroll. Ikke modal: resten av siden er fortsatt tilgjengelig.
  const menyKnapp = document.getElementById('meny-knapp');
  const hovedmeny = document.getElementById('hovedmeny');

  if (menyKnapp && hovedmeny) {
    const settApen = (apen: boolean) => {
      menyKnapp.setAttribute('aria-expanded', String(apen));
      const topp = document.getElementById('side-topp');
      if (apen) {
        hovedmeny.setAttribute('data-apen', '');
        // Åpen meny trenger flaten sin — også øverst på siden
        topp?.removeAttribute('data-oppe');
      } else {
        hovedmeny.removeAttribute('data-apen');
        if (window.scrollY < 24) topp?.setAttribute('data-oppe', '');
      }
    };

    const erApen = () => menyKnapp.getAttribute('aria-expanded') === 'true';

    menyKnapp.addEventListener('click', () => settApen(!erApen()));

    hovedmeny.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('a')) settApen(false);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && erApen()) {
        settApen(false);
        menyKnapp.focus();
      }
    });

    document.addEventListener('pointerdown', (e) => {
      if (
        erApen() &&
        !hovedmeny.contains(e.target as Node) &&
        !menyKnapp.contains(e.target as Node)
      ) {
        settApen(false);
      }
    });

    window.addEventListener('scroll', () => {
      if (erApen()) settApen(false);
    }, { passive: true });
  }

  // Auto-hide: naven følger scrollen piksel for piksel — glir ut i takt med
  // innholdet ved scroll ned, og tilbake i samme takt ved scroll opp. Når
  // scrollen har stått stille et øyeblikk, snapper den mykt helt inn eller
  // helt ut (aldri halvveis). Ingen terskel-hopp.
  const topp = document.getElementById('side-topp');
  if (topp) {
    // Starttilstand: usynlig plate hvis vi står øverst
    if (window.scrollY < 24) topp.setAttribute('data-oppe', '');

    let forrigeY = window.scrollY;
    let offset = 0; // 0 = helt synlig, navH = helt skjult
    let ventet = false;
    let snappTimer: ReturnType<typeof setTimeout> | undefined;

    const settTransform = () => {
      topp.style.transform = offset === 0 ? '' : `translateY(${-offset}px)`;
    };

    let sisteRetning = 0; // -1 = opp, 1 = ned

    const snapp = () => {
      const navH = topp.offsetHeight;
      if (offset === 0 || offset === navH) return;
      // Fullfør i samme retning som brukeren sist scrollet: opp = vis naven
      offset = sisteRetning < 0 ? 0 : navH;
      topp.classList.add('glir');
      settTransform();
      setTimeout(() => topp.classList.remove('glir'), 260);
    };

    window.addEventListener(
      'scroll',
      () => {
        if (snappTimer) clearTimeout(snappTimer);
        snappTimer = setTimeout(snapp, 140);
        if (ventet) return;
        ventet = true;
        requestAnimationFrame(() => {
          const y = window.scrollY;
          const delta = y - forrigeY;
          forrigeY = y;
          if (delta !== 0) sisteRetning = delta > 0 ? 1 : -1;
          // Materialtilstanden: usynlig øverst, tintet glass ved scroll
          if (y < 24) {
            topp.setAttribute('data-oppe', '');
          } else {
            topp.removeAttribute('data-oppe');
          }
          const navH = topp.offsetHeight;
          // Øverst på siden er naven alltid helt synlig
          const maks = Math.max(0, Math.min(navH, y));
          offset = Math.max(0, Math.min(maks, offset + delta));
          topp.classList.remove('glir');
          settTransform();
          ventet = false;
        });
      },
      { passive: true }
    );
  }
</script>
