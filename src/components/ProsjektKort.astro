---
interface Lenke {
  href: string;
  label: string;
  primaer?: boolean;
}

interface Props {
  tag: string;
  tittel: string;
  tekst: string;
  note?: string;
  lenker?: Lenke[];
  id?: string;
}

const { tag, tittel, tekst, note, lenker = [], id } = Astro.props;
---

<article class="kort" id={id}>
  <p class="tag">{tag}</p>
  <h3 class="tittel">{tittel}</h3>
  <p class="tekst">{tekst}</p>
  {note && <p class="note">{note}</p>}
  {lenker.length > 0 && (
    <p class="lenker">
      {lenker.map((l) => (
        <a href={l.href} class:list={[{ primaer: l.primaer }]} rel={l.href.startsWith('http') ? 'noreferrer noopener' : undefined}>
          {l.label} <span class="pil" aria-hidden="true">→</span>
        </a>
      ))}
    </p>
  )}
</article>

<style>
  .kort {
    background: var(--flate);
    border: 1px solid var(--linje);
    border-radius: var(--radius-md);
    box-shadow: var(--kort-skygge);
    padding: var(--s-4);
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
    height: 100%;
    box-sizing: border-box;
  }

  .tag {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.1em;
    color: var(--dempet);
    margin: 0;
    text-transform: uppercase;
  }

  .tittel {
    font-size: 19px;
    font-weight: 700;
    color: var(--tekst);
    margin: 0;
  }

  .tekst {
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--dempet);
    margin: 0;
  }

  .note {
    font-size: 14.5px;
    color: var(--tekst);
    margin: 0;
  }

  /* Lenkesonen er kortets egen fot: pinnes til bunn (kortet med mest
     tekst bestemmer høyden, lenkerader i samme rad ligger på linje) og
     skilles visuelt med tonet bakgrunn kant til kant. */
  .lenker {
    display: flex;
    gap: var(--s-4);
    margin: auto calc(-1 * var(--s-4)) calc(-1 * var(--s-4));
    padding: var(--s-3) var(--s-4);
    background: var(--flate-2);
    border-top: 1px solid var(--linje);
    border-radius: 0 0 var(--radius-md) var(--radius-md);
    font-family: var(--font-hd);
    font-size: 13.5px;
    flex-wrap: wrap;
  }

  .lenker a {
    text-decoration: none;
  }

  .lenker a:hover,
  .lenker a:focus-visible {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .pil {
    display: inline-block;
    transition: transform var(--dur-mikro) var(--ease);
  }

  .lenker a:hover .pil,
  .lenker a:focus-visible .pil {
    transform: translateX(3px);
  }

  .lenker a.primaer {
    color: var(--salvie);
  }
</style>
