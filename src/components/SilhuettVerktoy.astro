---
/* Silhuett-verktøyet: skriveark der elevene fyller bokstavene inn i
   ordets silhuett (høye, lave og dype bokser), med valgfritt bilde per
   ord. Samme lest som Ordkryss: oppsett i venstremargen, hvitt ark til
   høyre — arket ER utskriften. Bokstavlogikken bor i src/lib/silhuett.ts;
   bannordfilteret deles med Ordkryss (src/lib/ordkryss-kjerne.ts).
   Bildebanken foreslår bilde fra ordet (docs/PRD-bildebank.md);
   lærerens eget vinner. */

import profil from '../data/profil.json';

interface Props {
  lang?: 'nb' | 'en';
}

const { lang = 'nb' } = Astro.props;
const epost = profil.kontakt.epost;

const t =
  lang === 'nb'
    ? {
        tittelFelt: 'Tittel på arket',
        tittelEks: 'Skriv tittelen her',
        ordNavn: 'Ordene elevene skal skrive',
        ordEks: 'skriv et ord',
        leggTil: '+ Legg til ord',
        bildeHint: 'Bilde ved ordet er valgfritt og blir med på utskriften. Tips: kopier et bilde (høyreklikk → «Kopier bilde») og lim det inn i ordfeltet med Ctrl + V.',
        visOrdbank: 'Vis ordbank øverst på arket',
        lag: 'Lag skriveark',
        skrivUt: 'Skriv ut',
        instruks: 'Skriv ordene så pent du kan i silhuettene.',
        ordbank: 'Ordbank',
        navnLinje: 'Navn: ____________________   Dato: ____________',
        standardTittel: 'Silhuetter',
      }
    : {
        tittelFelt: 'Sheet title',
        tittelEks: 'Type the title here',
        ordNavn: 'Words for the pupils to write',
        ordEks: 'type a word',
        leggTil: '+ Add word',
        bildeHint: 'A picture per word is optional and prints with the sheet. Tip: copy a picture (right-click → “Copy image”) and paste it into the word field with Ctrl + V.',
        visOrdbank: 'Show a word bank at the top of the sheet',
        lag: 'Create writing sheet',
        skrivUt: 'Print',
        instruks: 'Write the words as neatly as you can in the shapes.',
        ordbank: 'Word bank',
        navnLinje: 'Name: ____________________   Date: ____________',
        standardTittel: 'Word shapes',
      };
---

<div class="si-verktoy" data-lang={lang} data-standardtittel={t.standardTittel} data-epost={epost}>
  <div class="si-oppsett">
    <section class="si-panel" aria-labelledby="si-panel-tittel">
      <h2 id="si-panel-tittel" class="sr-only">{lang === 'nb' ? 'Oppsett' : 'Setup'}</h2>

      <label class="si-felt">
        <span class="si-felt-navn">{t.tittelFelt}</span>
        <input type="text" id="si-tittel" placeholder={t.tittelEks} maxlength="60" />
      </label>

      <div class="si-felt">
        <span class="si-felt-navn" id="si-ord-navn">{t.ordNavn}</span>
        <ul id="si-ord-liste" aria-labelledby="si-ord-navn"></ul>
        <button type="button" id="si-legg-til" class="si-sekundaer">{t.leggTil}</button>
        <p class="si-hint">{t.bildeHint}</p>
      </div>

      <label class="si-valg">
        <input type="checkbox" id="si-vis-ordbank" checked />
        {t.visOrdbank}
      </label>

      <button type="button" id="si-lag" class="knapp si-primaer">{t.lag}</button>
      <p id="si-status" class="si-status" role="status" aria-live="polite"></p>
    </section>

    <section class="si-visning" id="si-ark-seksjon" hidden aria-labelledby="si-visning-tittel">
      <h2 id="si-visning-tittel" class="sr-only">
        {lang === 'nb' ? 'Forhåndsvisning' : 'Preview'}
      </h2>
      <div class="si-handlinger">
        <button type="button" id="si-skriv-ut" class="knapp si-primaer">{t.skrivUt}</button>
      </div>

      <div class="si-sticky-print">
        <button type="button" id="si-skriv-ut-sticky" class="si-sticky-knapp" title="Skriv ut arket (Ctrl+P)" aria-label={t.skrivUt}>
          🖨
        </button>
      </div>

      <div class="si-ark" id="si-ark">
        <h3 id="si-overskrift">{t.standardTittel}</h3>
        <p class="si-instruks">{t.instruks}</p>
        <p class="si-navn-linje">{t.navnLinje}</p>
        <div class="si-bank" id="si-bank" hidden>
          <p class="si-bank-navn">{t.ordbank}</p>
          <p class="si-bank-ord" id="si-bank-ord"></p>
        </div>
        <ul id="si-rader" class="si-rader"></ul>
      </div>
    </section>
  </div>
</div>

<style is:global>
  /* Skjerm: verktøyet følger sidens tokens; arket er alltid hvit «papir». */
  .si-oppsett {
    display: grid;
    grid-template-columns: 360px 1fr;
    gap: var(--s-5);
    align-items: start;
    margin-top: var(--s-4);
  }

  @media (max-width: 900px) {
    .si-oppsett {
      grid-template-columns: 1fr;
    }
  }

  .si-panel {
    background: var(--flate);
    border: 1px solid var(--linje);
    border-radius: var(--radius-md);
    box-shadow: var(--kort-skygge);
    padding: var(--s-4);
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
  }

  .si-felt {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin: 0;
    min-width: 0;
  }

  .si-felt-navn {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: 14px;
    color: var(--tekst);
  }

  .si-panel input[type='text'] {
    font-family: var(--font-sans);
    font-size: 16px;
    padding: 9px 10px;
    border: 1px solid var(--linje);
    border-radius: var(--radius-sm);
    background: var(--bg);
    color: var(--tekst);
    min-height: 44px;
    width: 100%;
    box-sizing: border-box;
  }

  .si-valg {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    min-height: 32px;
    color: var(--tekst);
  }

  .si-valg input {
    width: 19px;
    height: 19px;
    accent-color: var(--salvie);
    flex-shrink: 0;
  }

  /* Beroringsskjerm: hele valg-etiketten skal vaere et trygt maal */
  @media (pointer: coarse) {
    .si-valg {
      min-height: 44px;
    }
  }

  .si-hint {
    margin: 2px 0 0;
    font-size: 13.5px;
    color: var(--dempet);
  }

  #si-ord-liste {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .si-ord-rad {
    display: flex;
    gap: 6px;
    align-items: center;
    flex-wrap: wrap; /* bildebank-brikken legger seg på egen linje */
  }

  .si-ord-rad input[type='text'] {
    flex: 1;
    min-width: 0;
  }

  .si-ord-rad.upassende input[type='text'] {
    border-color: var(--feil);
  }

  .si-ikonknapp {
    font: inherit;
    min-width: 44px;
    min-height: 44px;
    border: 1px solid var(--linje);
    border-radius: var(--radius-sm);
    background: var(--bg);
    color: var(--tekst);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 2px;
    flex-shrink: 0;
  }

  .si-ikonknapp:hover {
    border-color: var(--salvie);
  }

  .si-mini-bilde {
    width: 36px;
    height: 36px;
    object-fit: cover;
    border-radius: 6px;
  }

  /* Fjern-bilde-badgen — samme mønster som i Ordkryss */
  .si-bilde-holder {
    position: relative;
    display: inline-flex;
    flex-shrink: 0;
  }

  .si-fjern-bilde {
    position: absolute;
    top: -8px;
    right: -8px;
    width: 24px;
    height: 24px;
    padding: 0;
    border: 1px solid var(--linje);
    border-radius: 50%;
    background: var(--flate-2);
    color: var(--tekst);
    font: 700 11px var(--font-hd);
    line-height: 1;
    display: grid;
    place-items: center;
    cursor: pointer;
    z-index: 1;
  }

  .si-fjern-bilde:hover {
    color: var(--feil);
    border-color: var(--feil);
  }

  .si-fjern-bilde:focus-visible {
    outline: 2px solid var(--salvie);
    outline-offset: 1px;
  }

  .si-primaer {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 700;
    background: var(--salvie);
    color: var(--salvie-kontrast);
    border: none;
    border-radius: 9px;
    padding: 11px 20px;
    min-height: 44px;
    cursor: pointer;
  }

  .si-primaer:hover {
    filter: brightness(1.06);
  }

  .si-sekundaer {
    font-family: var(--font-sans);
    font-size: 14.5px;
    font-weight: 600;
    background: var(--bg);
    color: var(--tekst);
    border: 1px solid var(--linje);
    border-radius: 9px;
    padding: 10px 16px;
    min-height: 44px;
    cursor: pointer;
  }

  .si-sekundaer:hover {
    border-color: var(--salvie);
  }

  .si-sekundaer:disabled {
    opacity: 0.5;
    cursor: default;
  }

  .si-status {
    margin: 0;
    font-size: 14.5px;
    color: var(--dempet);
    min-height: 1.4em;
  }

  .si-status.feil {
    color: var(--feil);
  }

  .si-handlinger {
    display: flex;
    gap: var(--s-3);
    flex-wrap: wrap;
    margin-bottom: var(--s-3);
  }

  /* Flytende print-knapp når arket er langt */
  .si-sticky-print {
    position: fixed;
    right: 24px;
    bottom: 24px;
    z-index: 15;
  }

  .si-sticky-knapp {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    border: 1px solid var(--linje);
    background: var(--salvie);
    color: var(--salvie-kontrast);
    font-size: 22px;
    cursor: pointer;
    box-shadow: var(--kort-skygge);
    display: grid;
    place-items: center;
  }

  .si-sticky-knapp:hover {
    filter: brightness(1.06);
  }

  /* ---- Arket: alltid hvitt papir, uavhengig av tema ---- */
  .si-ark {
    /* --si-skala settes av genereringen: få ord = store silhuetter,
       mange ord = mindre (og to kolonner / A3 ved behov) */
    --si-skala: 1;
    --si-x: calc(26px * var(--si-skala)); /* x-høyden */
    --si-topp: calc(13px * var(--si-skala)); /* over x-høyden */
    --si-bunn: calc(13px * var(--si-skala)); /* under grunnlinja */
    --si-bredde: calc(28px * var(--si-skala));
    --si-strek: 2px;
    background: #fff;
    color: #111;
    border: 1px solid var(--linje);
    border-radius: var(--radius-md);
    box-shadow: var(--kort-skygge);
    padding: 28px 32px;
    max-width: 660px;
  }

  #si-overskrift {
    margin: 0 0 4px;
    font-size: 24px;
    color: #111;
  }

  .si-instruks {
    margin: 0 0 6px;
    font-size: 14.5px;
    color: #333;
  }

  .si-navn-linje {
    margin: 0 0 16px;
    font-size: 13.5px;
    color: #333;
  }

  .si-bank {
    border: 2px solid #333;
    border-radius: 6px;
    padding: 8px 14px;
    margin-bottom: 18px;
    text-align: center;
  }

  .si-bank-navn {
    margin: 0;
    font-weight: 700;
    font-size: 14.5px;
    text-decoration: underline;
    color: #111;
  }

  .si-bank-ord {
    margin: 2px 0 0;
    font-size: 15px;
    color: #111;
  }

  .si-rader {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: calc(22px * var(--si-skala));
  }

  .si-rader[data-kolonner='2'] {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: calc(28px * var(--si-skala));
    row-gap: calc(22px * var(--si-skala));
  }

  .si-rad {
    display: flex;
    align-items: center;
    gap: 18px;
  }

  /* Systememoji-forslag fra bildebanken rendres som glyf */
  span.si-rad-bilde.bb-ark-glyf {
    height: auto;
    border: none;
    font-size: calc(50px * var(--si-skala));
    line-height: calc(64px * var(--si-skala));
  }

  .si-rad-bilde {
    width: calc(64px * var(--si-skala));
    height: calc(64px * var(--si-skala));
    object-fit: cover;
    border: 1px solid #333;
    border-radius: 4px;
    flex-shrink: 0;
  }

  /* Silhuetten: boksene deler grunnlinje — høye rager opp, dype henger
     under. Naboer deler kantstrek (negativ margin). */
  .si-ord {
    display: flex;
    align-items: flex-start;
    min-height: calc(var(--si-topp) + var(--si-x) + var(--si-bunn));
    flex-wrap: wrap;
  }

  .si-boks {
    box-sizing: border-box;
    width: var(--si-bredde);
    height: var(--si-x);
    margin-top: var(--si-topp);
    border: var(--si-strek) solid #333;
    background: #fff;
    flex-shrink: 0;
  }

  .si-boks + .si-boks {
    margin-left: calc(-1 * var(--si-strek));
  }

  .si-boks.hoy {
    margin-top: 0;
    height: calc(var(--si-topp) + var(--si-x));
  }

  .si-boks.dyp {
    height: calc(var(--si-x) + var(--si-bunn));
  }

  /* ---- Utskrift: kun arket, alltid lyst ---- */
  @media print {
    @page {
      margin: 14mm;
    }

    /* Lys utskrift uansett tema: color-scheme dark får ellers Chrome til
       å male hele arket mørkt i print */
    html,
    body {
      color-scheme: light;
      background: #fff !important;
      color: #000;
    }

    /* Skjul alt UI-krom — men ALDRI .ramme (main): den er arkets
       forelder, og skjules den, printes en tom side */
    .topp,
    .bunn,
    .hopp,
    .si-panel,
    .si-handlinger,
    .si-side-hode,
    .si-sticky-print {
      display: none !important;
    }

    .ramme {
      padding: 0;
      max-width: none;
      min-height: 0;
      background: #fff;
    }

    .si-oppsett {
      display: block;
      margin: 0;
    }

    .si-ark {
      --si-x: calc(9mm * var(--si-skala));
      --si-topp: calc(4.5mm * var(--si-skala));
      --si-bunn: calc(4.5mm * var(--si-skala));
      --si-bredde: calc(9.5mm * var(--si-skala));
      --si-strek: 0.5mm;
      border: none;
      box-shadow: none;
      border-radius: 0;
      padding: 0;
      max-width: none;
    }

    .si-rader {
      gap: calc(9mm * var(--si-skala));
    }

    .si-rader[data-kolonner='2'] {
      column-gap: calc(10mm * var(--si-skala));
      row-gap: calc(9mm * var(--si-skala));
    }

    .si-rad {
      gap: calc(8mm * var(--si-skala));
      break-inside: avoid;
    }

    .si-ord {
      flex-wrap: nowrap;
    }

    .si-rad-bilde {
      width: calc(20mm * var(--si-skala));
      height: calc(20mm * var(--si-skala));
      print-color-adjust: exact;
      -webkit-print-color-adjust: exact;
    }

    span.si-rad-bilde.bb-ark-glyf {
      height: auto;
      font-size: calc(15mm * var(--si-skala));
      line-height: calc(20mm * var(--si-skala));
    }

    .si-bank {
      margin-bottom: 8mm;
    }
  }
</style>

<script>
  import { bokstavBokser } from '../lib/silhuett';
  import { normaliserOrd, ordErUpassende } from '../lib/ordkryss-kjerne';
  import { opprettBildebank } from '../lib/bildebank-brikke';

  const rot = document.querySelector<HTMLElement>('.si-verktoy');
  if (rot) {
    const lang = (rot.dataset.lang ?? 'nb') as 'nb' | 'en';
    const standardTittel = rot.dataset.standardtittel ?? 'Silhuetter';
    const LAGRINGSNOKKEL = `silhuett-${lang}`;
    const MAKS_ORD = 24;

    const M =
      lang === 'nb'
        ? {
            minstEttOrd: 'Skriv inn minst ett ord først.',
            upassende: (o: string) =>
              `«${o}» passer ikke på et skoleark. Bytt ut ordet, så lager vi arket.`,
            klart: (antall: number, kolonner: number, ark: string) =>
              `Arket er klart: ${antall} ord${kolonner === 2 ? ' i to kolonner' : ''}${ark === 'a3' ? ' på A3' : ''}.`,
            ordAria: (i: number) => `Ord ${i}`,
            byttBilde: (i: number) => `Bytt bilde for ord ${i}`,
            leggBilde: (i: number) => `Legg til bilde for ord ${i}`,
            fjernBilde: (i: number) => `Fjern bildet for ord ${i}`,
            fjernOrd: (i: number) => `Fjern ord ${i}`,
            ordEks: 'skriv et ord',
          }
        : {
            minstEttOrd: 'Type at least one word first.',
            upassende: (o: string) =>
              `“${o}” does not belong on a school sheet. Swap the word and we will make the sheet.`,
            klart: (antall: number, kolonner: number, ark: string) =>
              `The sheet is ready: ${antall} words${kolonner === 2 ? ' in two columns' : ''}${ark === 'a3' ? ' on A3' : ''}.`,
            ordAria: (i: number) => `Word ${i}`,
            byttBilde: (i: number) => `Change picture for word ${i}`,
            leggBilde: (i: number) => `Add picture for word ${i}`,
            fjernBilde: (i: number) => `Remove the picture for word ${i}`,
            fjernOrd: (i: number) => `Remove word ${i}`,
            ordEks: 'type a word',
          };

    interface OrdRad {
      id: number;
      tekst: string;
      bilde: string | null;
    }

    let ordListe: OrdRad[] = [];
    let nesteId = 1;

    const el = <T extends HTMLElement = HTMLElement>(id: string): T =>
      document.getElementById(id) as T;

    const bildebank = opprettBildebank({
      lang,
      epost: rot.dataset.epost,
      erUpassende: ordErUpassende,
    });

    /** Lærerens eget bilde vinner; ellers bildebankens forslag (kan være null). */
    function bildeElementFor(o: OrdRad, klasse: string): HTMLElement | null {
      if (o.bilde) {
        const img = document.createElement('img');
        img.src = o.bilde;
        img.alt = '';
        img.className = klasse;
        return img;
      }
      const forslag = bildebank.lagArkElement(o.id);
      if (forslag) forslag.classList.add(klasse);
      return forslag;
    }

    function lagreUtkast() {
      try {
        localStorage.setItem(
          LAGRINGSNOKKEL,
          JSON.stringify({
            tittel: el<HTMLInputElement>('si-tittel').value,
            visOrdbank: el<HTMLInputElement>('si-vis-ordbank').checked,
            ord: ordListe.map((o) => o.tekst),
          })
        );
      } catch {}
    }

    function lastUtkast(): boolean {
      try {
        const raa = localStorage.getItem(LAGRINGSNOKKEL);
        if (!raa) return false;
        const u = JSON.parse(raa);
        el<HTMLInputElement>('si-tittel').value = u.tittel ?? '';
        el<HTMLInputElement>('si-vis-ordbank').checked = u.visOrdbank !== false;
        // Tåler utkast fra andre versjoner: strenger eller {tekst, bilde}
        (u.ord ?? []).forEach((o: unknown) => {
          const tekst =
            typeof o === 'string'
              ? o
              : typeof (o as Record<string, unknown>)?.tekst === 'string'
                ? ((o as Record<string, unknown>).tekst as string)
                : '';
          ordListe.push({ id: nesteId++, tekst, bilde: null });
        });
        return ordListe.length > 0;
      } catch {
        return false;
      }
    }

    function leggTilOrd(tekst = '') {
      if (ordListe.length >= MAKS_ORD) return;
      ordListe.push({ id: nesteId++, tekst, bilde: null });
      tegnOrdListe();
    }

    function tegnOrdListe() {
      const liste = el('si-ord-liste');
      liste.replaceChildren();

      ordListe.forEach((ord, indeks) => {
        const rad = document.createElement('li');
        rad.className = 'si-ord-rad';

        const felt = document.createElement('input');
        felt.type = 'text';
        felt.value = ord.tekst.slice(0, 18);
        felt.maxLength = 18;
        felt.setAttribute('aria-label', M.ordAria(indeks + 1));
        felt.placeholder = M.ordEks;
        felt.addEventListener('input', () => {
          ord.tekst = felt.value;
          const stygt = ordErUpassende(felt.value);
          rad.classList.toggle('upassende', stygt);
          felt.setAttribute('aria-invalid', stygt ? 'true' : 'false');
          lagreUtkast();
        });
        if (ordErUpassende(ord.tekst)) rad.classList.add('upassende');

        // Lim inn bilde rett i ordfeltet: både «Kopier bilde» fra nettet
        // (clipboardData.items) og kopierte bildefiler fra filutforskeren
        // (clipboardData.files). Vanlig tekst-liming går sin gang.
        felt.addEventListener('paste', (e) => {
          const data = e.clipboardData;
          if (!data) return;
          const fraItems = [...data.items]
            .find((i) => i.type.startsWith('image/'))
            ?.getAsFile();
          const fraFiler = [...data.files].find((f) => f.type.startsWith('image/'));
          const fil = fraItems ?? fraFiler;
          if (!fil) return;
          e.preventDefault();
          const leser = new FileReader();
          leser.onload = () => {
            ord.bilde = String(leser.result);
            tegnOrdListe();
            lagreUtkast();
          };
          leser.readAsDataURL(fil);
        });

        const bildeKnapp = document.createElement('button');
        bildeKnapp.type = 'button';
        bildeKnapp.className = 'si-ikonknapp';
        bildeKnapp.setAttribute(
          'aria-label',
          ord.bilde ? M.byttBilde(indeks + 1) : M.leggBilde(indeks + 1)
        );

        if (ord.bilde) {
          const mini = document.createElement('img');
          mini.src = ord.bilde;
          mini.alt = '';
          mini.className = 'si-mini-bilde';
          bildeKnapp.appendChild(mini);
        } else {
          bildeKnapp.textContent = '🖼';
        }

        const filFelt = document.createElement('input');
        filFelt.type = 'file';
        filFelt.accept = 'image/*';
        filFelt.hidden = true;
        filFelt.addEventListener('change', () => {
          const fil = filFelt.files?.[0];
          if (!fil) return;
          const leser = new FileReader();
          leser.onload = () => {
            ord.bilde = String(leser.result);
            tegnOrdListe();
          };
          leser.readAsDataURL(fil);
        });
        bildeKnapp.addEventListener('click', () => filFelt.click());

        // Bildet kan fjernes for seg (uten å slette ordet)
        const bildeHolder = document.createElement('span');
        bildeHolder.className = 'si-bilde-holder';
        bildeHolder.appendChild(bildeKnapp);
        if (ord.bilde) {
          const fjernBilde = document.createElement('button');
          fjernBilde.type = 'button';
          fjernBilde.className = 'si-fjern-bilde';
          fjernBilde.textContent = '✕';
          fjernBilde.setAttribute('aria-label', M.fjernBilde(indeks + 1));
          fjernBilde.addEventListener('click', () => {
            ord.bilde = null;
            tegnOrdListe();
            lagreUtkast();
          });
          bildeHolder.appendChild(fjernBilde);
        }

        const fjern = document.createElement('button');
        fjern.type = 'button';
        fjern.className = 'si-ikonknapp';
        fjern.textContent = '✕';
        fjern.setAttribute('aria-label', M.fjernOrd(indeks + 1));
        fjern.addEventListener('click', () => {
          ordListe = ordListe.filter((o) => o.id !== ord.id);
          bildebank.nullstill(ord.id);
          if (ordListe.length === 0) leggTilOrd();
          tegnOrdListe();
          lagreUtkast();
        });

        rad.append(felt, bildeHolder, filFelt, fjern);
        bildebank.monter(ord.id, felt, rad);
        liste.appendChild(rad);
      });

      el<HTMLButtonElement>('si-legg-til').disabled = ordListe.length >= MAKS_ORD;
    }

    function siStatus(tekst: string, erFeil = false) {
      const status = el('si-status');
      status.textContent = tekst;
      status.classList.toggle('feil', erFeil);
    }

    /* Layoutberegning: få ord = store silhuetter, mange = mindre, to
       kolonner over 10 rader-ekvivalenter, og A3 når A4 måtte krympe
       under lesbart. Alt regnes i print-mm (skjermen speiler skalaen). */
    function velgLayout(
      antall: number,
      maxLen: number,
      harBilde: boolean,
      visBank: boolean
    ) {
      const skalaFor = (kolonner: number, ark: 'a4' | 'a3') => {
        const bredde = (ark === 'a3' ? 269 : 182) - (kolonner - 1) * 10;
        // Høydebudsjett: topptekst 34mm, ordbank vokser med antall linjer
        // (ca. 10 ord per linje), pluss 8mm sikkerhetsmargin mot side 2
        const bankHoyde = visBank ? 14 + Math.ceil(antall / 10) * 7 : 0;
        const hoyde = (ark === 'a3' ? 392 : 269) - 34 - bankHoyde - 8;
        const kolB = bredde / kolonner - 3; // 3mm slakk mot boks-brekk
        const radBredde = maxLen * 9.5 + (harBilde ? 28 : 0);
        const radHoyde = 27 + (harBilde ? 2 : 0);
        const raderPerKol = Math.ceil(antall / kolonner);
        return Math.min(2, kolB / radBredde, hoyde / (raderPerKol * radHoyde));
      };
      // Prøv A4 først (1 kolonne, så 2 hvis mange ord) — A3 bare når
      // A4 ikke gir lesbar størrelse
      const kandidater: Array<{ kolonner: number; ark: 'a4' | 'a3' }> = [
        { kolonner: 1, ark: 'a4' },
      ];
      if (antall > 6) kandidater.push({ kolonner: 2, ark: 'a4' });
      let best = kandidater[0];
      let bestSkala = skalaFor(best.kolonner, best.ark);
      for (const k of kandidater.slice(1)) {
        const sk = skalaFor(k.kolonner, k.ark);
        if (sk > bestSkala) {
          best = k;
          bestSkala = sk;
        }
      }
      if (bestSkala < 0.85) {
        for (const k of [
          { kolonner: 2, ark: 'a3' as const },
          { kolonner: 1, ark: 'a3' as const },
        ]) {
          const sk = skalaFor(k.kolonner, k.ark);
          if (sk > bestSkala) {
            best = k;
            bestSkala = sk;
          }
        }
      }
      return { ...best, skala: Math.max(0.55, Math.floor(bestSkala * 100) / 100) };
    }

    /* A3 krever egen @page-regel — den kan ikke styres med klasser, så
       den injiseres/fjernes som eget style-element */
    function settArkStorrelse(ark: 'a4' | 'a3') {
      let stil = document.getElementById('si-page-stil');
      if (ark === 'a3') {
        if (!stil) {
          stil = document.createElement('style');
          stil.id = 'si-page-stil';
          document.head.appendChild(stil);
        }
        stil.textContent = '@media print { @page { size: A3 portrait; margin: 14mm; } }';
      } else if (stil) {
        stil.remove();
      }
    }

    function generer() {
      const rene = ordListe
        .map((o) => ({ ...o, tekst: o.tekst.trim() }))
        .filter((o) => o.tekst.length > 0);

      if (rene.length === 0) {
        siStatus(M.minstEttOrd, true);
        return;
      }

      for (const o of rene) {
        if (ordErUpassende(o.tekst)) {
          siStatus(M.upassende(o.tekst), true);
          return;
        }
      }

      // Overskrift og ordbank
      el('si-overskrift').textContent =
        el<HTMLInputElement>('si-tittel').value.trim() || standardTittel;

      // Ordbanken STOKKES (Fisher-Yates) så rekkefølgen aldri speiler
      // silhuettene — ellers kan eleven bare skrive av ovenfra og ned
      const visBank = el<HTMLInputElement>('si-vis-ordbank').checked;
      const bank = el('si-bank');
      bank.hidden = !visBank;
      if (visBank) {
        const stokket = rene.map((o) => normaliserOrd(o.tekst).toLowerCase());
        for (let i = stokket.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          [stokket[i], stokket[j]] = [stokket[j], stokket[i]];
        }
        el('si-bank-ord').textContent = stokket.join('  –  ');
      }

      // Dynamisk layout ut fra antall og lengste ord
      const bokserPerOrd = rene.map((o) => bokstavBokser(o.tekst).length);
      const maxLen = Math.max(1, ...bokserPerOrd);
      const harBilde = rene.some((o) => o.bilde || bildebank.forslagFor(o.id));
      const layout = velgLayout(rene.length, maxLen, harBilde, visBank);
      const ark = el('si-ark');
      ark.style.setProperty('--si-skala', String(layout.skala));
      settArkStorrelse(layout.ark);

      // Radene: bilde (om det finnes) + silhuettboksene
      const rader = el('si-rader');
      if (layout.kolonner === 2) {
        rader.setAttribute('data-kolonner', '2');
      } else {
        rader.removeAttribute('data-kolonner');
      }
      rader.replaceChildren();
      rene.forEach((o) => {
        const rad = document.createElement('li');
        rad.className = 'si-rad';

        const bilde = bildeElementFor(o, 'si-rad-bilde');
        if (bilde) rad.appendChild(bilde);

        const ordEl = document.createElement('span');
        ordEl.className = 'si-ord';
        ordEl.setAttribute('aria-label', normaliserOrd(o.tekst).toLowerCase());
        bokstavBokser(o.tekst).forEach((boks) => {
          const b = document.createElement('span');
          b.className = `si-boks ${boks.type}`;
          ordEl.appendChild(b);
        });
        rad.appendChild(ordEl);
        rader.appendChild(rad);
      });

      el('si-ark-seksjon').removeAttribute('hidden');
      siStatus(M.klart(rene.length, layout.kolonner, layout.ark));
      lagreUtkast();
    }

    // Init
    if (!lastUtkast()) {
      leggTilOrd();
      leggTilOrd();
      leggTilOrd();
    }
    tegnOrdListe();
    el('si-legg-til').parentElement?.appendChild(bildebank.innstillinger());

    ['si-tittel', 'si-vis-ordbank'].forEach((id) =>
      el(id).addEventListener('change', lagreUtkast)
    );

    el('si-legg-til').addEventListener('click', () => {
      leggTilOrd();
      lagreUtkast();
    });

    el('si-lag').addEventListener('click', generer);

    const skrivUt = () => window.print();
    el('si-skriv-ut').addEventListener('click', skrivUt);
    el('si-skriv-ut-sticky').addEventListener('click', skrivUt);
  }
</script>
