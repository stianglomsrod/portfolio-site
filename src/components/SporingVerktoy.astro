---
/* Sporing-verktøyet v2: ekte norsk skriftforming (se
   docs/innsikt/SPORING-DESIGN.md). Hver rad er et BOKSTAVHUS: fire
   linjer med loft/stue/kjeller (valgfrie sonefarger gul/rosa/blå) og
   hus-ikon med tak til venstre. Modellbokstaven tegnes med solid strek
   (vokal rød / konsonant blå, valgfritt sort), grønn startprikk per
   strøk, strøknummer når det er flere, og pilspiss langs strøket —
   posisjon og vinkel leses ut av skjelettbanene i
   src/lib/bokstavbaner.ts med getPointAtLength. Deretter følger
   stiplede sporebokstaver, og valgfri tom øvelinje under (mønsteret fra
   Kaleido skriftforming: modellrad → tom rad). */

interface Props {
  lang?: 'nb' | 'en';
}

const { lang = 'nb' } = Astro.props;

const t =
  lang === 'nb'
    ? {
        tittelFelt: 'Tittel på arket',
        tittelEks: 'Skriv tittelen her',
        radNavn: 'Bokstaver eller ord (én per rad)',
        radEks: 'f.eks. a eller sol',
        leggTil: '+ Legg til rad',
        hint: 'Én bokstav per rad gir full skriftforming med startpunkt, tall og piler. Et ord gir sporing av hele ordet.',
        storrelse: 'Størrelse',
        storrelseStor: 'stor (1.–2. trinn)',
        storrelseMiddels: 'middels',
        husfarger: 'Farger i bokstavhuset (loft, stue, kjeller)',
        bokstavfarge: 'Farge på modellbokstaven',
        fargeVokal: 'vokaler røde, konsonanter blå',
        fargeSort: 'sort',
        tomLinje: 'Tom øvelinje under hver rad',
        lag: 'Lag sporingsark',
        skrivUt: 'Skriv ut',
        navnLinje: 'Navn: ____________________   Dato: ____________',
        instruks: 'Start på den grønne prikken og følg pilene. Spor bokstavene så pent du kan.',
        standardTittel: 'Sporing',
      }
    : {
        tittelFelt: 'Sheet title',
        tittelEks: 'Type the title here',
        radNavn: 'Letters or words (one per row)',
        radEks: 'e.g. a or sun',
        leggTil: '+ Add row',
        hint: 'A single letter per row gives full letter formation with starting point, numbers and arrows. A word gives tracing of the whole word.',
        storrelse: 'Size',
        storrelseStor: 'large (early years)',
        storrelseMiddels: 'medium',
        husfarger: 'Colours in the letter house (attic, living room, basement)',
        bokstavfarge: 'Model letter colour',
        fargeVokal: 'vowels red, consonants blue',
        fargeSort: 'black',
        tomLinje: 'Empty practice line under each row',
        lag: 'Create tracing sheet',
        skrivUt: 'Print',
        navnLinje: 'Name: ____________________   Date: ____________',
        instruks: 'Start at the green dot and follow the arrows. Trace the letters as neatly as you can.',
        standardTittel: 'Tracing',
      };
---

<div class="sp-verktoy" data-lang={lang} data-standardtittel={t.standardTittel}>
  <div class="sp-oppsett">
    <section class="sp-panel" aria-labelledby="sp-panel-tittel">
      <h2 id="sp-panel-tittel" class="sr-only">{lang === 'nb' ? 'Oppsett' : 'Setup'}</h2>

      <label class="sp-felt">
        <span class="sp-felt-navn">{t.tittelFelt}</span>
        <input type="text" id="sp-tittel" placeholder={t.tittelEks} maxlength="60" />
      </label>

      <div class="sp-felt">
        <span class="sp-felt-navn" id="sp-rad-navn">{t.radNavn}</span>
        <ul id="sp-liste" aria-labelledby="sp-rad-navn"></ul>
        <button type="button" id="sp-legg-til" class="sp-sekundaer">{t.leggTil}</button>
        <p class="sp-hint">{t.hint}</p>
      </div>

      <label class="sp-felt">
        <span class="sp-felt-navn">{t.storrelse}</span>
        <select id="sp-storrelse">
          <option value="stor" selected>{t.storrelseStor}</option>
          <option value="middels">{t.storrelseMiddels}</option>
        </select>
      </label>

      <label class="sp-felt">
        <span class="sp-felt-navn">{t.bokstavfarge}</span>
        <select id="sp-farge">
          <option value="vokal" selected>{t.fargeVokal}</option>
          <option value="sort">{t.fargeSort}</option>
        </select>
      </label>

      <label class="sp-valg">
        <input type="checkbox" id="sp-husfarger" checked />
        {t.husfarger}
      </label>

      <label class="sp-valg">
        <input type="checkbox" id="sp-tom-linje" checked />
        {t.tomLinje}
      </label>

      <button type="button" id="sp-lag" class="knapp sp-primaer">{t.lag}</button>
      <p id="sp-status" class="sp-status" role="status" aria-live="polite"></p>
    </section>

    <section class="sp-visning" id="sp-ark-seksjon" hidden aria-labelledby="sp-visning-tittel">
      <h2 id="sp-visning-tittel" class="sr-only">
        {lang === 'nb' ? 'Forhåndsvisning' : 'Preview'}
      </h2>
      <div class="sp-handlinger">
        <button type="button" id="sp-skriv-ut" class="knapp sp-primaer">{t.skrivUt}</button>
      </div>

      <div class="sp-sticky-print">
        <button type="button" id="sp-skriv-ut-sticky" class="sp-sticky-knapp" title="Skriv ut arket (Ctrl+P)" aria-label={t.skrivUt}>
          🖨
        </button>
      </div>

      <div class="sp-ark" id="sp-ark">
        <h3 id="sp-overskrift">{t.standardTittel}</h3>
        <p class="sp-instruks">{t.instruks}</p>
        <p class="sp-navn-linje">{t.navnLinje}</p>
        <div id="sp-rader" class="sp-rader"></div>
      </div>
    </section>
  </div>
</div>

<style is:global>
  .sp-oppsett {
    display: grid;
    grid-template-columns: 360px 1fr;
    gap: var(--s-5);
    align-items: start;
    margin-top: var(--s-4);
  }

  @media (max-width: 900px) {
    .sp-oppsett {
      grid-template-columns: 1fr;
    }
  }

  .sp-panel {
    background: var(--flate);
    border: 1px solid var(--linje);
    border-radius: var(--radius-md);
    box-shadow: var(--kort-skygge);
    padding: var(--s-4);
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
  }

  .sp-felt {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin: 0;
    min-width: 0;
  }

  .sp-felt-navn {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: 14px;
    color: var(--tekst);
  }

  .sp-panel input[type='text'],
  .sp-panel select {
    font-family: var(--font-sans);
    font-size: 16px;
    padding: 9px 10px;
    border: 1px solid var(--linje);
    border-radius: var(--radius-sm);
    background: var(--bg);
    color: var(--tekst);
    min-height: 44px;
    width: 100%;
    box-sizing: border-box;
  }

  .sp-valg {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    min-height: 32px;
    color: var(--tekst);
  }

  .sp-valg input {
    width: 19px;
    height: 19px;
    accent-color: var(--salvie);
    flex-shrink: 0;
  }

  @media (pointer: coarse) {
    .sp-valg {
      min-height: 44px;
    }
  }

  .sp-hint {
    margin: 2px 0 0;
    font-size: 13.5px;
    color: var(--dempet);
  }

  #sp-liste {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .sp-rad-inn {
    display: flex;
    gap: 6px;
    align-items: center;
  }

  .sp-rad-inn input[type='text'] {
    flex: 1;
    min-width: 0;
  }

  .sp-rad-inn.upassende input[type='text'] {
    border-color: var(--feil);
  }

  .sp-ikonknapp {
    font: inherit;
    min-width: 44px;
    min-height: 44px;
    border: 1px solid var(--linje);
    border-radius: var(--radius-sm);
    background: var(--bg);
    color: var(--tekst);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .sp-ikonknapp:hover {
    border-color: var(--salvie);
  }

  .sp-primaer {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 700;
    background: var(--salvie);
    color: var(--salvie-kontrast);
    border: none;
    border-radius: 9px;
    padding: 11px 20px;
    min-height: 44px;
    cursor: pointer;
  }

  .sp-primaer:hover {
    filter: brightness(1.06);
  }

  .sp-sekundaer {
    font-family: var(--font-sans);
    font-size: 14.5px;
    font-weight: 600;
    background: var(--bg);
    color: var(--tekst);
    border: 1px solid var(--linje);
    border-radius: 9px;
    padding: 10px 16px;
    min-height: 44px;
    cursor: pointer;
  }

  .sp-sekundaer:hover {
    border-color: var(--salvie);
  }

  .sp-sekundaer:disabled {
    opacity: 0.5;
    cursor: default;
  }

  .sp-status {
    margin: 0;
    font-size: 14.5px;
    color: var(--dempet);
    min-height: 1.4em;
  }

  .sp-status.feil {
    color: var(--feil);
  }

  .sp-handlinger {
    display: flex;
    gap: var(--s-3);
    flex-wrap: wrap;
    margin-bottom: var(--s-3);
  }

  .sp-sticky-print {
    position: fixed;
    right: 24px;
    bottom: 24px;
    z-index: 15;
  }

  .sp-sticky-knapp {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    border: 1px solid var(--linje);
    background: var(--salvie);
    color: var(--salvie-kontrast);
    font-size: 22px;
    cursor: pointer;
    box-shadow: var(--kort-skygge);
    display: grid;
    place-items: center;
  }

  .sp-ark {
    background: #fff;
    color: #111;
    border: 1px solid var(--linje);
    border-radius: var(--radius-md);
    box-shadow: var(--kort-skygge);
    padding: 28px 32px;
    max-width: 660px;
  }

  #sp-overskrift {
    margin: 0 0 4px;
    font-size: 24px;
    color: #111;
  }

  .sp-instruks {
    margin: 0 0 6px;
    font-size: 14.5px;
    color: #333;
  }

  .sp-navn-linje {
    margin: 0 0 18px;
    font-size: 13.5px;
    color: #333;
  }

  .sp-rader {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .sp-rad svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .sp-rader[data-storrelse='middels'] .sp-rad svg {
    width: 82%;
  }

  @media print {
    @page {
      margin: 14mm;
    }

    html,
    body {
      color-scheme: light;
      background: #fff !important;
      color: #000;
    }

    .topp,
    .bunn,
    .hopp,
    .sp-panel,
    .sp-handlinger,
    .sp-side-hode,
    .sp-sticky-print {
      display: none !important;
    }

    .ramme {
      padding: 0;
      max-width: none;
      min-height: 0;
      background: #fff;
    }

    .sp-oppsett {
      display: block;
      margin: 0;
    }

    .sp-ark {
      border: none;
      box-shadow: none;
      border-radius: 0;
      padding: 0;
      max-width: none;
    }

    .sp-rader {
      gap: 6mm;
    }

    .sp-rad {
      break-inside: avoid;
    }

    .sp-rad svg {
      print-color-adjust: exact;
      -webkit-print-color-adjust: exact;
    }
  }
</style>

<script>
  import { ordErUpassende } from '../lib/ordkryss-kjerne';
  import { LINJER, VOKALER, bane } from '../lib/bokstavbaner';

  const rot = document.querySelector<HTMLElement>('.sp-verktoy');
  if (rot) {
    const lang = (rot.dataset.lang ?? 'nb') as 'nb' | 'en';
    const standardTittel = rot.dataset.standardtittel ?? 'Sporing';
    const LAGRINGSNOKKEL = `sporing-${lang}`;
    const MAKS = 8;
    const NS = 'http://www.w3.org/2000/svg';

    // fargene fra designgrunnlaget
    const SONE_LOFT = '#FFF3C6';
    const SONE_STUE = '#FBE3EF';
    const SONE_KJELLER = '#DDEFF8';
    const ROD = '#c23a2f';
    const BLAA = '#1f5f8b';
    const SORT = '#222';
    const GRONN = '#1a8a3a';
    const SPOR = '#b8b8b8';
    const PIL = '#8d8d8d';

    const VB_BREDDE = 330;
    const VB_HOYDE = 44;
    const START_X = 24; // etter hus-ikonet
    const GAP = 7;

    const M =
      lang === 'nb'
        ? {
            minstEn: 'Skriv inn minst én bokstav eller ett ord.',
            upassende: (o: string) =>
              `«${o}» passer ikke på et skoleark. Bytt det ut, så lager vi arket.`,
            ukjentTegn: (tegn: string, rad: string) =>
              `«${tegn}» i «${rad}» har ingen sporingsbane ennå — bruk bokstavene a–å og A–Å.`,
            klart: (n: number) => `Arket er klart: ${n} rader.`,
            radAria: (i: number) => `Rad ${i}`,
            fjern: (i: number) => `Fjern rad ${i}`,
            radEks: 'f.eks. a eller sol',
          }
        : {
            minstEn: 'Type at least one letter or word.',
            upassende: (o: string) =>
              `“${o}” does not belong on a school sheet. Swap it and we will make the sheet.`,
            ukjentTegn: (tegn: string, rad: string) =>
              `“${tegn}” in “${rad}” has no tracing path yet — use the letters a–å and A–Å.`,
            klart: (n: number) => `The sheet is ready: ${n} rows.`,
            radAria: (i: number) => `Row ${i}`,
            fjern: (i: number) => `Remove row ${i}`,
            radEks: 'e.g. a or sun',
          };

    interface Rad {
      id: number;
      tekst: string;
    }

    let rader: Rad[] = [];
    let nesteId = 1;

    const el = <T extends HTMLElement = HTMLElement>(id: string): T =>
      document.getElementById(id) as T;

    function lagreUtkast() {
      try {
        localStorage.setItem(
          LAGRINGSNOKKEL,
          JSON.stringify({
            tittel: el<HTMLInputElement>('sp-tittel').value,
            storrelse: el<HTMLSelectElement>('sp-storrelse').value,
            farge: el<HTMLSelectElement>('sp-farge').value,
            husfarger: el<HTMLInputElement>('sp-husfarger').checked,
            tomLinje: el<HTMLInputElement>('sp-tom-linje').checked,
            rader: rader.map((r) => r.tekst),
          })
        );
      } catch {}
    }

    function lastUtkast(): boolean {
      try {
        const raa = localStorage.getItem(LAGRINGSNOKKEL);
        if (!raa) return false;
        const u = JSON.parse(raa);
        el<HTMLInputElement>('sp-tittel').value = u.tittel ?? '';
        (['storrelse', 'farge'] as const).forEach((navn) => {
          const felt = el<HTMLSelectElement>(`sp-${navn}`);
          if ([...felt.options].some((o) => o.value === u[navn])) felt.value = u[navn];
        });
        el<HTMLInputElement>('sp-husfarger').checked = u.husfarger !== false;
        el<HTMLInputElement>('sp-tom-linje').checked = u.tomLinje !== false;
        (u.rader ?? []).forEach((r: unknown) => {
          if (typeof r === 'string') rader.push({ id: nesteId++, tekst: r });
        });
        return rader.length > 0;
      } catch {
        return false;
      }
    }

    function leggTil(tekst = '') {
      if (rader.length >= MAKS) return;
      rader.push({ id: nesteId++, tekst });
      tegnListe();
    }

    function tegnListe() {
      const liste = el('sp-liste');
      liste.replaceChildren();
      rader.forEach((rad, indeks) => {
        const li = document.createElement('li');
        li.className = 'sp-rad-inn';
        const felt = document.createElement('input');
        felt.type = 'text';
        felt.value = rad.tekst.slice(0, 12);
        felt.maxLength = 12;
        felt.placeholder = M.radEks;
        felt.setAttribute('aria-label', M.radAria(indeks + 1));
        felt.addEventListener('input', () => {
          rad.tekst = felt.value;
          const stygt = ordErUpassende(felt.value);
          li.classList.toggle('upassende', stygt);
          felt.setAttribute('aria-invalid', stygt ? 'true' : 'false');
          lagreUtkast();
        });
        const fjern = document.createElement('button');
        fjern.type = 'button';
        fjern.className = 'sp-ikonknapp';
        fjern.textContent = '✕';
        fjern.setAttribute('aria-label', M.fjern(indeks + 1));
        fjern.addEventListener('click', () => {
          rader = rader.filter((r) => r.id !== rad.id);
          if (rader.length === 0) leggTil();
          tegnListe();
          lagreUtkast();
        });
        li.append(felt, fjern);
        liste.appendChild(li);
      });
      el<HTMLButtonElement>('sp-legg-til').disabled = rader.length >= MAKS;
    }

    function svgEl(navn: string, attrs: Record<string, string>, tekst?: string) {
      const e = document.createElementNS(NS, navn);
      for (const [k, v] of Object.entries(attrs)) e.setAttribute(k, v);
      if (tekst !== undefined) e.textContent = tekst;
      return e;
    }

    function tegnFor(tegn: string, fargevalg: string): string {
      if (fargevalg === 'sort') return SORT;
      return VOKALER.has(tegn) ? ROD : BLAA;
    }

    /* Selve bokstavhuset: soner, fire linjer og hus-ikon med tak */
    function lagHus(svg: SVGElement, medFarger: boolean) {
      const { topp, xtopp, grunn, bunn } = LINJER;
      if (medFarger) {
        svg.appendChild(svgEl('rect', { x: String(START_X - 4), y: String(topp), width: String(VB_BREDDE - START_X + 2), height: String(xtopp - topp), fill: SONE_LOFT }));
        svg.appendChild(svgEl('rect', { x: String(START_X - 4), y: String(xtopp), width: String(VB_BREDDE - START_X + 2), height: String(grunn - xtopp), fill: SONE_STUE }));
        svg.appendChild(svgEl('rect', { x: String(START_X - 4), y: String(grunn), width: String(VB_BREDDE - START_X + 2), height: String(bunn - grunn), fill: SONE_KJELLER }));
      }
      const linje = (y: number, farge: string, stiplet: boolean, tykkelse = 0.55) =>
        svg.appendChild(
          svgEl('line', {
            x1: String(START_X - 4), y1: String(y), x2: String(VB_BREDDE - 2), y2: String(y),
            stroke: farge, 'stroke-width': String(tykkelse),
            ...(stiplet ? { 'stroke-dasharray': '3 2.4' } : {}),
          })
        );
      linje(topp, '#b9b9b9', true);
      linje(xtopp, '#b9b9b9', true);
      linje(grunn, '#555', false, 0.8);
      linje(bunn, '#cfcfcf', false, 0.45);

      // hus-ikonet: vegg over stua + tak over loftet (jf. bokstavhus-arkene)
      svg.appendChild(svgEl('path', { d: `M 2 ${topp} L 10 ${topp - 2.6} L 18 ${topp}`, fill: 'none', stroke: '#777', 'stroke-width': '0.9' }));
      svg.appendChild(svgEl('rect', { x: '4', y: String(topp), width: '12', height: String(bunn - topp), fill: 'none', stroke: '#999', 'stroke-width': '0.6' }));
      svg.appendChild(svgEl('line', { x1: '4', y1: String(xtopp), x2: '16', y2: String(xtopp), stroke: '#bbb', 'stroke-width': '0.5' }));
      svg.appendChild(svgEl('line', { x1: '4', y1: String(grunn), x2: '16', y2: String(grunn), stroke: '#bbb', 'stroke-width': '0.5' }));
    }

    /* Én instans av teksten (modell eller spore). Returnerer paths som
       skal dekoreres (kun modell). */
    function leggTekst(
      svg: SVGElement,
      tekst: string,
      x0: number,
      modell: boolean,
      fargevalg: string
    ): { bredde: number; dekor: { path: SVGPathElement; farge: string; nummer: number | null }[] } {
      let x = x0;
      const dekor: { path: SVGPathElement; farge: string; nummer: number | null }[] = [];
      for (const tegn of tekst) {
        const b = bane(tegn);
        if (!b) continue;
        const farge = modell ? tegnFor(tegn, fargevalg) : SPOR;
        const synligeStrok = b.strok.filter((s) => !s.prikk);
        const flereStrok = synligeStrok.length > 1;
        let strokNr = 0;
        b.strok.forEach((strok) => {
          const g = svgEl('g', { transform: `translate(${x} 0)` });
          if (strok.prikk) {
            // i/j-prikken: fylt punkt (stiplet-grå på sporeversjonen)
            const m = strok.d.match(/M\s*([\d.]+)\s+([\d.]+)/);
            if (m) {
              g.appendChild(
                svgEl('circle', {
                  cx: m[1], cy: m[2], r: '1.7',
                  fill: modell ? farge : SPOR,
                })
              );
            }
            svg.appendChild(g);
            return;
          }
          strokNr++;
          const path = svgEl('path', {
            d: strok.d,
            fill: 'none',
            stroke: farge,
            'stroke-width': modell ? '2.3' : '2.1',
            'stroke-linecap': 'round',
            'stroke-linejoin': 'round',
            ...(modell ? {} : { 'stroke-dasharray': '3 2.6' }),
          }) as SVGPathElement;
          if (modell) {
            path.setAttribute('class', 'sp-modell-strok');
            dekor.push({ path, farge, nummer: flereStrok ? strokNr : null });
          } else {
            path.setAttribute('class', 'sp-spor-strok');
          }
          g.appendChild(path);
          svg.appendChild(g);
        });
        x += b.bredde;
      }
      return { bredde: x - x0, dekor };
    }

    /* Startprikk, strøknummer og pilspiss — leses ut av banen selv */
    function dekorer(svg: SVGElement, dekor: { path: SVGPathElement; farge: string; nummer: number | null }[]) {
      dekor.forEach(({ path, farge, nummer }) => {
        const g = path.parentElement as unknown as SVGGElement;
        const lengde = path.getTotalLength();
        const start = path.getPointAtLength(0);
        g.appendChild(svgEl('circle', { cx: String(start.x), cy: String(start.y), r: '1.8', fill: GRONN }));
        if (nummer !== null) {
          g.appendChild(
            svgEl('text', {
              x: String(start.x + 3), y: String(start.y - 2.2),
              'font-size': '4.6', 'font-weight': '700', fill: GRONN,
            }, String(nummer))
          );
        }
        // pilspiss ved ~57 % av strøket, rotert etter tangenten
        if (lengde > 9) {
          const a = path.getPointAtLength(lengde * 0.55);
          const b = path.getPointAtLength(Math.min(lengde, lengde * 0.55 + 1.4));
          const vinkel = (Math.atan2(b.y - a.y, b.x - a.x) * 180) / Math.PI;
          g.appendChild(
            svgEl('path', {
              d: 'M 0 0 L -3.4 -1.9 L -3.4 1.9 Z',
              fill: PIL,
              transform: `translate(${b.x} ${b.y}) rotate(${vinkel})`,
              class: 'sp-pil',
            })
          );
        }
        void farge;
      });
    }

    function siStatus(tekst: string, erFeil = false) {
      const status = el('sp-status');
      status.textContent = tekst;
      status.classList.toggle('feil', erFeil);
    }

    function generer() {
      const rene = rader.map((r) => r.tekst.trim()).filter(Boolean);
      if (rene.length === 0) {
        siStatus(M.minstEn, true);
        return;
      }
      for (const tekst of rene) {
        if (ordErUpassende(tekst)) {
          siStatus(M.upassende(tekst), true);
          return;
        }
        for (const tegn of tekst) {
          if (!bane(tegn)) {
            siStatus(M.ukjentTegn(tegn, tekst), true);
            return;
          }
        }
      }

      const fargevalg = el<HTMLSelectElement>('sp-farge').value;
      const medFarger = el<HTMLInputElement>('sp-husfarger').checked;
      const tomLinje = el<HTMLInputElement>('sp-tom-linje').checked;

      el('sp-overskrift').textContent =
        el<HTMLInputElement>('sp-tittel').value.trim() || standardTittel;

      const beholder = el('sp-rader');
      beholder.setAttribute('data-storrelse', el<HTMLSelectElement>('sp-storrelse').value);
      beholder.replaceChildren();

      const alleDekor: { svg: SVGElement; dekor: { path: SVGPathElement; farge: string; nummer: number | null }[] }[] = [];

      rene.forEach((tekst) => {
        const rad = document.createElement('div');
        rad.className = 'sp-rad';
        rad.setAttribute('aria-label', tekst);
        const svg = svgEl('svg', { viewBox: `-1 -3 ${VB_BREDDE + 2} ${VB_HOYDE + 3}`, 'aria-hidden': 'true' });
        lagHus(svg, medFarger);

        const instansBredde = [...tekst].reduce((sum, tegn) => sum + (bane(tegn)?.bredde ?? 0), 0);
        const { dekor } = leggTekst(svg, tekst, START_X, true, fargevalg);
        let x = START_X + instansBredde + GAP + 3;
        while (x + instansBredde <= VB_BREDDE - 4) {
          leggTekst(svg, tekst, x, false, fargevalg);
          x += instansBredde + GAP;
        }

        rad.appendChild(svg);
        beholder.appendChild(rad);
        alleDekor.push({ svg, dekor });

        if (tomLinje) {
          const tom = document.createElement('div');
          tom.className = 'sp-rad';
          const tomSvg = svgEl('svg', { viewBox: `-1 -3 ${VB_BREDDE + 2} ${VB_HOYDE + 3}`, 'aria-hidden': 'true' });
          lagHus(tomSvg, medFarger);
          tom.appendChild(tomSvg);
          beholder.appendChild(tom);
        }
      });

      el('sp-ark-seksjon').removeAttribute('hidden');
      // dekoreringen måler pathene — gjøres etter at de står i DOM
      alleDekor.forEach(({ svg, dekor }) => dekorer(svg, dekor));

      siStatus(M.klart(rene.length));
      lagreUtkast();
    }

    if (!lastUtkast()) {
      leggTil('a');
      leggTil('s');
      leggTil('sol');
    }
    tegnListe();

    el('sp-legg-til').addEventListener('click', () => {
      leggTil();
      lagreUtkast();
    });

    el('sp-lag').addEventListener('click', generer);

    const skrivUt = () => window.print();
    el('sp-skriv-ut').addEventListener('click', skrivUt);
    el('sp-skriv-ut-sticky').addEventListener('click', skrivUt);

    ['sp-tittel', 'sp-storrelse', 'sp-farge', 'sp-husfarger', 'sp-tom-linje'].forEach((id) =>
      el(id).addEventListener('change', lagreUtkast)
    );
  }
</script>
