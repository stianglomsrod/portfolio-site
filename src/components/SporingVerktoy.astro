---
/* Sporing-verktøyet v2: ekte norsk skriftforming (se
   docs/innsikt/SPORING-DESIGN.md). Hver rad er et BOKSTAVHUS: fire
   linjer med loft/stue/kjeller (valgfrie sonefarger gul/rosa/blå) og
   hus-ikon med tak til venstre. Modellbokstaven tegnes med solid strek
   (vokal rød / konsonant blå, valgfritt sort), grønn startprikk per
   strøk, strøknummer når det er flere, og pilspiss langs strøket —
   posisjon og vinkel leses ut av skjelettbanene i
   src/lib/bokstavbaner.ts med getPointAtLength. Deretter følger
   stiplede sporebokstaver, og valgfri tom øvelinje under (mønsteret fra
   Kaleido skriftforming: modellrad → tom rad). */

interface Props {
  lang?: 'nb' | 'en';
}

const { lang = 'nb' } = Astro.props;

const t =
  lang === 'nb'
    ? {
        tittelFelt: 'Tittel på arket',
        tittelEks: 'Skriv tittelen her',
        radNavn: 'Bokstaver eller ord (én per rad)',
        radEks: 'f.eks. a eller sol',
        leggTil: '+ Legg til rad',
        hint: 'Én bokstav per rad gir full skriftforming med startpunkt, tall og piler. Et ord gir sporing av hele ordet.',
        storrelse: 'Størrelse',
        storrelseStor: 'stor (1.–2. trinn)',
        storrelseMiddels: 'middels',
        husfarger: 'Farger i bokstavhuset (loft, stue, kjeller)',
        tomLinje: 'Tom øvelinje under hver rad',
        lag: 'Lag sporingsark',
        skrivUt: 'Skriv ut',
        navnLinje: 'Navn: ____________________   Dato: ____________',
        instruks: 'Start på den grønne prikken og følg pilene. Spor bokstavene så pent du kan.',
        standardTittel: 'Sporing',
      }
    : {
        tittelFelt: 'Sheet title',
        tittelEks: 'Type the title here',
        radNavn: 'Letters or words (one per row)',
        radEks: 'e.g. a or sun',
        leggTil: '+ Add row',
        hint: 'A single letter per row gives full letter formation with starting point, numbers and arrows. A word gives tracing of the whole word.',
        storrelse: 'Size',
        storrelseStor: 'large (early years)',
        storrelseMiddels: 'medium',
        husfarger: 'Colours in the letter house (attic, living room, basement)',
        tomLinje: 'Empty practice line under each row',
        lag: 'Create tracing sheet',
        skrivUt: 'Print',
        navnLinje: 'Name: ____________________   Date: ____________',
        instruks: 'Start at the green dot and follow the arrows. Trace the letters as neatly as you can.',
        standardTittel: 'Tracing',
      };
---

<div class="sp-verktoy" data-lang={lang} data-standardtittel={t.standardTittel}>
  <div class="sp-oppsett">
    <section class="sp-panel" aria-labelledby="sp-panel-tittel">
      <h2 id="sp-panel-tittel" class="sr-only">{lang === 'nb' ? 'Oppsett' : 'Setup'}</h2>

      <label class="sp-felt">
        <span class="sp-felt-navn">{t.tittelFelt}</span>
        <input type="text" id="sp-tittel" placeholder={t.tittelEks} maxlength="60" />
      </label>

      <div class="sp-felt">
        <span class="sp-felt-navn" id="sp-rad-navn">{t.radNavn}</span>
        <ul id="sp-liste" aria-labelledby="sp-rad-navn"></ul>
        <button type="button" id="sp-legg-til" class="sp-sekundaer">{t.leggTil}</button>
        <p class="sp-hint">{t.hint}</p>
      </div>

      <label class="sp-felt">
        <span class="sp-felt-navn">{t.storrelse}</span>
        <select id="sp-storrelse">
          <option value="stor" selected>{t.storrelseStor}</option>
          <option value="middels">{t.storrelseMiddels}</option>
        </select>
      </label>

      <label class="sp-valg">
        <input type="checkbox" id="sp-husfarger" checked />
        {t.husfarger}
      </label>

      <label class="sp-valg">
        <input type="checkbox" id="sp-tom-linje" checked />
        {t.tomLinje}
      </label>

      <button type="button" id="sp-lag" class="knapp sp-primaer">{t.lag}</button>
      <p id="sp-status" class="sp-status" role="status" aria-live="polite"></p>
    </section>

    <section class="sp-visning" id="sp-ark-seksjon" hidden aria-labelledby="sp-visning-tittel">
      <h2 id="sp-visning-tittel" class="sr-only">
        {lang === 'nb' ? 'Forhåndsvisning' : 'Preview'}
      </h2>
      <div class="sp-handlinger">
        <button type="button" id="sp-skriv-ut" class="knapp sp-primaer">{t.skrivUt}</button>
      </div>

      <div class="sp-sticky-print">
        <button type="button" id="sp-skriv-ut-sticky" class="sp-sticky-knapp" title="Skriv ut arket (Ctrl+P)" aria-label={t.skrivUt}>
          🖨
        </button>
      </div>

      <div class="sp-ark" id="sp-ark">
        <h3 id="sp-overskrift">{t.standardTittel}</h3>
        <p class="sp-instruks">{t.instruks}</p>
        <p class="sp-navn-linje">{t.navnLinje}</p>
        <div id="sp-rader" class="sp-rader"></div>
      </div>
    </section>
  </div>
</div>

<style is:global>
  .sp-oppsett {
    display: grid;
    grid-template-columns: 360px 1fr;
    gap: var(--s-5);
    align-items: start;
    margin-top: var(--s-4);
  }

  @media (max-width: 900px) {
    .sp-oppsett {
      grid-template-columns: 1fr;
    }
  }

  .sp-panel {
    background: var(--flate);
    border: 1px solid var(--linje);
    border-radius: var(--radius-md);
    box-shadow: var(--kort-skygge);
    padding: var(--s-4);
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
  }

  .sp-felt {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin: 0;
    min-width: 0;
  }

  .sp-felt-navn {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: 14px;
    color: var(--tekst);
  }

  .sp-panel input[type='text'],
  .sp-panel select {
    font-family: var(--font-sans);
    font-size: 16px;
    padding: 9px 10px;
    border: 1px solid var(--linje);
    border-radius: var(--radius-sm);
    background: var(--bg);
    color: var(--tekst);
    min-height: 44px;
    width: 100%;
    box-sizing: border-box;
  }

  .sp-valg {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    min-height: 32px;
    color: var(--tekst);
  }

  .sp-valg input {
    width: 19px;
    height: 19px;
    accent-color: var(--salvie);
    flex-shrink: 0;
  }

  @media (pointer: coarse) {
    .sp-valg {
      min-height: 44px;
    }
  }

  .sp-hint {
    margin: 2px 0 0;
    font-size: 13.5px;
    color: var(--dempet);
  }

  #sp-liste {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .sp-rad-inn {
    display: flex;
    gap: 6px;
    align-items: center;
  }

  .sp-rad-inn input[type='text'] {
    flex: 1;
    min-width: 0;
  }

  .sp-rad-inn.upassende input[type='text'] {
    border-color: var(--feil);
  }

  .sp-ikonknapp {
    font: inherit;
    min-width: 44px;
    min-height: 44px;
    border: 1px solid var(--linje);
    border-radius: var(--radius-sm);
    background: var(--bg);
    color: var(--tekst);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .sp-ikonknapp:hover {
    border-color: var(--salvie);
  }

  .sp-primaer {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 700;
    background: var(--salvie);
    color: var(--salvie-kontrast);
    border: none;
    border-radius: 9px;
    padding: 11px 20px;
    min-height: 44px;
    cursor: pointer;
  }

  .sp-primaer:hover {
    filter: brightness(1.06);
  }

  .sp-sekundaer {
    font-family: var(--font-sans);
    font-size: 14.5px;
    font-weight: 600;
    background: var(--bg);
    color: var(--tekst);
    border: 1px solid var(--linje);
    border-radius: 9px;
    padding: 10px 16px;
    min-height: 44px;
    cursor: pointer;
  }

  .sp-sekundaer:hover {
    border-color: var(--salvie);
  }

  .sp-sekundaer:disabled {
    opacity: 0.5;
    cursor: default;
  }

  .sp-status {
    margin: 0;
    font-size: 14.5px;
    color: var(--dempet);
    min-height: 1.4em;
  }

  .sp-status.feil {
    color: var(--feil);
  }

  .sp-handlinger {
    display: flex;
    gap: var(--s-3);
    flex-wrap: wrap;
    margin-bottom: var(--s-3);
  }

  .sp-sticky-print {
    position: fixed;
    right: 24px;
    bottom: 24px;
    z-index: 15;
  }

  .sp-sticky-knapp {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    border: 1px solid var(--linje);
    background: var(--salvie);
    color: var(--salvie-kontrast);
    font-size: 22px;
    cursor: pointer;
    box-shadow: var(--kort-skygge);
    display: grid;
    place-items: center;
  }

  .sp-ark {
    background: #fff;
    color: #111;
    border: 1px solid var(--linje);
    border-radius: var(--radius-md);
    box-shadow: var(--kort-skygge);
    padding: 28px 32px;
    max-width: 660px;
  }

  #sp-overskrift {
    margin: 0 0 4px;
    font-size: 24px;
    color: #111;
  }

  .sp-instruks {
    margin: 0 0 6px;
    font-size: 14.5px;
    color: #333;
  }

  .sp-navn-linje {
    margin: 0 0 18px;
    font-size: 13.5px;
    color: #333;
  }

  .sp-rader {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .sp-rad svg {
    display: block;
    width: 100%;
    height: auto;
  }

  @media print {
    @page {
      margin: 14mm;
    }

    html,
    body {
      color-scheme: light;
      background: #fff !important;
      color: #000;
    }

    .topp,
    .bunn,
    .hopp,
    .sp-panel,
    .sp-handlinger,
    .sp-side-hode,
    .sp-sticky-print {
      display: none !important;
    }

    .ramme {
      padding: 0;
      max-width: none;
      min-height: 0;
      background: #fff;
    }

    .sp-oppsett {
      display: block;
      margin: 0;
    }

    .sp-ark {
      border: none;
      box-shadow: none;
      border-radius: 0;
      padding: 0;
      max-width: none;
    }

    .sp-rader {
      gap: 3.5mm;
    }

    .sp-rad {
      break-inside: avoid;
    }

    #sp-overskrift {
      font-size: 19px;
      margin: 0 0 2px;
    }

    .sp-instruks {
      font-size: 13px;
      margin: 0 0 3px;
    }

    .sp-navn-linje {
      margin: 0 0 10px;
    }

    .sp-rad svg {
      print-color-adjust: exact;
      -webkit-print-color-adjust: exact;
    }
  }
</style>

<script>
  import { ordErUpassende } from '../lib/ordkryss-kjerne';
  import { LINJER, bane } from '../lib/bokstavbaner';

  const rot = document.querySelector<HTMLElement>('.sp-verktoy');
  if (rot) {
    const lang = (rot.dataset.lang ?? 'nb') as 'nb' | 'en';
    const standardTittel = rot.dataset.standardtittel ?? 'Sporing';
    const LAGRINGSNOKKEL = `sporing-${lang}`;
    const MAKS = 6; // færre rader = større bokstaver (Salto-størrelse på A4)
    const NS = 'http://www.w3.org/2000/svg';

    // fargene fra designgrunnlaget (v3, docs/innsikt/SPORING-DESIGN.md):
    // bokstavstrekene er nøytralt sorte, veiledningen bærer fargen. Piler og
    // tall ligger UTENFOR bokstavformen (Salto-konvensjonen) i rolig mørk
    // skifer; grønt startpunkt er eneste sterke farge.
    const SONE_LOFT = '#FFF3C6';
    const SONE_STUE = '#FBE3EF';
    const SONE_KJELLER = '#DDEFF8';
    const SORT = '#222';
    const GRONN = '#1a8a3a';
    const SPOR = '#b8b8b8';
    const PIL = '#3b4a59';

    /* smalere viewBox → fysisk større bokstaver på arket. «stor» gir
       x-høyde ≈ 8,7 mm på A4 (Salto-klassen); «middels» som før. */
    const VB_STOR = 250;
    const VB_MIDDELS = 340;
    const VB_HOYDE = 44;
    const START_X = 40; // etter hus-ikonet
    const GAP = 7;

    const M =
      lang === 'nb'
        ? {
            minstEn: 'Skriv inn minst én bokstav eller ett ord.',
            upassende: (o: string) =>
              `«${o}» passer ikke på et skoleark. Bytt det ut, så lager vi arket.`,
            ukjentTegn: (tegn: string, rad: string) =>
              `«${tegn}» i «${rad}» har ingen sporingsbane ennå — bruk bokstavene a–å og A–Å.`,
            klart: (n: number) => `Arket er klart: ${n} rader.`,
            radAria: (i: number) => `Rad ${i}`,
            fjern: (i: number) => `Fjern rad ${i}`,
            radEks: 'f.eks. a eller sol',
          }
        : {
            minstEn: 'Type at least one letter or word.',
            upassende: (o: string) =>
              `“${o}” does not belong on a school sheet. Swap it and we will make the sheet.`,
            ukjentTegn: (tegn: string, rad: string) =>
              `“${tegn}” in “${rad}” has no tracing path yet — use the letters a–å and A–Å.`,
            klart: (n: number) => `The sheet is ready: ${n} rows.`,
            radAria: (i: number) => `Row ${i}`,
            fjern: (i: number) => `Remove row ${i}`,
            radEks: 'e.g. a or sun',
          };

    interface Rad {
      id: number;
      tekst: string;
    }

    let rader: Rad[] = [];
    let nesteId = 1;

    const el = <T extends HTMLElement = HTMLElement>(id: string): T =>
      document.getElementById(id) as T;

    function lagreUtkast() {
      try {
        localStorage.setItem(
          LAGRINGSNOKKEL,
          JSON.stringify({
            tittel: el<HTMLInputElement>('sp-tittel').value,
            storrelse: el<HTMLSelectElement>('sp-storrelse').value,
            husfarger: el<HTMLInputElement>('sp-husfarger').checked,
            tomLinje: el<HTMLInputElement>('sp-tom-linje').checked,
            rader: rader.map((r) => r.tekst),
          })
        );
      } catch {}
    }

    function lastUtkast(): boolean {
      try {
        const raa = localStorage.getItem(LAGRINGSNOKKEL);
        if (!raa) return false;
        const u = JSON.parse(raa);
        el<HTMLInputElement>('sp-tittel').value = u.tittel ?? '';
        const storrelse = el<HTMLSelectElement>('sp-storrelse');
        if ([...storrelse.options].some((o) => o.value === u.storrelse)) storrelse.value = u.storrelse;
        el<HTMLInputElement>('sp-husfarger').checked = u.husfarger !== false;
        el<HTMLInputElement>('sp-tom-linje').checked = u.tomLinje !== false;
        (u.rader ?? []).forEach((r: unknown) => {
          if (typeof r === 'string') rader.push({ id: nesteId++, tekst: r });
        });
        return rader.length > 0;
      } catch {
        return false;
      }
    }

    function leggTil(tekst = '') {
      if (rader.length >= MAKS) return;
      rader.push({ id: nesteId++, tekst });
      tegnListe();
    }

    function tegnListe() {
      const liste = el('sp-liste');
      liste.replaceChildren();
      rader.forEach((rad, indeks) => {
        const li = document.createElement('li');
        li.className = 'sp-rad-inn';
        const felt = document.createElement('input');
        felt.type = 'text';
        felt.value = rad.tekst.slice(0, 12);
        felt.maxLength = 12;
        felt.placeholder = M.radEks;
        felt.setAttribute('aria-label', M.radAria(indeks + 1));
        felt.addEventListener('input', () => {
          rad.tekst = felt.value;
          const stygt = ordErUpassende(felt.value);
          li.classList.toggle('upassende', stygt);
          felt.setAttribute('aria-invalid', stygt ? 'true' : 'false');
          lagreUtkast();
        });
        const fjern = document.createElement('button');
        fjern.type = 'button';
        fjern.className = 'sp-ikonknapp';
        fjern.textContent = '✕';
        fjern.setAttribute('aria-label', M.fjern(indeks + 1));
        fjern.addEventListener('click', () => {
          rader = rader.filter((r) => r.id !== rad.id);
          if (rader.length === 0) leggTil();
          tegnListe();
          lagreUtkast();
        });
        li.append(felt, fjern);
        liste.appendChild(li);
      });
      el<HTMLButtonElement>('sp-legg-til').disabled = rader.length >= MAKS;
    }

    function svgEl(navn: string, attrs: Record<string, string>, tekst?: string) {
      const e = document.createElementNS(NS, navn);
      for (const [k, v] of Object.entries(attrs)) e.setAttribute(k, v);
      if (tekst !== undefined) e.textContent = tekst;
      return e;
    }

    /* Selve bokstavhuset: soner, fire linjer og hus-ikon med tak */
    function lagHus(svg: SVGElement, medFarger: boolean, vbBredde: number) {
      const { topp, xtopp, grunn, bunn } = LINJER;
      if (medFarger) {
        svg.appendChild(svgEl('rect', { x: String(START_X - 4), y: String(topp), width: String(vbBredde - START_X + 2), height: String(xtopp - topp), fill: SONE_LOFT }));
        svg.appendChild(svgEl('rect', { x: String(START_X - 4), y: String(xtopp), width: String(vbBredde - START_X + 2), height: String(grunn - xtopp), fill: SONE_STUE }));
        svg.appendChild(svgEl('rect', { x: String(START_X - 4), y: String(grunn), width: String(vbBredde - START_X + 2), height: String(bunn - grunn), fill: SONE_KJELLER }));
      }
      const linje = (y: number, farge: string, stiplet: boolean, tykkelse = 0.55) =>
        svg.appendChild(
          svgEl('line', {
            x1: String(START_X - 4), y1: String(y), x2: String(vbBredde - 2), y2: String(y),
            stroke: farge, 'stroke-width': String(tykkelse),
            ...(stiplet ? { 'stroke-dasharray': '3 2.4' } : {}),
          })
        );
      linje(topp, '#c4c4c4', true);
      linje(xtopp, '#c4c4c4', true);
      linje(grunn, '#666', false, 0.8);
      linje(bunn, '#d2d2d2', false, 0.45);

      // hus-ikonet: bred vegg med tak over loftet (jf. bokstavhus-arkene)
      svg.appendChild(svgEl('path', { d: `M 0.5 ${topp} L 16.5 ${topp - 3.8} L 32.5 ${topp}`, fill: 'none', stroke: '#777', 'stroke-width': '1' }));
      svg.appendChild(svgEl('rect', { x: '3', y: String(topp), width: '27', height: String(bunn - topp), fill: 'none', stroke: '#999', 'stroke-width': '0.6' }));
      svg.appendChild(svgEl('line', { x1: '3', y1: String(xtopp), x2: '30', y2: String(xtopp), stroke: '#bbb', 'stroke-width': '0.5' }));
      svg.appendChild(svgEl('line', { x1: '3', y1: String(grunn), x2: '30', y2: String(grunn), stroke: '#bbb', 'stroke-width': '0.5' }));
    }

    type Nivaa = 'modell' | 'lett' | 'ren';

    interface Punkt { x: number; y: number }

    interface Jobb {
      g: SVGGElement;
      path: SVGPathElement;
      tegn: string;
      strokIdx: number;
      /** unik per bokstavinstans — luft-regelen måler mot hele bokstaven */
      gruppeId: number;
      /** strøknummer når bokstaven har 3+ strøk (Salto-ro), ellers null */
      nummer: number | null;
      /** strøk 1 (får grønn startprikk) */
      forste: boolean;
      nivaa: Nivaa;
      /** bokstavinstansens x-forskyvning — blekk-skyen deles på tvers av
          ordet og maales i rad-koordinater */
      offX: number;
      egneIdx?: Set<number>;
      /** sample-t (banelengde) per egen indeks — brukes til å telle egen
          strek NEDSTRØMS for pilen som hinder (e-løkka skal stoppe pilen) */
      egneT?: Map<number, number>;
    }

    /* v4-veiledningsmotor (se docs/innsikt/sporing/FORMPROFIL-V4.md):
       pilen er en TYNN OFFSET-PARALLELL av strøkets første del — samplet
       langs banen og forskjøvet ut langs normalen — slik at pilens krumning
       alltid følger strøkets (Kaleido/Salto-fasit). Siden velges med
       LUFT-regelen; er begge sider trange, brukes en INNLEDNINGSPIL i lufta
       før strøkstart (Salto-mønsteret for tverrstreker). Tall + liten prikk
       ved pilens hale. */

    /** Per-strøk overstyring: 'tegn:strokIdx' → 1/-1 (side) eller 0 (lead-in) */
    const SIDE_HINT: Record<string, number> = {};

    /* Hvor langt langs strøket kan pilen følge før første skarpe hjørne? */
    function hjornekutt(path: SVGPathElement, L: number, maks: number): number {
      const steg = 0.9;
      let prev: Punkt | null = null;
      for (let t = 0.4; t <= maks; t += steg) {
        const p = path.getPointAtLength(t);
        const p2 = path.getPointAtLength(Math.min(L, t + 0.7));
        let tx = p2.x - p.x, ty = p2.y - p.y;
        const tl = Math.hypot(tx, ty) || 1;
        tx /= tl; ty /= tl;
        if (prev) {
          if (tx * prev.x + ty * prev.y < 0.64) return Math.max(3.4, t - steg);
        }
        prev = { x: tx, y: ty };
      }
      return maks;
    }

    function offsetPilBane(path: SVGPathElement, L: number, side: number): Punkt[] {
      const frac = hjornekutt(path, L, Math.max(4, Math.min(0.32 * L, 10)));
      const gap = 3.4;
      const n = 9;
      const pts: Punkt[] = [];
      for (let i = 0; i <= n; i++) {
        const t = (frac * i) / n;
        const p = path.getPointAtLength(t);
        const p2 = path.getPointAtLength(Math.min(L, t + 0.7));
        let tx = p2.x - p.x, ty = p2.y - p.y;
        const tl = Math.hypot(tx, ty) || 1;
        tx /= tl; ty /= tl;
        pts.push({ x: p.x + -ty * gap * side, y: p.y + tx * gap * side });
      }
      return pts;
    }

    /* Innledningspil: i lufta FØR strøkstart, hodet peker inn mot starten.
       Lengden krymper hvis halen ellers treffer annet blekk (ord-modus). */
    function leadInBane(path: SVGPathElement, L: number, minDistAnnen: (p: Punkt) => number): Punkt[] {
      const p0 = path.getPointAtLength(0);
      const p2 = path.getPointAtLength(Math.min(L, 1.2));
      let tx = p2.x - p0.x, ty = p2.y - p0.y;
      const tl = Math.hypot(tx, ty) || 1;
      tx /= tl; ty /= tl;
      let lengde = 6.6;
      const prov = { x: p0.x - tx * lengde, y: p0.y - ty * lengde };
      if (minDistAnnen(prov) < 2) lengde = 4.4;
      const hode = { x: p0.x - tx * 2.1, y: p0.y - ty * 2.1 };
      const hale = { x: p0.x - tx * lengde, y: p0.y - ty * lengde };
      return [hale, { x: (hale.x + hode.x) / 2, y: (hale.y + hode.y) / 2 }, hode];
    }

    /* Samlet sving (radianer, fortegn) over pilens spenn — avgjør om strøket
       er buet, og hvilken side som er konveks. */
    function samletSving(path: SVGPathElement, L: number, frac: number): number {
      let sum = 0;
      let prev: Punkt | null = null;
      const n = 6;
      for (let i = 0; i <= n; i++) {
        const t = (frac * i) / n;
        const p = path.getPointAtLength(t);
        const p2 = path.getPointAtLength(Math.min(L, t + 0.7));
        let tx = p2.x - p.x, ty = p2.y - p.y;
        const tl = Math.hypot(tx, ty) || 1;
        tx /= tl; ty /= tl;
        if (prev) sum += Math.asin(Math.max(-1, Math.min(1, prev.x * ty - prev.y * tx)));
        prev = { x: tx, y: ty };
      }
      return sum;
    }

    function velgPolylinje(
      path: SVGPathElement,
      L: number,
      inkSamples: Punkt[],
      egneIdx: Set<number>,
      egneT: Map<number, number>,
      offX: number,
      hintKey: string
    ): Punkt[] {
      const fracEks = hjornekutt(path, L, Math.max(4, Math.min(0.32 * L, 10))) + 3;
      const minDistAnnen = (p: Punkt) => {
        let m = 99;
        for (let i = 0; i < inkSamples.length; i++) {
          // egen strek INNENFOR pilens spenn gir konstant gap og ignoreres;
          // egen strek NEDSTRØMS (f.eks. e-løkka) er et reelt hinder
          if (egneIdx.has(i) && (egneT.get(i) ?? 0) <= fracEks) continue;
          const q = inkSamples[i];
          const d = Math.hypot(p.x + offX - q.x, p.y - q.y);
          if (d < m) m = d;
        }
        return m;
      };
      const luft = (pts: Punkt[]) => {
        let sum = 0;
        for (const p of pts) sum += Math.min(6, minDistAnnen(p));
        return sum / pts.length;
      };
      /* trim haleenden av pilen der den nærmer seg annet blekk (f.eks.
         d-bollens bue som ellers ville truffet staven) */
      const trim = (pts: Punkt[]) => {
        let n = pts.length;
        while (n > 4 && minDistAnnen(pts[n - 1]) < 2) n--;
        return pts.slice(0, n);
      };
      const hint = SIDE_HINT[hintKey];
      if (hint !== undefined) {
        return hint === 0 ? leadInBane(path, L, minDistAnnen) : trim(offsetPilBane(path, L, hint));
      }
      const frac = hjornekutt(path, L, Math.max(4, Math.min(0.32 * L, 10)));
      const sving = samletSving(path, L, frac);
      if (Math.abs(sving) > 0.45) {
        // buet strøk: pilen ligger ALLTID på konveks side (utsiden av kurven) —
        // aldri inne i telehullet, uansett hvor «luftig» hullet er
        const side = sving > 0 ? -1 : 1;
        const pts = trim(offsetPilBane(path, L, side));
        if (luft(pts) < 2.2) return leadInBane(path, L, minDistAnnen);
        return pts;
      }
      const kand = [offsetPilBane(path, L, 1), offsetPilBane(path, L, -1)];
      const l0 = luft(kand[0]), l1 = luft(kand[1]);
      if (Math.max(l0, l1) < 3.1) return leadInBane(path, L, minDistAnnen);
      if (Math.abs(l0 - l1) < 0.3) {
        // like mye luft (frittstående stav/tverrstrek): foretrekk venstre/over
        const gj = (pts: Punkt[]) => pts.reduce((s, p) => s + p.x + p.y * 0.4, 0);
        return trim(gj(kand[0]) < gj(kand[1]) ? kand[0] : kand[1]);
      }
      return trim(l0 > l1 ? kand[0] : kand[1]);
    }

    interface TallPlan { g: SVGGElement; x: number; y: number; ux: number; uy: number; nummer: number }

    /* Tegner pil + haleprikk; tallet planlegges (returneres) slik at
       kolliderende tall kan nudges fra hverandre før de tegnes. */
    function tegnPil(job: Jobb, inkSamples: Punkt[]): TallPlan | null {
      const { g, path } = job;
      const L = path.getTotalLength();
      if (L < 3) return null;
      const pts = velgPolylinje(path, L, inkSamples, job.egneIdx!, job.egneT!, job.offX, `${job.tegn}:${job.strokIdx}`);
      const d = 'M ' + pts.map((p) => `${p.x.toFixed(2)} ${p.y.toFixed(2)}`).join(' L ');
      g.appendChild(
        svgEl('path', {
          d, fill: 'none', stroke: PIL, 'stroke-width': '0.55',
          'stroke-linecap': 'round', 'stroke-linejoin': 'round', class: 'sp-pil',
        })
      );
      const sist = pts[pts.length - 1], nest = pts[pts.length - 2];
      const vin = (Math.atan2(sist.y - nest.y, sist.x - nest.x) * 180) / Math.PI;
      g.appendChild(
        svgEl('path', {
          d: 'M 0 0 L -2.4 -1.25 L -2.4 1.25 Z', fill: PIL, class: 'sp-pil',
          transform: `translate(${sist.x.toFixed(2)} ${sist.y.toFixed(2)}) rotate(${vin.toFixed(1)})`,
        })
      );
      // hale: liten prikk + ev. tall (Kaleido: tallet står ved pilens hale)
      const hale = pts[0];
      g.appendChild(svgEl('circle', { cx: hale.x.toFixed(2), cy: hale.y.toFixed(2), r: '0.55', fill: PIL }));
      if (!job.nummer) return null;
      const dx = pts[1].x - hale.x, dy = pts[1].y - hale.y;
      const dl = Math.hypot(dx, dy) || 1;
      return {
        g,
        x: hale.x - (dx / dl) * 2.6,
        y: hale.y - (dy / dl) * 2.6,
        ux: -(dx / dl), uy: -(dy / dl),
        nummer: job.nummer,
      };
    }

    /* Tall som havner oppå hverandre (strøk med delt startpunkt: E, Å, m …)
       skyves parvis FRA hverandre før de tegnes (to runder tar kjedene). */
    function tegnTall(planer: TallPlan[]) {
      for (let runde = 0; runde < 2; runde++) {
        for (let i = 0; i < planer.length; i++) {
          for (let j = 0; j < i; j++) {
            const a = planer[i], b = planer[j];
            // gruppene deler koordinatsystem kun innen samme bokstav
            if (a.g.getAttribute('transform') !== b.g.getAttribute('transform')) continue;
            const dx = a.x - b.x, dy = a.y - b.y;
            const d = Math.hypot(dx, dy);
            if (d < 3.4) {
              const ux = d > 0.1 ? dx / d : a.ux;
              const uy = d > 0.1 ? dy / d : a.uy;
              const skyv = (3.4 - d) / 2 + 0.3;
              a.x += ux * skyv; a.y += uy * skyv;
              b.x -= ux * skyv; b.y -= uy * skyv;
            }
          }
        }
      }
      planer.forEach((p) => {
        p.g.appendChild(
          svgEl('text', {
            x: p.x.toFixed(2), y: (p.y + 1.2).toFixed(2),
            'font-size': '3.6', 'font-weight': '600', fill: PIL, 'text-anchor': 'middle',
          }, String(p.nummer))
        );
      });
    }

    /* Én instans av teksten. «modell» = solid m/ full veiledning utenfor,
       «lett» = stiplet m/ kun grønn startprikk (dus bro, de første øvingene),
       «ren» = bare stiplet. */
    let nesteGruppeId = 1;
    function leggTekst(
      svg: SVGElement,
      tekst: string,
      x0: number,
      nivaa: Nivaa
    ): { bredde: number; jobber: Jobb[] } {
      let x = x0;
      const modell = nivaa === 'modell';
      const jobber: Jobb[] = [];
      for (const tegn of tekst) {
        const b = bane(tegn);
        if (!b) continue;
        const gruppeId = nesteGruppeId++;
        const offX = x;
        const farge = modell ? SORT : SPOR;
        const synlige = b.strok.filter((s) => !s.prikk);
        const nummererer = synlige.length >= 3; // tall kun ved 3+ strøk
        let nr = 0;
        b.strok.forEach((strok, strokIdx) => {
          const g = svgEl('g', { transform: `translate(${x} 0)` }) as SVGGElement;
          if (strok.prikk) {
            const m = strok.d.match(/M\s*([\d.]+)\s+([\d.]+)/);
            if (m) {
              g.appendChild(svgEl('circle', { cx: m[1], cy: m[2], r: '1.35', fill: farge }));
            }
            svg.appendChild(g);
            return;
          }
          nr++;
          const path = svgEl('path', {
            d: strok.d,
            fill: 'none',
            stroke: farge,
            'stroke-width': modell ? '2.2' : '2',
            'stroke-linecap': 'round',
            'stroke-linejoin': 'round',
            ...(modell ? {} : { 'stroke-dasharray': '2.8 2.7' }),
          }) as SVGPathElement;
          path.setAttribute('class', modell ? 'sp-modell-strok' : 'sp-spor-strok');
          g.appendChild(path);
          svg.appendChild(g);
          jobber.push({
            g, path, tegn, strokIdx, gruppeId, offX,
            nummer: nummererer ? nr : null,
            forste: nr === 1,
            nivaa,
          });
        });
        x += b.bredde;
      }
      return { bredde: x - x0, jobber };
    }

    /* Tegner veiledningen etter at pathene står i DOM (getPointAtLength). */
    function dekorer(jobber: Jobb[]) {
      // blekk-punktsky i RAD-koordinater over hele modellsettet (hele ordet),
      // så veiledningen også unngår nabobokstavens blekk i ord-modus
      const inkSamples: Punkt[] = [];
      const modell = jobber.filter((j) => j.nivaa === 'modell');
      modell.forEach((j) => {
        const L = j.path.getTotalLength();
        const n = Math.max(6, Math.min(16, Math.round(L / 2.5)));
        const fra = inkSamples.length;
        j.egneT = new Map();
        for (let i = 0; i <= n; i++) {
          const t = (L * i) / n;
          const p = j.path.getPointAtLength(t);
          inkSamples.push({ x: p.x + j.offX, y: p.y });
          j.egneT.set(fra + i, t);
        }
        j.egneIdx = new Set(Array.from({ length: n + 1 }, (_, i) => fra + i));
      });
      // grønn startprikk med hvit halo (leselig også der streker krysser)
      const prikk = (j: Jobb, r: number) => {
        const p0 = j.path.getPointAtLength(0);
        j.g.appendChild(
          svgEl('circle', {
            cx: String(p0.x), cy: String(p0.y), r: String(r),
            fill: GRONN, stroke: '#fff', 'stroke-width': '0.4',
          })
        );
      };
      const tallPlaner: TallPlan[] = [];
      jobber.forEach((j) => {
        if (j.nivaa === 'ren') return;
        if (j.nivaa === 'modell') {
          const plan = tegnPil(j, inkSamples);
          if (plan) tallPlaner.push(plan);
          if (j.forste) prikk(j, 1.15);
        } else if (j.nivaa === 'lett' && j.forste) {
          prikk(j, 1.05);
        }
      });
      tegnTall(tallPlaner);
    }

    function siStatus(tekst: string, erFeil = false) {
      const status = el('sp-status');
      status.textContent = tekst;
      status.classList.toggle('feil', erFeil);
    }

    function generer() {
      const rene = rader.map((r) => r.tekst.trim()).filter(Boolean);
      if (rene.length === 0) {
        siStatus(M.minstEn, true);
        return;
      }
      for (const tekst of rene) {
        if (ordErUpassende(tekst)) {
          siStatus(M.upassende(tekst), true);
          return;
        }
        for (const tegn of tekst) {
          if (!bane(tegn)) {
            siStatus(M.ukjentTegn(tegn, tekst), true);
            return;
          }
        }
      }

      const medFarger = el<HTMLInputElement>('sp-husfarger').checked;
      const tomLinje = el<HTMLInputElement>('sp-tom-linje').checked;

      el('sp-overskrift').textContent =
        el<HTMLInputElement>('sp-tittel').value.trim() || standardTittel;

      const beholder = el('sp-rader');
      beholder.setAttribute('data-storrelse', el<HTMLSelectElement>('sp-storrelse').value);
      beholder.replaceChildren();

      const alleDekor: Jobb[][] = [];
      const vbBredde = el<HTMLSelectElement>('sp-storrelse').value === 'stor' ? VB_STOR : VB_MIDDELS;
      // viewBox-en får luft over loftet (y ned til -7,5) så piler og tall som
      // ligger UTENFOR bokstavene ikke klippes — og strammes i bunnen slik at
      // radene ikke sprenger A4-siden.
      const VIEWBOX = `-1 -7.5 ${vbBredde + 2} 49`;

      rene.forEach((tekst) => {
        const rad = document.createElement('div');
        rad.className = 'sp-rad';
        rad.setAttribute('aria-label', tekst);
        const svg = svgEl('svg', { viewBox: VIEWBOX, 'aria-hidden': 'true' });
        lagHus(svg, medFarger, vbBredde);

        const instansBredde = [...tekst].reduce((sum, tegn) => sum + (bane(tegn)?.bredde ?? 0), 0);
        const jobbListe = [...leggTekst(svg, tekst, START_X, 'modell').jobber];
        // de to første øvingene får dus bro (kun grønn startprikk), resten er
        // rene stiplede — og slutten av rada står tom til egenskriving
        const reserver = Math.max(instansBredde * 1.2, 24);
        let x = START_X + instansBredde + GAP + 3;
        let nr = 0;
        while (x + instansBredde <= vbBredde - 4 - reserver) {
          const nivaa = nr < 2 ? 'lett' : 'ren';
          jobbListe.push(...leggTekst(svg, tekst, x, nivaa).jobber);
          x += instansBredde + GAP;
          nr++;
        }

        rad.appendChild(svg);
        beholder.appendChild(rad);
        alleDekor.push(jobbListe);

        if (tomLinje) {
          const tom = document.createElement('div');
          tom.className = 'sp-rad';
          const tomSvg = svgEl('svg', { viewBox: VIEWBOX, 'aria-hidden': 'true' });
          lagHus(tomSvg, medFarger, vbBredde);
          tom.appendChild(tomSvg);
          beholder.appendChild(tom);
        }
      });

      el('sp-ark-seksjon').removeAttribute('hidden');
      // dekoreringen måler pathene — gjøres etter at de står i DOM
      alleDekor.forEach((jobber) => dekorer(jobber));

      siStatus(M.klart(rene.length));
      lagreUtkast();
    }

    if (!lastUtkast()) {
      leggTil('a');
      leggTil('s');
      leggTil('sol');
    }
    tegnListe();

    el('sp-legg-til').addEventListener('click', () => {
      leggTil();
      lagreUtkast();
    });

    el('sp-lag').addEventListener('click', generer);

    const skrivUt = () => window.print();
    el('sp-skriv-ut').addEventListener('click', skrivUt);
    el('sp-skriv-ut-sticky').addEventListener('click', skrivUt);

    ['sp-tittel', 'sp-storrelse', 'sp-husfarger', 'sp-tom-linje'].forEach((id) =>
      el(id).addEventListener('change', lagreUtkast)
    );
  }
</script>
