---
import '../styles/fonts.css';
import '../styles/tokens.css';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  lang?: 'nb' | 'en';
  /** Sti til samme side på det andre språket (for hreflang) */
  alternativ?: string;
}

const { title, description, noindex = false, lang = 'nb', alternativ } = Astro.props;
const side = 'https://stianglomsrod.no';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {alternativ && (
      <link
        rel="alternate"
        hreflang={lang === 'nb' ? 'en' : 'nb'}
        href={`${side}${alternativ}`}
      />
    )}
    {alternativ && (
      <link
        rel="alternate"
        hreflang={lang}
        href={`${side}${Astro.url.pathname}`}
      />
    )}
    <link
      rel="preload"
      href="/fonts/atkinson-hyperlegible-regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/hanken-grotesk-vf.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/anybody-stiglo.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <script is:inline>
      /* Tema og hue før first paint: manuelle valg i localStorage vinner,
         ellers følges prefers-color-scheme via CSS. Cookiefritt. Grunnfarge
         (hue) og aksent (hue2) fra sliderne i /sandbox følger deg på hele
         siden; aksenten følger grunnfargen til den er løsnet. */
      (() => {
        // JS-flagg før first paint: hamburgermenyen og scroll-avsløringen
        // finnes bare med JS — uten JS vises full meny og alt innhold.
        document.documentElement.classList.add('har-js');
        try {
          const t = localStorage.getItem('data-theme');
          if (t === 'light' || t === 'dark') {
            document.documentElement.dataset.theme = t;
          }
          const klamp = (v) => Math.min(360, Math.max(0, Math.round(Number(v)) || 0));
          const h = localStorage.getItem('hue');
          const h2 = localStorage.getItem('hue2');
          if (h !== null) {
            document.documentElement.style.setProperty('--hue', String(klamp(h)));
          }
          if (h2 !== null) {
            document.documentElement.style.setProperty('--hue2', String(klamp(h2)));
          } else if (h !== null) {
            document.documentElement.style.setProperty('--hue2', String(klamp(h)));
          }
        } catch {}
      })();
    </script>
  </head>
  <body>
    <slot />
    <script>
      import { startAvslor } from '../lib/avslor';
      startAvslor();
    </script>
  </body>
</html>

<style is:global>
  /* Border-box overalt: oppgitt bredde ER ytterkanten, uansett padding.
     Uten denne stakk padded blokker (readme, moduler) forbi naboene sine
     selv med lik max-width — kilden til alle «skjeve kanter»-feilene. */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    background: var(--bg);
    color: var(--tekst);
    font-family: var(--font-sans);
    font-size: var(--tekst-broed);
    line-height: 1.6;
  }

  h1,
  h2,
  h3,
  h4 {
    font-family: var(--font-hd);
    font-weight: 700;
    color: var(--overskrift);
  }

  ::selection {
    background: color-mix(in srgb, var(--salvie) 30%, transparent);
  }

  a {
    color: var(--salvie);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  :focus-visible {
    outline: 2px solid var(--salvie);
    outline-offset: 2px;
  }

  /* v3-label: Hanken 600 sperret — erstatter mono-labels overalt */
  .label {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--dempet);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
    border: 0;
  }

  /* Scroll-avsløring (styres av src/lib/avslor.ts): kun opacity/transform,
     aldri layout. Klassene finnes bare med JS, og aldri ved
     prefers-reduced-motion. Utskrift viser alltid alt. */
  .avslor {
    opacity: 0;
    transform: translateY(16px);
  }

  .avslor.vist {
    opacity: 1;
    transform: none;
    transition:
      opacity 480ms var(--ease),
      transform 480ms var(--ease);
  }

  @media print {
    .avslor {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>
