---
import '../styles/fonts.css';
import '../styles/tokens.css';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
}

const { title, description, noindex = false } = Astro.props;
---

<!doctype html>
<html lang="nb">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link
      rel="preload"
      href="/fonts/atkinson-hyperlegible-regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/hanken-grotesk-vf.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/anybody-stiglo.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <script is:inline>
      /* Tema og hue før first paint: manuelle valg i localStorage vinner,
         ellers følges prefers-color-scheme via CSS. Cookiefritt. Hue-verdien
         (fra slideren i /sandbox) følger deg på hele siden. */
      (() => {
        try {
          const t = localStorage.getItem('data-theme');
          if (t === 'light' || t === 'dark') {
            document.documentElement.dataset.theme = t;
          }
          const h = localStorage.getItem('hue');
          if (h !== null) {
            const n = Math.min(360, Math.max(0, Math.round(Number(h)) || 0));
            document.documentElement.style.setProperty('--hue', String(n));
          }
        } catch {}
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    padding: 0;
    background: var(--bg);
    color: var(--tekst);
    font-family: var(--font-sans);
    font-size: var(--tekst-broed);
    line-height: 1.6;
  }

  h1,
  h2,
  h3,
  h4 {
    font-family: var(--font-hd);
    font-weight: 700;
  }

  ::selection {
    background: color-mix(in srgb, var(--salvie) 30%, transparent);
  }

  a {
    color: var(--salvie);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  :focus-visible {
    outline: 2px solid var(--salvie);
    outline-offset: 2px;
  }

  /* v3-label: Hanken 600 sperret — erstatter mono-labels overalt */
  .label {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--dempet);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
    border: 0;
  }
</style>
