---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { motpart, UI, type Spraak } from '../lib/i18n';

interface Props {
  title: string;
  description?: string;
  lang?: Spraak;
}

const { title, description, lang = 'nb' } = Astro.props;
const alternativ = motpart(Astro.url.pathname, lang);
const t = UI[lang];
---

<Base title={title} description={description} lang={lang} alternativ={alternativ}>
  <a class="hopp" href="#innhold">{t.hoppTil}</a>
  <slot name="topp" />
  <Nav lang={lang} alternativ={alternativ} />
  <main id="innhold" class="ramme">
    <slot />
  </main>
  <Footer lang={lang} />
</Base>

<style>
  .hopp {
    position: absolute;
    left: -9999px;
    top: var(--s-2);
    z-index: 10;
    background: var(--flate);
    color: var(--tekst);
    padding: var(--s-2) var(--s-4);
    border-radius: var(--radius-sm);
    border: 1px solid var(--linje);
  }

  .hopp:focus-visible {
    left: var(--s-2);
  }

  .ramme {
    max-width: 1060px;
    margin: 0 auto;
    padding: 0 var(--s-6) var(--s-8);
    min-height: 55vh;
  }

  @media (max-width: 680px) {
    .ramme {
      padding: 0 var(--s-4) var(--s-7);
    }
  }
</style>
