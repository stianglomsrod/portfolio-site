---
import Side from '../../layouts/Side.astro';

/* English how-i-work page. NORSK TVILLING: src/pages/slik-jobber-jeg.astro
   — endre begge (samme flytskjema-symbolspråk: diamant = beslutning,
   heltrukket = fremover, stiplet = tilbake for å rette, prikket = ny økt). */

const readme = [
  { nokkel: 'goals:', verdi: 'defined and written down before every session' },
  { nokkel: 'guardrails:', verdi: 'what the agent must not do, explicit and enforceable' },
  { nokkel: 'human_review:', verdi: 'decisions, direction and spot checks stay with a human' },
];
---

<Side
  lang="en"
  title="How I work — Stian Glomsrød"
  description="A README for the way of working: goals, guardrails and a human in the loop."
>
  <p class="kicker">README · HOW I WORK</p>
  <h1>How I work</h1>
  <p class="ingress">
    AI agents make me faster, but they do not get the last word. I work in a
    fixed flow where every step has an owner and a clear boundary.
  </p>

  <div class="readme" translate="no">
    {readme.map((r) => (
      <div class="readme-rad">
        <span class="nokkel">{r.nokkel}</span>
        <span class="verdi">{r.verdi}</span>
      </div>
    ))}
  </div>

  <section aria-labelledby="flyt-tittel">
    <h2 id="flyt-tittel">The flow</h2>
    <p class="flyt-ingress">
      Work moves forward when the criteria are green, and back when they are
      not. The flow itself also changes along the way, as I learn what works.
    </p>
    <div class="flyt-omraade">
      <svg id="retur-svg" aria-hidden="true"></svg>
      <ol class="flyt">
        <li class="node-rad">
          <div class="steg">
            <div class="node eier-menneske" data-node="0">
              <span class="node-nr" aria-hidden="true">1</span>
              <div class="node-innhold">
                <h3>Context and requirements</h3>
                <p>
                  Goals, boundaries and success criteria are written down before
                  anything is built. Requirements can change along the way, but
                  as a documented decision.
                </p>
              </div>
            </div>
          </div>
          <div class="kobling" aria-hidden="true">
            <span class="kobling-linje"></span>
            <span class="kobling-pil">▼</span>
          </div>
        </li>

        <li class="node-rad">
          <div class="steg">
            <div class="node eier-agent" data-node="1">
              <span class="node-nr" aria-hidden="true">2</span>
              <div class="node-innhold">
                <h3>Tools</h3>
                <p>
                  I build my own skills for Claude, for the job and the domain
                  the product lives in, plus persistent rules the agents must
                  follow, for documentation and design principles among other
                  things. What gets checked and enforced depends on the context.
                </p>
              </div>
            </div>
          </div>
          <div class="kobling" aria-hidden="true">
            <span class="kobling-label">rigged</span>
            <span class="kobling-linje"></span>
            <span class="kobling-pil">▼</span>
          </div>
        </li>

        <li class="node-rad">
          <div class="steg har-gate">
            <div class="node eier-agent" data-node="2">
              <span class="node-nr" aria-hidden="true">3</span>
              <div class="node-innhold">
                <h3>The work loop</h3>
                <p>
                  The agent builds in small, bounded deliveries: attempt,
                  validate against the criteria, correct.
                </p>
              </div>
            </div>
            <div class="gate-arm" aria-hidden="true">
              <span class="arm-linje"></span>
              <span class="arm-pil">▶</span>
            </div>
            <div class="gate">
              <svg class="gate-form" viewBox="0 0 176 62" aria-hidden="true">
                <polygon points="88,1 175,31 88,61 1,31" />
              </svg>
              <span class="gate-tekst">all green?</span>
            </div>
            <div class="gate-nei">
              <span class="retur-pill" data-rute="a">
                <b class="pill-tag">no</b> correct and rerun
                <span class="pill-maal">↺ 3</span>
              </span>
            </div>
          </div>
          <div class="kobling" aria-hidden="true">
            <span class="kobling-label">yes</span>
            <span class="kobling-linje"></span>
            <span class="kobling-pil">▼</span>
          </div>
        </li>

        <li class="node-rad">
          <div class="steg har-gate">
            <div class="node eier-menneske" data-node="3">
              <span class="node-nr" aria-hidden="true">4</span>
              <div class="node-innhold">
                <h3>Checkpoint</h3>
                <p>
                  This is where the human sits: direction, trade-offs and spot
                  checks. New insight sends the flow back, not forward.
                </p>
              </div>
            </div>
            <div class="gate-arm" aria-hidden="true">
              <span class="arm-linje"></span>
              <span class="arm-pil">▶</span>
            </div>
            <div class="gate">
              <svg class="gate-form" viewBox="0 0 176 62" aria-hidden="true">
                <polygon points="88,1 175,31 88,61 1,31" />
              </svg>
              <span class="gate-tekst">approved?</span>
            </div>
            <div class="gate-nei">
              <span class="retur-pill" data-rute="b">
                <b class="pill-tag">no</b> requirements adjusted
                <span class="pill-maal">→ 1</span>
              </span>
              <span class="retur-pill" data-rute="c">
                <b class="pill-tag">no</b> tools improved
                <span class="pill-maal">→ 2</span>
              </span>
            </div>
          </div>
          <div class="kobling" aria-hidden="true">
            <span class="kobling-label">yes</span>
            <span class="kobling-linje"></span>
            <span class="kobling-pil">▼</span>
          </div>
        </li>

        <li class="node-rad">
          <div class="steg">
            <div class="node" data-node="4">
              <span class="node-nr" aria-hidden="true">5</span>
              <div class="node-innhold">
                <h3>Handover</h3>
                <p>
                  The state is written down: what is done, what remains, and the
                  next step. The next session, or a completely new agent, can
                  take over without any verbal context.
                </p>
              </div>
            </div>
            <div class="syklus-plass">
              <span class="retur-pill syklus-pill" data-rute="d">
                <b class="pill-tag">⟲</b> next session, with full history
                <span class="pill-maal">→ 1</span>
              </span>
            </div>
          </div>
        </li>
      </ol>
    </div>
    <p class="tegnforklaring" aria-hidden="true">
      <span><i class="strek hel"></i> forward</span>
      <span><i class="strek stiplet"></i> back to correct</span>
      <span><i class="strek prikket"></i> new session</span>
      <span><i class="eier-chip menneske"></i> human owns it</span>
      <span><i class="eier-chip agent"></i> agent at work</span>
    </p>
  </section>

  <section aria-labelledby="guardrails-tittel">
    <h2 id="guardrails-tittel">Guardrails in practice</h2>
    <p class="broedtekst">
      This site is itself built this way. The requirements live in their own
      documents, checks run automatically before every build, and decisions
      are logged with a date and a rollback command.
    </p>
    <p class="broedtekst">
      The tooling has improved along the way too: when something turned out
      badly, the rule or skill that let it through was tightened.
    </p>
    <p class="broedtekst">
      The way of working is written down so that a team can pick it up and
      use it.
    </p>
  </section>
</Side>

<style>
  .kicker {
    font-family: var(--font-hd);
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    color: var(--dempet);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-3);
  }

  h2 {
    font-size: 18px;
    margin: var(--s-6) 0 var(--s-3);
  }

  .ingress {
    color: var(--dempet);
    max-width: 68ch;
    margin: 0;
  }

  .readme {
    background: var(--flate);
    border: 1px solid var(--linje);
    border-radius: var(--radius-md);
    padding: var(--s-4);
    margin-top: var(--s-4);
    /* Deler høyrekant med flyt-radene under: samme 120px-felt for
       returlinjene trekkes fra her (håndheves av kant-sjekk) */
    max-width: min(940px, calc(100% - 120px));
  }

  @media (max-width: 680px) {
    .readme {
      max-width: 100%;
    }
  }

  .readme-rad {
    display: flex;
    gap: var(--s-3);
    align-items: baseline;
    padding: 5px 0;
  }

  .nokkel {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: 13px;
    color: var(--tekst);
    width: 130px;
    flex-shrink: 0;
  }

  .verdi {
    font-size: 15px;
    color: var(--tekst);
  }

  /* Agent-tonen er hue-forskjøvet fra aksenten (+80) så den skiller seg
     fra salvie i BEGGE temaer og roterer med paletten. Kun dekor (kant og
     aria-hidden tall) — ikke brødtekst, så L/C-kravet gjelder ikke her. */
  section {
    --eier-agent: oklch(58% 0.11 calc(var(--hue2) + 80));
  }

  .flyt-ingress {
    color: var(--dempet);
    max-width: 62ch;
    margin: 0 0 var(--s-4);
  }

  /* Én flate: hvert steg er en vannrett rad (node → diamant → nei-piller),
     så hele flyten får plass i én viewport. Returlinjene rutes i eget felt
     til høyre. */
  .flyt-omraade {
    position: relative;
    max-width: 1060px;
    padding-right: 120px;
  }

  #retur-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    overflow: visible;
  }

  @media (max-width: 680px) {
    .flyt-omraade {
      padding-right: 0;
    }
  }

  .flyt {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 940px;
  }

  .node-rad {
    display: flex;
    flex-direction: column;
  }

  /* Steg-raden: node | arm | diamant | nei-piller. Rader uten gate bruker
     samme spor så nodene får identisk bredde og venstre flukt. */
  .steg {
    display: grid;
    grid-template-columns: minmax(0, 480px) 26px 150px minmax(0, 1fr);
    align-items: center;
    gap: 0 var(--s-2);
  }

  .node {
    grid-column: 1;
    display: flex;
    gap: var(--s-3);
    background: var(--flate);
    border: 1px solid var(--linje);
    border-left-width: 3px;
    border-radius: var(--radius-md);
    box-shadow: var(--kort-skygge);
    padding: var(--s-3) var(--s-4);
  }

  /* Rader uten beslutning lar noden fylle ut til diamant-sporet, så
     høyresiden ikke står tom */
  .steg:not(.har-gate) .node {
    grid-column: 1 / 4;
  }

  /* Eierfarger — sidens poeng er at hvert steg har en eier:
     salvie = mennesket (handlekraft), aksent = agenten/verktøyet */
  .node.eier-menneske {
    border-left-color: var(--salvie);
  }

  .node.eier-menneske .node-nr {
    color: var(--salvie);
    border-color: var(--salvie);
  }

  .node.eier-agent {
    border-left-color: var(--eier-agent);
  }

  .node.eier-agent .node-nr {
    color: var(--eier-agent);
    border-color: var(--eier-agent);
  }

  .node-nr {
    font-family: var(--font-hd);
    font-weight: 700;
    font-size: 13.5px;
    color: var(--dempet);
    border: 1px solid var(--linje);
    border-radius: 50%;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .node-innhold h3 {
    font-size: 16px;
    margin: 0 0 var(--s-1);
  }

  .node-innhold p {
    font-size: 15px;
    line-height: 1.55;
    color: var(--dempet);
    margin: 0;
    max-width: 58ch;
  }

  /* Kobling mellom stegene: heltrukket = flyten fremover. Sentreres under
     node-sporet (ikke hele raden). */
  .kobling {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2px 0;
    width: min(100%, 480px);
  }

  .kobling-label {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: 12.5px;
    letter-spacing: 0.06em;
    color: var(--salvie);
    padding: 1px 0;
  }

  .kobling-linje {
    width: 2px;
    height: 9px;
    background: var(--linje);
  }

  .kobling-pil {
    color: var(--linje);
    font-size: 10px;
    line-height: 1;
  }

  /* Armen fra noden inn i diamanten: heltrukket, vannrett */
  .gate-arm {
    grid-column: 2;
    display: flex;
    align-items: center;
  }

  .arm-linje {
    flex: 1;
    height: 2px;
    background: var(--linje);
  }

  .arm-pil {
    color: var(--linje);
    font-size: 9px;
    line-height: 1;
    margin-left: -1px;
  }

  /* Beslutningsport: diamant (ISO-konvensjon) med spørsmålet inni.
     Ja fortsetter nedover fra raden, nei går ut til høyre som merket pille. */
  .gate {
    position: relative;
    grid-column: 3;
    width: 150px;
    height: 56px;
    display: grid;
    place-items: center;
  }

  .gate-form {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .gate-form polygon {
    fill: var(--flate);
    stroke: var(--salvie);
    stroke-width: 1.3;
  }

  .gate-tekst {
    position: relative;
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: 13.5px;
    color: var(--tekst);
  }

  .gate-nei {
    grid-column: 4;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
    padding-left: var(--s-2);
  }

  /* Retur-piller: vannrette etiketter som også er startpunktet for
     returlinjene. Kantstilen speiler linjespråket (stiplet/prikket). */
  .retur-pill {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    font-family: var(--font-hd);
    font-size: 13px;
    color: var(--tekst);
    background: var(--flate-2);
    border: 1px dashed var(--linje);
    border-radius: var(--radius-sm);
    padding: 5px 10px;
    white-space: nowrap;
  }

  .pill-tag {
    font-weight: 700;
    font-size: 12px;
    color: var(--feil);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pill-maal {
    font-weight: 600;
    color: var(--salvie);
  }

  /* Syklus-pillen står ved siden av overleveringsnoden (siste rad) */
  .syklus-plass {
    grid-column: 3 / 5;
    justify-self: start;
    padding-left: var(--s-2);
  }

  .syklus-pill {
    border-style: dotted;
  }

  .syklus-pill .pill-tag {
    text-transform: none;
    color: var(--salvie);
  }

  /* Tegnforklaring: linjetypene betyr noe, så de forklares */
  .tegnforklaring {
    display: flex;
    gap: var(--s-5);
    flex-wrap: wrap;
    margin: var(--s-4) 0 0;
    font-family: var(--font-hd);
    font-size: 13px;
    color: var(--dempet);
  }

  .strek {
    display: inline-block;
    width: 24px;
    border-top: 2px solid var(--dempet);
    vertical-align: middle;
    margin-right: 6px;
  }

  .strek.stiplet {
    border-top-style: dashed;
  }

  .strek.prikket {
    border-top-style: dotted;
  }

  .eier-chip {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 3px;
    vertical-align: middle;
    margin-right: 6px;
  }

  .eier-chip.menneske {
    background: var(--salvie);
  }

  .eier-chip.agent {
    background: var(--eier-agent);
  }

  @media (max-width: 680px) {
    /* På smale skjermer stables stegene igjen: pillene bærer informasjonen
       alene (→ 1 osv.), og linjefeltet til høyre finnes ikke */
    .tegnforklaring {
      display: none;
    }

    .steg {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--s-2);
    }

    .node {
      width: 100%;
      box-sizing: border-box;
    }

    .gate-arm {
      display: none;
    }

    .gate-nei {
      align-items: center;
      padding-left: 0;
    }

    .retur-pill {
      white-space: normal;
    }

    .syklus-plass {
      padding-left: 0;
    }

    .kobling {
      width: 100%;
    }
  }

  .broedtekst {
    max-width: 68ch;
    line-height: 1.6;
    color: var(--tekst);
  }
</style>

<script>
  /* Returlinjene tegnes fra pillene (etikettene) til målnodene, rutet i
     eget felt til høyre. Se den norske tvillingen for full forklaring. */
  const omraade = document.querySelector<HTMLElement>('.flyt-omraade');
  const svg = document.getElementById('retur-svg');
  const noder = [...document.querySelectorAll<HTMLElement>('.flyt .node')];

  interface Rute {
    pill: string;
    til: number; // data-node på målet
    bane: number; // parallell bane i høyrefeltet (0 = innerst)
    inngang: number | 'bunn'; // px fra målnodens topp; 'bunn' = nederst
    prikket?: boolean;
  }

  const ruter: Rute[] = [
    { pill: 'a', til: 2, bane: 0, inngang: 'bunn' },
    { pill: 'c', til: 1, bane: 1, inngang: 26 },
    { pill: 'b', til: 0, bane: 2, inngang: 26 },
    { pill: 'd', til: 0, bane: 3, inngang: 46, prikket: true },
  ];

  const NS = 'http://www.w3.org/2000/svg';

  function tegn() {
    if (!omraade || !svg || noder.length < 5) return;
    svg.replaceChildren();
    if (omraade.clientWidth < 760) return;

    const boks = omraade.getBoundingClientRect();
    /* Banefeltet ligger til høyre for ALT i radene (noder og piller) */
    const alleBokser = [
      ...noder,
      ...omraade.querySelectorAll<HTMLElement>('[data-rute]'),
    ];
    const kolonneHoyre = Math.max(
      ...alleBokser.map((n) => n.getBoundingClientRect().right)
    );

    for (const rute of ruter) {
      const pill = omraade.querySelector<HTMLElement>(`[data-rute="${rute.pill}"]`);
      if (!pill) continue;
      const fra = pill.getBoundingClientRect();
      const til = noder[rute.til].getBoundingClientRect();

      const startX = fra.right - boks.left + 4;
      const startY = fra.top + fra.height / 2 - boks.top;
      const baneX = kolonneHoyre - boks.left + 20 + rute.bane * 24;
      const inngang =
        rute.inngang === 'bunn' ? til.height - 14 : rute.inngang;
      const sluttY = til.top - boks.top + inngang;
      const sluttX = til.right - boks.left + 9;

      const linje = document.createElementNS(NS, 'path');
      linje.setAttribute(
        'd',
        `M ${startX} ${startY} H ${baneX} V ${sluttY} H ${sluttX}`
      );
      linje.setAttribute('fill', 'none');
      linje.setAttribute('stroke-width', '1.5');
      linje.setAttribute('stroke-dasharray', rute.prikket ? '2 5' : '6 5');
      linje.setAttribute('stroke-linecap', 'round');
      linje.style.stroke = 'var(--dempet)';
      svg.appendChild(linje);

      const pilhode = document.createElementNS(NS, 'path');
      pilhode.setAttribute('d', `M ${sluttX} ${sluttY} l 8 -4.5 v 9 z`);
      pilhode.style.fill = 'var(--dempet)';
      svg.appendChild(pilhode);
    }
  }

  tegn();
  if (omraade) new ResizeObserver(tegn).observe(omraade);
  document.fonts?.ready.then(tegn);
</script>
