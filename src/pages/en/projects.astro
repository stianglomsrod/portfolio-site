---
import Side from '../../layouts/Side.astro';
import ProsjektKort from '../../components/ProsjektKort.astro';
import prosjekter from '../../data/prosjekter.json';

/* English projects page. NORSK TVILLING: src/pages/prosjekter.astro —
   endre begge. Sannhetsreglene gjelder på begge språk: Klar er en
   fungerende prototype evaluert med lærere, ikke i produksjon. */

const klarSteg = [
  {
    steg: 'problem',
    tekst:
      'Teachers spend evenings translating weekly plans and messages into something pupils with executive function challenges can actually use. The existing tools demand more structure than a school day has.',
  },
  {
    steg: 'insight',
    tekst:
      'From participatory design with teachers: low friction and time saved decide whether something gets used; help must come without stigma; motivation must not turn into pressure. The needs were mapped in workshops, with the teachers as co-designers.',
  },
  {
    steg: 'choice',
    tekst:
      'A responsive PWA (React, Next.js, TypeScript, Supabase/PostgreSQL) with role-based access, teacher and pupil on the same data layer. Smart Import: AI-assisted import of weekly letters with an editable preview, so a human always approves before anything is published.',
  },
  {
    steg: 'result',
    tekst:
      'A working prototype, evaluated with teachers. Design science research, not an effect study. Pupils only took part in the precursor project.',
  },
  {
    steg: 'learning',
    tekst:
      'A prototype and a production system are two different things, and AI in the product needs a human checkpoint. The boundaries here are deliberate.',
  },
];

const klarBilder = [
  { fil: '/bilder/klar/smart-import.png', alt: 'Screenshot of Smart Import in Klar: a weekly letter interpreted into an editable preview before publishing' },
  { fil: '/bilder/klar/laererens-landingsside.png', alt: 'Screenshot of the teacher landing page in Klar with an overview of classes and tasks' },
  { fil: '/bilder/klar/elevens-landingsside.png', alt: 'Screenshot of the pupil landing page in Klar with today’s plan' },
];
---

<Side
  lang="en"
  title="Projects — Stian Glomsrød"
  description="Cases: Klar, Companion, Lori Frisør and their precursors — problem, insight, choice, result, learning."
>
  <p class="kicker">Projects</p>
  <h1>Projects</h1>
  <p class="ingress">
    The same way of working runs through quite different deliveries: a
    product, a long-running development flow and a handover to a client.
  </p>
  <p class="format" aria-hidden="true">
    problem <span>→</span> insight <span>→</span> choice <span>→</span> result
    <span>→</span> learning
  </p>

  <section class="hovedcase" id="klar" aria-labelledby="klar-tittel">
    <p class="case-tag">Main case · Master's project · 2026</p>
    <h2 id="klar-tittel">Klar</h2>
    <p class="case-ingress">
      A digital aid for pupils with executive function challenges, built with
      participatory design as the method.
    </p>
    <dl class="steg-liste">
      {klarSteg.map((s) => (
        <div class="steg">
          <dt>{s.steg}</dt>
          <dd>{s.tekst}</dd>
        </div>
      ))}
    </dl>
    <div class="galleri">
      {klarBilder.map((b, i) => (
        <button
          type="button"
          class="galleri-knapp"
          data-bilde={i}
          aria-label={`Show larger image: ${b.alt}`}
        >
          <img src={b.fil} alt={b.alt} loading="lazy" width="1920" height="871" />
        </button>
      ))}
    </div>
    <dialog id="lysboks" aria-label="Image viewer">
      <button type="button" class="lb-knapp lb-lukk" data-lukk aria-label="Close the image viewer">✕</button>
      <button type="button" class="lb-knapp lb-forrige" data-forrige aria-label="Previous image">←</button>
      <figure class="lb-figur">
        <img id="lysboks-bilde" src="" alt="" />
        <figcaption>
          <span id="lysboks-tekst"></span>
          <span id="lysboks-teller" class="lb-teller" aria-live="polite"></span>
        </figcaption>
      </figure>
      <button type="button" class="lb-knapp lb-neste" data-neste aria-label="Next image">→</button>
    </dialog>
    <p class="testbruker">
      The demo has a login. Get in touch and I will set you up with a test user.
    </p>
    <p class="case-lenker">
      <a href={prosjekter.klar.demo} class="primaer" rel="noreferrer noopener">demo <span class="pil" aria-hidden="true">→</span></a>
      <a href={prosjekter.klar.repo} rel="noreferrer noopener">repo <span class="pil" aria-hidden="true">→</span></a>
    </p>
  </section>

  <section class="andre" aria-label="More projects">
    <div class="kort-grid">
      <ProsjektKort
        tag="Documented development flow"
        tittel="Companion"
        tekst={prosjekter.companion.stack}
        note="Nikko's idea, built on over a long stretch of time with a documented workflow."
        lenker={[{ href: prosjekter.companion.repo, label: 'repo' }]}
      />
      <ProsjektKort
        tag="Handed over to its owner"
        tittel={prosjekter.lori.navn}
        tekst="Astro · Keystatic (owner editing) · Vercel · handover documentation · chose to integrate Timma rather than rebuild booking"
        note="A website a hair salon can run on its own after handover."
        lenker={[
          { href: prosjekter.lori.url, label: 'the site', primaer: true },
          { href: prosjekter.lori.repo, label: 'repo' },
        ]}
      />
      <ProsjektKort
        tag="The precursor to Klar"
        tittel={prosjekter.pdApp.navn}
        tekst="The precursor to Klar: a Vue frontend and Django backend, with future users as co-designers."
        note="132 commits written by hand, before agentic tools. A genuine time capsule."
        lenker={[
          { href: prosjekter.pdApp.frontend, label: 'frontend' },
          { href: prosjekter.pdApp.backend, label: 'backend' },
        ]}
      />
      <ProsjektKort
        tag="The foundation"
        tittel="CS50x + Ordkryss"
        tekst="Basic programming through Harvard's CS50x."
        note="The final project: Ordkryss, a word search generator that prints. A small, honest student project with its bugs and worst practices preserved."
        lenker={[
          { href: prosjekter.cs50x.sertifikat, label: 'certificate' },
          { href: '/en/sandbox/wordsearch', label: 'the rebuilt tool' },
        ]}
      />
      <ProsjektKort
        tag="Built in open dialogue with Claude"
        tittel="This site"
        tekst="The portfolio you are reading: Astro with live data from now.json and GitHub, plus a game in /sandbox."
        lenker={[
          { href: prosjekter.denneSiden.repo, label: 'repo' },
          { href: '/en/colophon', label: 'how it was made' },
        ]}
      />
      <ProsjektKort
        tag="Future startup"
        tittel={prosjekter.claudeFirst.navn}
        tekst="Landing page for a software studio in the planning stage: websites, apps and AI tools for small businesses."
        lenker={[{ href: prosjekter.claudeFirst.url, label: 'the site' }]}
      />
    </div>
  </section>

  <p class="grense">
    The examples show a way of working and technical judgement, at prototype
    scale.
  </p>
</Side>

<style>
  .kicker {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--dempet);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-3);
  }

  .ingress {
    color: var(--dempet);
    max-width: 68ch;
    margin: 0;
  }

  .format {
    font-family: var(--font-hd);
    font-size: 14px;
    color: var(--dempet);
    margin: var(--s-3) 0 0;
  }

  .format span {
    color: var(--dempet);
  }

  /* Fyller ramma — samme kant som kortgrid-en under */
  .hovedcase {
    background: var(--flate);
    border: 1px solid var(--linje);
    border-radius: var(--radius-lg);
    box-shadow: var(--kort-skygge);
    padding: var(--s-5);
    margin-top: var(--s-6);
  }

  .case-tag {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: 12.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--dempet);
    margin: 0 0 var(--s-2);
  }

  h2 {
    font-size: 24px;
    margin: 0 0 var(--s-1);
  }

  .case-ingress {
    color: var(--dempet);
    margin: 0 0 var(--s-4);
  }

  .steg-liste {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }

  .steg {
    display: grid;
    grid-template-columns: 92px 1fr;
    gap: var(--s-3);
  }

  .steg dt {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: 12.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--dempet);
  }

  .steg dd {
    margin: 0;
    font-size: 15.5px;
    line-height: 1.6;
    color: var(--tekst);
    max-width: 62ch;
  }

  @media (max-width: 680px) {
    .steg {
      grid-template-columns: 1fr;
      gap: var(--s-1);
    }
  }

  .galleri {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--s-2);
    margin-top: var(--s-4);
  }

  .galleri-knapp {
    all: unset;
    cursor: pointer;
    border-radius: var(--radius-sm);
    transition: transform 160ms var(--ease);
  }

  .galleri-knapp:hover,
  .galleri-knapp:focus-visible {
    transform: scale(1.02);
  }

  .galleri-knapp:focus-visible {
    outline: 2px solid var(--salvie);
    outline-offset: 2px;
  }

  .galleri img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
    border: 1px solid var(--linje);
  }

  /* Lysboks: native <dialog> gir fokusfelle og Esc-lukking gratis */
  #lysboks {
    background: var(--bg);
    border: 1px solid var(--linje);
    border-radius: var(--radius-lg);
    padding: var(--s-5);
    max-width: min(92vw, 1200px);
    color: var(--tekst);
  }

  #lysboks::backdrop {
    background: rgba(10, 13, 12, 0.82);
  }

  .lb-figur {
    margin: 0;
  }

  #lysboks-bilde {
    display: block;
    max-width: 100%;
    max-height: 74vh;
    border-radius: var(--radius-sm);
    border: 1px solid var(--linje);
  }

  .lb-figur figcaption {
    display: flex;
    justify-content: space-between;
    gap: var(--s-4);
    margin-top: var(--s-3);
    font-size: 15px;
    color: var(--dempet);
  }

  .lb-teller {
    flex-shrink: 0;
  }

  .lb-knapp {
    all: unset;
    position: absolute;
    min-width: 44px;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    color: var(--tekst);
    background: var(--flate);
    border: 1px solid var(--linje);
    border-radius: 50%;
    cursor: pointer;
  }

  .lb-knapp:hover {
    border-color: var(--dempet);
  }

  .lb-knapp:focus-visible {
    outline: 2px solid var(--salvie);
    outline-offset: 2px;
  }

  .lb-lukk {
    top: var(--s-3);
    right: var(--s-3);
  }

  .lb-forrige {
    left: var(--s-3);
    top: 50%;
    transform: translateY(-50%);
  }

  .lb-neste {
    right: var(--s-3);
    top: 50%;
    transform: translateY(-50%);
  }

  .testbruker {
    font-size: 15px;
    color: var(--tekst);
    margin: var(--s-4) 0 0;
  }

  .case-lenker {
    display: flex;
    gap: var(--s-4);
    margin: var(--s-2) 0 0;
    font-family: var(--font-hd);
    font-size: 15px;
  }

  .case-lenker a {
    text-decoration: none;
  }

  .case-lenker a:hover,
  .case-lenker a:focus-visible {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .pil {
    display: inline-block;
    transition: transform var(--dur-mikro) var(--ease);
  }

  .case-lenker a:hover .pil,
  .case-lenker a:focus-visible .pil {
    transform: translateX(3px);
  }

  .case-lenker .primaer {
    color: var(--salvie);
  }

  .kort-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--s-3);
    margin-top: var(--s-4);
  }

  .grense {
    font-size: 15px;
    color: var(--dempet);
    margin-top: var(--s-5);
  }
</style>

<script>
  // Lysboks med frem/tilbake: <dialog> gir fokusfelle og Esc; piltaster
  // og knapper blar med wrap-around.
  const dialog = document.getElementById('lysboks') as HTMLDialogElement | null;
  const bildeEl = document.getElementById('lysboks-bilde') as HTMLImageElement | null;
  const tekstEl = document.getElementById('lysboks-tekst');
  const tellerEl = document.getElementById('lysboks-teller');
  const knapper = [...document.querySelectorAll<HTMLButtonElement>('.galleri-knapp')];
  const bilder = knapper.map((k) => {
    const img = k.querySelector('img');
    return { src: img?.getAttribute('src') ?? '', alt: img?.alt ?? '' };
  });

  let aktiv = 0;

  const vis = (indeks: number) => {
    aktiv = (indeks + bilder.length) % bilder.length;
    const b = bilder[aktiv];
    if (bildeEl) {
      bildeEl.src = b.src;
      bildeEl.alt = b.alt;
    }
    if (tekstEl) tekstEl.textContent = b.alt;
    if (tellerEl) tellerEl.textContent = `${aktiv + 1} of ${bilder.length}`;
  };

  knapper.forEach((k, i) =>
    k.addEventListener('click', () => {
      vis(i);
      dialog?.showModal();
    })
  );

  dialog?.querySelector('[data-lukk]')?.addEventListener('click', () => dialog.close());
  dialog?.querySelector('[data-forrige]')?.addEventListener('click', () => vis(aktiv - 1));
  dialog?.querySelector('[data-neste]')?.addEventListener('click', () => vis(aktiv + 1));

  dialog?.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') vis(aktiv - 1);
    if (e.key === 'ArrowRight') vis(aktiv + 1);
  });

  dialog?.addEventListener('click', (e) => {
    if (e.target === dialog) dialog.close();
  });
</script>
