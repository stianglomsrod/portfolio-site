---
import Side from '../../layouts/Side.astro';
import HueVelger from '../../components/HueVelger.astro';

/* The workshop. NORSK TVILLING: src/pages/sandbox.astro — endre begge. */
---

<Side
  lang="en"
  title="/sandbox — Stian Glomsrød"
  description="The workshop: experiments, tools and the game “Shameless Pitch”."
>
  <p class="kicker">/sandbox</p>
  <h1>Sandbox</h1>
  <p class="dempet">
    My workshop. Everything from finished to unfinished things shows up here.
  </p>

  <div class="eks-grid">
    <a class="eksperiment" href="/sandbox/skamlos-pitch">
      <span class="eks-tag">Game</span>
      <span class="eks-tittel">Skamløs Pitch: Kompetansebyen</span>
      <span class="eks-tekst">
        A small top-down RPG about building competence. The game reads the
        same data sources as the rest of the site. In Norwegian.
      </span>
      <span class="eks-cta">play <span class="pil" aria-hidden="true">→</span></span>
    </a>

    <a class="eksperiment" href="/en/teacher">
      <span class="eks-tag">Tools</span>
      <span class="eks-tittel">The teacher's room</span>
      <span class="eks-tekst">
        All the teacher tools in one place: type your content, print
        worksheets with answer keys. Language, maths, games.
      </span>
      <span class="eks-cta">to the teacher's room <span class="pil" aria-hidden="true">→</span></span>
    </a>

    <div class="full-rad">
      <HueVelger lang="en" />
    </div>
  </div>
</Side>

<style>
  .kicker {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--hue-aksent);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-3);
  }

  .dempet {
    color: var(--dempet);
    max-width: 68ch;
  }

  /* Delt spor-regel: se den norske tvillingen. Håndheves av kant-sjekk. */
  .eks-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--s-3);
    margin-top: var(--s-5);
  }

  .full-rad,
  .eks-bred {
    grid-column: 1 / -1;
  }

  @media (max-width: 900px) {
    .eks-grid {
      grid-template-columns: 1fr;
    }
  }

  .eksperiment {
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
    background: var(--flate);
    border: 1px solid var(--linje);
    border-radius: var(--radius-md);
    box-shadow: var(--kort-skygge);
    padding: var(--s-4) var(--s-4);
    text-decoration: none;
    transition: border-color 160ms, transform 160ms var(--ease), box-shadow 160ms var(--ease);
  }

  .eksperiment:hover,
  .eksperiment:focus-visible {
    border-color: var(--salvie);
    transform: translateY(-3px);
    box-shadow: var(--kort-skygge-hover);
  }

  .eks-tag {
    font-family: var(--font-hd);
    font-size: 12.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--hue-aksent);
  }

  .eks-tittel {
    font-size: 19px;
    font-weight: 700;
    color: var(--tekst);
  }

  .eks-tekst {
    font-size: 15.5px;
    line-height: 1.5;
    color: var(--dempet);
  }

  .eks-cta {
    font-family: var(--font-hd);
    font-size: 14.5px;
    color: var(--salvie);
    margin-top: auto;
  }

  .pil {
    display: inline-block;
    transition: transform var(--dur-mikro) var(--ease);
  }

  .eksperiment:hover .pil,
  .eksperiment:focus-visible .pil {
    transform: translateX(3px);
  }
</style>
