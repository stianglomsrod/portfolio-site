---
import Side from '../../../layouts/Side.astro';
import AlfabetiseringVerktoy from '../../../components/AlfabetiseringVerktoy.astro';

/* Alphabetical order in the sandbox. NORSK TVILLING:
   src/pages/sandbox/alfabetisering.astro — endre begge. */
---

<Side
  lang="en"
  title="Alphabetical order — make printable sorting sheets"
  description="Pupils write the words in alphabetical order — with a proper answer key."
>
  <div class="al-side-hode">
    <p class="kicker">/sandbox · tool</p>
    <h1>Alphabetical order</h1>
    <p class="dempet">
      Make sorting sheets: type the words and the sheet shows them shuffled with numbered writing lines below. The answer key sorts them correctly.
    </p>
  </div>
  <AlfabetiseringVerktoy lang="en" />
</Side>

<style>
  .kicker {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--hue-aksent);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-3);
  }

  .dempet {
    color: var(--dempet);
    max-width: 68ch;
    margin: 0;
  }
</style>
