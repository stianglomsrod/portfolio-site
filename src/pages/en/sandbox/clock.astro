---
import Side from '../../../layouts/Side.astro';
import KlokkeVerktoy from '../../../components/KlokkeVerktoy.astro';

/* The clock in the sandbox. NORSK TVILLING:
   src/pages/sandbox/klokke.astro — endre begge. */
---

<Side
  lang="en"
  title="The clock — make printable clock sheets"
  description="Clock faces with hands to read — or empty faces where pupils draw the hands themselves."
>
  <div class="kl-side-hode">
    <p class="kicker">/sandbox · tool</p>
    <h1>The clock</h1>
    <p class="dempet">
      Make clock sheets: choose whether pupils read the clock or draw the hands, and the precision — whole hours, halves, quarters or five minutes. Answer key included.
    </p>
  </div>
  <KlokkeVerktoy lang="en" />
</Side>

<style>
  .kicker {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--hue-aksent);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-3);
  }

  .dempet {
    color: var(--dempet);
    max-width: 68ch;
    margin: 0;
  }
</style>
