---
import Side from '../../../layouts/Side.astro';
import LuketekstVerktoy from '../../../components/LuketekstVerktoy.astro';

/* Gap-fill text in the sandbox. NORSK TVILLING:
   src/pages/sandbox/luketekst.astro — endre begge. */
---

<Side
  lang="en"
  title="Gap-fill — make printable cloze sheets"
  description="Paste a text, choose which words become gaps, and print — with a word bank and an answer key."
>
  <div class="lu-side-hode">
    <p class="kicker">/sandbox · tool</p>
    <h1>Gap-fill text</h1>
    <p class="dempet">
      Make cloze sheets: paste a text and pick the gaps automatically or by clicking the words. Word bank and answer-key printing are optional.
    </p>
  </div>
  <LuketekstVerktoy lang="en" />
</Side>

<style>
  .kicker {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--hue-aksent);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-3);
  }

  .dempet {
    color: var(--dempet);
    max-width: 68ch;
    margin: 0;
  }
</style>
