---
import Side from '../../../layouts/Side.astro';
import HundrekartVerktoy from '../../../components/HundrekartVerktoy.astro';

/* Hundred chart in the teacher's room. NORSK TVILLING:
   src/pages/sandbox/hundrekart.astro — endre begge. */
---

<Side
  lang="en"
  title="Hundred chart — make printable fill-in sheets"
  description="The hundred chart with empty squares for pupils to fill in — pick 1–100 or 0–99 and how much is pre-filled. Answer key included."
>
  <div class="hu-side-hode">
    <p class="kicker">/teacher · maths</p>
    <h1>Hundred chart</h1>
    <p class="dempet">
      Make hundred chart sheets: pick 1–100 or 0–99 and how much is filled
      in — a few empty squares, only the tens, or a completely empty chart.
      The key fills everything.
    </p>
  </div>
  <HundrekartVerktoy lang="en" />
</Side>

<style>
  .kicker {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--hue-aksent);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-3);
  }

  .dempet {
    color: var(--dempet);
    max-width: 68ch;
    margin: 0;
  }
</style>
