---
import Side from '../../../layouts/Side.astro';
import HemmeligKodeVerktoy from '../../../components/HemmeligKodeVerktoy.astro';

/* Secret code in the teacher's room. NORSK TVILLING:
   src/pages/sandbox/hemmelig-kode.astro — endre begge. */
---

<Side
  lang="en"
  title="Secret code — make printable code sheets"
  description="Your words are encoded with numbers or secret symbols — pupils use the key to decode them. Answer key included."
>
  <div class="ko-side-hode">
    <p class="kicker">/teacher · language</p>
    <h1>Secret code</h1>
    <p class="dempet">
      Make code sheets: your words or sentences are encoded sign by sign,
      and pupils use the key at the top of the sheet to crack the code.
      Pick a number code (fixed or secret) or symbols — the answer key
      prints separately.
    </p>
  </div>
  <HemmeligKodeVerktoy lang="en" />
</Side>

<style>
  .kicker {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--hue-aksent);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-3);
  }

  .dempet {
    color: var(--dempet);
    max-width: 68ch;
    margin: 0;
  }
</style>
