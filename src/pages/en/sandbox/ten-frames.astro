---
import Side from '../../../layouts/Side.astro';
import TierammeVerktoy from '../../../components/TierammeVerktoy.astro';

/* Ten frames in the teacher's room. NORSK TVILLING:
   src/pages/sandbox/tierammer.astro — endre begge. */
---

<Side
  lang="en"
  title="Quantities and ten frames — make printable sheets"
  description="Ten frames and dice patterns: count dots, draw quantities or find friends of ten. For early maths, with an answer key."
>
  <div class="ti-side-hode">
    <p class="kicker">/teacher · maths</p>
    <h1>Quantities and ten frames</h1>
    <p class="dempet">
      Make quantity sheets for early maths: pupils count dots in ten frames
      or dice patterns, draw quantities themselves, or find friends of ten.
      Pick the range 0–10 or 0–20 — the answer key prints separately.
    </p>
  </div>
  <TierammeVerktoy lang="en" />
</Side>

<style>
  .kicker {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--hue-aksent);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-3);
  }

  .dempet {
    color: var(--dempet);
    max-width: 68ch;
    margin: 0;
  }
</style>
