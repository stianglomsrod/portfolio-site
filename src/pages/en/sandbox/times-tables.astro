---
import Side from '../../../layouts/Side.astro';
import GangetabellVerktoy from '../../../components/GangetabellVerktoy.astro';

/* Times table in the sandbox. NORSK TVILLING:
   src/pages/sandbox/gangetabell.astro — endre begge. */
---

<Side
  lang="en"
  title="Times table — make printable fill-in sheets"
  description="The 10 × 10 table as a fill-in sheet — empty or partly filled, with an answer key."
>
  <div class="ga-side-hode">
    <p class="kicker">/sandbox · tool</p>
    <h1>Times table</h1>
    <p class="dempet">
      Make times table sheets: the full 10 × 10 table as a fill-in sheet, empty or with some answers in place. The key fills everything.
    </p>
  </div>
  <GangetabellVerktoy lang="en" />
</Side>

<style>
  .kicker {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--hue-aksent);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-3);
  }

  .dempet {
    color: var(--dempet);
    max-width: 68ch;
    margin: 0;
  }
</style>
