---
import Side from '../../../layouts/Side.astro';
import SporingVerktoy from '../../../components/SporingVerktoy.astro';

/* Tracing in the sandbox. NORSK TVILLING:
   src/pages/sandbox/sporing.astro — endre begge. */
---

<Side
  lang="en"
  title="Tracing — make handwriting letter-formation sheets"
  description="Letters in a letter house with a green starting point and direction arrows on the outside — model, practice, then writing on their own."
>
  <div class="sp-side-hode">
    <p class="kicker">/sandbox · tool</p>
    <h1>Tracing</h1>
    <p class="dempet">
      Make letter-formation sheets: type the letters or words and they are drawn in a letter house (attic, middle, basement) with a green starting point and direction arrows on the outside of the letter — one clear model, then guided practice, then on their own. Optional house colours and empty practice line.
    </p>
  </div>
  <SporingVerktoy lang="en" />
</Side>

<style>
  .kicker {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--hue-aksent);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-3);
  }

  .dempet {
    color: var(--dempet);
    max-width: 68ch;
    margin: 0;
  }
</style>
