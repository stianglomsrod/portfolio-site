---
import Side from '../../../layouts/Side.astro';
import SporingVerktoy from '../../../components/SporingVerktoy.astro';

/* Tracing in the sandbox. NORSK TVILLING:
   src/pages/sandbox/sporing.astro — endre begge. */
---

<Side
  lang="en"
  title="Tracing — make dotted-letter writing sheets"
  description="Dotted letters and words on writing lines — the pupil traces and then writes on their own."
>
  <div class="sp-side-hode">
    <p class="kicker">/sandbox · tool</p>
    <h1>Tracing</h1>
    <p class="dempet">
      Make handwriting tracing sheets: type the letters or words and the sheet shows them as dotted outlines on writing lines — the first one clear, the rest fainter. Optional empty line under each row.
    </p>
  </div>
  <SporingVerktoy lang="en" />
</Side>

<style>
  .kicker {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--hue-aksent);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-3);
  }

  .dempet {
    color: var(--dempet);
    max-width: 68ch;
    margin: 0;
  }
</style>
