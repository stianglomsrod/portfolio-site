---
import Side from '../layouts/Side.astro';
import Hero from '../components/Hero.astro';
import ProsjektKort from '../components/ProsjektKort.astro';
import prosjekter from '../data/prosjekter.json';

/* Rendres per forespørsel så matrisen og «aktiv i dag» alltid er ferske.
   Edge-cachen (15 min + stale-while-revalidate) tar trafikken — GitHub
   treffes bare når cachen er utløpt. ENGELSK TVILLING: en/index.astro. */
export const prerender = false;
Astro.response.headers.set(
  'Cache-Control',
  'public, s-maxage=900, stale-while-revalidate=86400'
);
---

<Side
  title="Stian Glomsrød — utvikler og UX"
  description="Lærer på vei inn i utviklerrollen. Dette pågår akkurat nå."
>
  <Hero />
  <section class="bevis-seksjon" aria-labelledby="bevis-tittel">
    <h2 class="label" id="bevis-tittel">Utvalgte prosjekter</h2>
    <div class="bevis-grid">
      <ProsjektKort
        tag="Masterprosjekt · 2026"
        tittel="Klar"
        tekst="Digitalt hjelpemiddel for elever med eksekutive vansker, bygd med participatory design som metode."
        note="Demoen har innlogging. Ta kontakt, så gir jeg deg en testbruker."
        lenker={[
          { href: prosjekter.klar.demo, label: 'prøv demoen', primaer: true },
          { href: '/prosjekter#klar', label: 'les historien' },
        ]}
      />
      <ProsjektKort
        tag="Dokumentert utviklingsflyt"
        tittel="Companion"
        tekst={prosjekter.companion.beskrivelse}
        lenker={[{ href: prosjekter.companion.repo, label: 'repo' }]}
      />
      <ProsjektKort
        tag="Overlevert til eier"
        tittel={prosjekter.lori.navn}
        tekst={prosjekter.lori.beskrivelse}
        lenker={[{ href: prosjekter.lori.url, label: 'nettstedet' }]}
      />
      <ProsjektKort
        tag="Bygd med Claude Design og Claude Code"
        tittel={prosjekter.denneSiden.navn}
        tekst={prosjekter.denneSiden.beskrivelse}
        lenker={[
          { href: prosjekter.denneSiden.repo, label: 'repo' },
          { href: '/kolofon', label: 'slik ble siden til' },
        ]}
      />
      <ProsjektKort
        tag="Fremtidig startup"
        tittel={prosjekter.claudeFirst.navn}
        tekst={prosjekter.claudeFirst.beskrivelse}
        lenker={[{ href: prosjekter.claudeFirst.url, label: 'nettstedet' }]}
      />
    </div>
    <p class="mer">
      <a href="/prosjekter">alle prosjekter <span class="pil" aria-hidden="true">→</span></a>
    </p>
  </section>
</Side>

<style>
  .bevis-seksjon {
    margin-top: var(--s-8);
  }

  .bevis-seksjon h2 {
    margin: 0 0 var(--s-3);
  }

  .bevis-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--s-3);
  }

  .mer {
    margin: var(--s-4) 0 0;
    font-size: 15px;
  }

  .pil {
    display: inline-block;
    transition: transform var(--dur-mikro) var(--ease);
  }

  .mer a:hover .pil,
  .mer a:focus-visible .pil {
    transform: translateX(3px);
  }
</style>
