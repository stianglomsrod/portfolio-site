---
import Side from '../layouts/Side.astro';
import Kontaktskjema from '../components/Kontaktskjema.astro';
import profil from '../data/profil.json';
import now from '../../now.json';

/* Om meg (v3): portrett, klartekst-bio og kontaktskjemaet.
   Copy er lo-fi til endelig tekst. */
---

<Side
  title="Om og kontakt — Stian Glomsrød"
  description="Hvem Stian er, hva han ser etter, og hvordan du tar kontakt."
>
  <p class="label kicker">Om meg</p>
  <h1>Om meg</h1>

  <div class="topp">
    <div class="bio">
      <p class="lead">
        Lektor med master i digitalt læringsdesign (OsloMet, 2026). Siden 2022
        har jeg jobbet aktivt mot et karrierebytte til tech-bransjen —
        gjennom studier, egne prosjekter og agentisk KI i daglig bruk.
      </p>
      <p>
        Jeg elsker å utvikle programmeringsferdighetene på gamlemåten,
        samtidig som jeg liker å utforske bruk av KI i utvikling.
      </p>
      <p class="bio-detalj">
        Det som står her kan du sjekke selv: lenkene går til kode, demoer og
        sertifikater.
      </p>
      <dl class="fakta" translate="no">
        <div><dt>sted:</dt><dd>Halden</dd></div>
        <div><dt>status:</dt><dd class="signal">søker {now.soker}</dd></div>
        <div><dt>svartid:</dt><dd>under et døgn</dd></div>
      </dl>
    </div>
    <img
      class="portrett"
      src="/bilder/stian-byste.jpg"
      alt="Stian Glomsrød smiler mot kamera, i svart pikéskjorte og caps"
      width="245"
      height="245"
      loading="eager"
    />
  </div>

  <section id="kontakt" aria-labelledby="kontakt-tittel">
    <h2 class="kontakt-tittel" id="kontakt-tittel">Ta kontakt</h2>
    <p class="kontakt-ingress">
      Jeg svarer innen et døgn. E-posten går til {profil.kontakt.epost}.
    </p>
    <Kontaktskjema />
  </section>
</Side>

<style>
  .kicker {
    font-family: var(--font-hd);
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    color: var(--dempet);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-4);
  }

  .topp {
    display: flex;
    gap: var(--s-6);
    align-items: flex-start;
    justify-content: space-between;
    max-width: 780px;
  }

  .bio {
    max-width: 52ch;
  }

  .bio p {
    margin: 0 0 var(--s-3);
    line-height: 1.6;
  }

  .lead {
    font-size: 18px;
  }

  .bio-detalj {
    color: var(--dempet);
  }

  .fakta {
    margin: var(--s-4) 0 0;
    font-family: var(--font-hd);
    font-size: 12px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .fakta div {
    display: flex;
    gap: var(--s-2);
  }

  .fakta dt {
    color: var(--dempet);
    width: 72px;
    flex-shrink: 0;
  }

  .fakta dd {
    margin: 0;
    color: var(--tekst);
  }

  .fakta .signal {
    color: var(--salvie);
  }

  /* Sirkelbyste til høyre — utsnittet er sentrert på ansiktet */
  .portrett {
    display: block;
    width: 230px;
    height: 230px;
    border-radius: 50%;
    border: 2px solid var(--linje);
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .topp {
      flex-direction: column-reverse;
    }
  }

  .kontakt-tittel {
    font-size: 18px;
    margin: var(--s-7) 0 var(--s-2);
  }

  .kontakt-ingress {
    color: var(--dempet);
    max-width: 68ch;
    margin: 0 0 var(--s-4);
  }
</style>
