---
import Side from '../layouts/Side.astro';
import Kontaktskjema from '../components/Kontaktskjema.astro';
import profil from '../data/profil.json';
import now from '../../now.json';

/* Om meg (v3): portrett, klartekst-bio og kontaktskjemaet.
   Copy er lo-fi til endelig tekst. */
---

<Side
  title="Om og kontakt — Stian Glomsrød"
  description="Hvem Stian er, hva han ser etter, og hvordan du tar kontakt."
>
  <p class="label kicker">Om meg</p>
  <h1>Om meg</h1>

  <div class="topp">
    <div class="bio">
      <p class="lead">
        Lektor med master i digital læringsdesign (OsloMet, 2026), på vei inn
        i utviklerrollen. Bygger ekte ting med agentisk KI og dokumenterer
        alt.
      </p>
      <p class="bio-detalj">
        Små påstander, tunge kvitteringer — det som står her skal kunne
        etterprøves ett klikk unna.
      </p>
      <dl class="fakta" translate="no">
        <div><dt>sted:</dt><dd>Halden / remote</dd></div>
        <div><dt>status:</dt><dd class="signal">søker {now.soker}</dd></div>
        <div><dt>svartid:</dt><dd>&lt; 24t</dd></div>
      </dl>
    </div>
    <figure class="portrett-ramme">
      <img
        class="portrett"
        src="/bilder/stian-byste.jpg"
        alt="Stian Glomsrød smiler mot kamera, i svart pikéskjorte og caps"
        width="360"
        height="380"
        loading="eager"
      />
      <figcaption>
        <span class="fig-markoer" aria-hidden="true"></span>
        stian.png · ekte foto, ingen filter
      </figcaption>
    </figure>
  </div>

  <section id="kontakt" aria-labelledby="kontakt-tittel">
    <h2 class="kontakt-tittel" id="kontakt-tittel">Ta kontakt</h2>
    <p class="kontakt-ingress">
      Jeg svarer innen et døgn. E-posten går til {profil.kontakt.epost} —
      ingenting lagres på veien.
    </p>
    <Kontaktskjema />
  </section>
</Side>

<style>
  .kicker {
    font-family: var(--font-hd);
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    color: var(--dempet);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-4);
  }

  .topp {
    display: flex;
    gap: var(--s-6);
    align-items: flex-start;
    justify-content: space-between;
    max-width: 780px;
  }

  .bio {
    max-width: 52ch;
  }

  .bio p {
    margin: 0 0 var(--s-3);
    line-height: 1.6;
  }

  .lead {
    font-size: 18px;
  }

  .bio-detalj {
    color: var(--dempet);
  }

  .fakta {
    margin: var(--s-4) 0 0;
    font-family: var(--font-hd);
    font-size: 12px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .fakta div {
    display: flex;
    gap: var(--s-2);
  }

  .fakta dt {
    color: var(--dempet);
    width: 72px;
    flex-shrink: 0;
  }

  .fakta dd {
    margin: 0;
    color: var(--tekst);
  }

  .fakta .signal {
    color: var(--salvie);
  }

  /* Byste til høyre, rammet som artefakt med mono-bildetekst */
  .portrett-ramme {
    margin: 0;
    flex-shrink: 0;
    width: 250px;
    background: var(--flate);
    border: 1px solid var(--linje);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .portrett {
    display: block;
    width: 100%;
    height: auto;
  }

  figcaption {
    display: flex;
    align-items: center;
    gap: var(--s-2);
    font-family: var(--font-hd);
    font-size: 10.5px;
    color: var(--dempet);
    padding: var(--s-2) var(--s-3);
    border-top: 1px solid var(--linje);
  }

  .fig-markoer {
    width: 7px;
    height: 13px;
    background: var(--salvie);
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .topp {
      flex-direction: column-reverse;
    }

    .portrett-ramme {
      width: min(100%, 300px);
    }
  }

  .kontakt-tittel {
    font-size: 18px;
    margin: var(--s-7) 0 var(--s-2);
  }

  .kontakt-ingress {
    color: var(--dempet);
    max-width: 68ch;
    margin: 0 0 var(--s-4);
  }
</style>
