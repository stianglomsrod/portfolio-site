---
import Side from '../layouts/Side.astro';
import Kontaktskjema from '../components/Kontaktskjema.astro';
import profil from '../data/profil.json';
import now from '../../now.json';

/* Om/kontakt: portrett (ekte foto, ingen filter), STIAN(1)-manside og
   kontaktskjemaet. Copy er lo-fi til endelig tekst. */
---

<Side
  title="Om og kontakt — Stian Glomsrød"
  description="Hvem Stian er, hva han ser etter, og hvordan du tar kontakt."
>
  <p class="kicker">OM / KONTAKT</p>
  <h1>Om og kontakt</h1>

  <div class="topp">
    <div class="bio">
      <p class="lead">
        Lektor med master i digital læringsdesign (OsloMet, 2026), på vei inn
        i utviklerrollen. Bygger ekte ting med agentisk KI og dokumenterer
        alt.
      </p>
      <p class="bio-detalj">
        Små påstander, tunge kvitteringer — det som står her skal kunne
        etterprøves ett klikk unna.
      </p>
      <dl class="fakta" translate="no">
        <div><dt>sted:</dt><dd>Halden / remote</dd></div>
        <div><dt>status:</dt><dd class="signal">søker {now.soker}</dd></div>
        <div><dt>svartid:</dt><dd>&lt; 24t</dd></div>
      </dl>
    </div>
    <figure class="portrett-ramme">
      <img
        class="portrett"
        src="/bilder/stian-byste.jpg"
        alt="Stian Glomsrød smiler mot kamera, i svart pikéskjorte og caps"
        width="360"
        height="380"
        loading="eager"
      />
      <figcaption>
        <span class="fig-markoer" aria-hidden="true"></span>
        stian.png · ekte foto, ingen filter
      </figcaption>
    </figure>
  </div>

  <section class="manside" aria-label="STIAN(1) — manside" translate="no">
    <div class="man-hode" aria-hidden="true">
      <span>STIAN(1)</span><span>Brukerhåndbok</span><span>STIAN(1)</span>
    </div>
    <div class="man-seksjon">
      <h2>NAVN</h2>
      <p>stian — lærer i overgang til utvikler. halden edition.</p>
    </div>
    <div class="man-seksjon">
      <h2>SYNOPSIS</h2>
      <p>stian [--utvikler] [--ux] [--ai-first] <span class="konst">--tilgjengelig=nå</span></p>
    </div>
    <div class="man-seksjon">
      <h2>BESKRIVELSE</h2>
      <p>
        Master i digital læringsdesign (OsloMet, 2026). Bygger ekte ting med
        agentisk KI og dokumenterer alt. Søker {now.soker}. Små påstander,
        tunge kvitteringer.
      </p>
    </div>
    <div class="man-seksjon">
      <h2>EXIT STATUS</h2>
      <p>Returnerer 0 ved ansettelse.</p>
    </div>
    <div class="man-seksjon">
      <h2>SE OGSÅ</h2>
      <p>
        <a href="/prosjekter#klar">klar(1)</a>,
        <a href="/prosjekter">companion(1)</a>,
        <a href="/sandbox">sandbox(7)</a>
      </p>
    </div>
  </section>

  <section id="kontakt" aria-labelledby="kontakt-tittel">
    <h2 class="kontakt-tittel" id="kontakt-tittel">Ta kontakt</h2>
    <p class="kontakt-ingress">
      Svarer innen 24 timer på hverdager. E-post går til
      {profil.kontakt.epost} — ingenting lagres på veien.
    </p>
    <Kontaktskjema />
  </section>
</Side>

<style>
  .kicker {
    font-family: var(--font-mono);
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    color: var(--dempet);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-4);
  }

  .topp {
    display: flex;
    gap: var(--s-6);
    align-items: flex-start;
    justify-content: space-between;
    max-width: 780px;
  }

  .bio {
    max-width: 52ch;
  }

  .bio p {
    margin: 0 0 var(--s-3);
    line-height: 1.6;
  }

  .lead {
    font-size: 18px;
  }

  .bio-detalj {
    color: var(--dempet);
  }

  .fakta {
    margin: var(--s-4) 0 0;
    font-family: var(--font-mono);
    font-size: 12px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .fakta div {
    display: flex;
    gap: var(--s-2);
  }

  .fakta dt {
    color: var(--dempet);
    width: 72px;
    flex-shrink: 0;
  }

  .fakta dd {
    margin: 0;
    color: var(--tekst);
  }

  .fakta .signal {
    color: var(--signal);
  }

  /* Byste til høyre, rammet som artefakt med mono-bildetekst */
  .portrett-ramme {
    margin: 0;
    flex-shrink: 0;
    width: 250px;
    background: var(--flate);
    border: 1px solid var(--linje);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .portrett {
    display: block;
    width: 100%;
    height: auto;
  }

  figcaption {
    display: flex;
    align-items: center;
    gap: var(--s-2);
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--dempet);
    padding: var(--s-2) var(--s-3);
    border-top: 1px solid var(--linje);
  }

  .fig-markoer {
    width: 7px;
    height: 13px;
    background: var(--signal);
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .topp {
      flex-direction: column-reverse;
    }

    .portrett-ramme {
      width: min(100%, 300px);
    }
  }

  /* STIAN(1) — manside på terminalflaten (ankeret, identisk i begge temaer) */
  .manside {
    background: var(--terminal);
    border: 1px solid var(--linje);
    border-radius: var(--radius-md);
    padding: var(--s-4) var(--s-5);
    margin-top: var(--s-6);
    max-width: 640px;
    font-family: var(--font-mono);
    font-size: 12.5px;
    line-height: 1.85;
    color: var(--kode-tekst);
  }

  .man-hode {
    display: flex;
    justify-content: space-between;
    color: var(--syn-komm);
    font-size: 11px;
    margin-bottom: var(--s-3);
  }

  .man-seksjon h2 {
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--term-groenn);
    margin: var(--s-3) 0 0;
    font-weight: 600;
  }

  .man-seksjon p {
    margin: 0;
    padding-left: 4ch;
    max-width: 60ch;
  }

  .konst {
    color: var(--syn-konst);
  }

  .man-seksjon a {
    color: var(--syn-fn);
  }

  @media (max-width: 560px) {
    .man-seksjon p {
      padding-left: 2ch;
    }
  }

  .kontakt-tittel {
    font-size: 18px;
    margin: var(--s-7) 0 var(--s-2);
  }

  .kontakt-ingress {
    color: var(--dempet);
    max-width: 68ch;
    margin: 0 0 var(--s-4);
  }
</style>
