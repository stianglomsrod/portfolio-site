---
import Side from '../layouts/Side.astro';
import Kontaktskjema from '../components/Kontaktskjema.astro';

/* Skjelett: bygges ut med portrett og STIAN(1)-manside. Kontaktskjemaet
   (Done 8) er på plass. */
---

<Side
  title="Om og kontakt — Stian Glomsrød"
  description="Hvem Stian er, og hvordan du tar kontakt."
>
  <p class="kicker">OM / KONTAKT</p>
  <h1>Om og kontakt</h1>
  <p class="dempet">
    Lærer med master i digital læringsdesign (OsloMet, 2026), på vei inn i
    utviklerrollen. Portrett, STIAN(1)-mansiden og mer kommer her.
  </p>
  <section id="kontakt" aria-labelledby="kontakt-tittel">
    <h2 id="kontakt-tittel">Ta kontakt</h2>
    <Kontaktskjema />
  </section>
</Side>

<style>
  .kicker {
    font-family: var(--font-mono);
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    color: var(--dempet);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-3);
  }

  .dempet {
    color: var(--dempet);
    max-width: 68ch;
  }
</style>
