---
import Side from '../layouts/Side.astro';
import ProsjektKort from '../components/ProsjektKort.astro';
import prosjekter from '../data/prosjekter.json';

/* Case-format fra briefen: problem → innsikt → valg → resultat → læring.
   Klar er hovedcase. Lori Frisør vises på plassholdernivå (= dagens
   offentlige nivå: navn + stack + lenker, ingen skjermbilder) til skriftlig
   godkjenning er arkivert (Done 19). Copy er lo-fi til endelig tekst. */

const klarSteg = [
  {
    steg: 'problem',
    tekst:
      'Lærere bruker kvelder på å oversette ukeplaner og beskjeder til noe elever med eksekutive vansker faktisk kan bruke. Verktøyene som finnes krever mer struktur enn skolehverdagen har.',
  },
  {
    steg: 'innsikt',
    tekst:
      'Fra deltakende design med lærere: lav terskel og tidssparing avgjør om noe blir brukt; hjelp må skje uten stigma; motivasjon må ikke bli press. Behovene ble kartlagt i workshops — lærerne var meddesignere.',
  },
  {
    steg: 'valg',
    tekst:
      'Responsiv PWA (React, Next.js, TypeScript, Supabase/PostgreSQL) med rollebasert tilgang — lærer og elev på samme datalag. Smart Import: AI-assistert import av ukebrev med redigerbar forhåndsvisning, så et menneske alltid godkjenner før noe publiseres.',
  },
  {
    steg: 'resultat',
    tekst:
      'Fungerende prototype, evaluert med lærere. Designvitenskapelig utviklingsarbeid, ikke effektstudie — elever deltok kun i forløperprosjektet.',
  },
  {
    steg: 'læring',
    tekst:
      'Prototype og produksjonssystem er to ulike ting, og AI i produktet krever et menneskelig kontrollpunkt. Avgrensningene her står med vilje.',
  },
];

const klarBilder = [
  { fil: '/bilder/klar/smart-import.png', alt: 'Skjermbilde av Smart Import i Klar: ukebrev er tolket til en redigerbar forhåndsvisning før publisering' },
  { fil: '/bilder/klar/laererens-landingsside.png', alt: 'Skjermbilde av lærerens landingsside i Klar med oversikt over klasser og oppgaver' },
  { fil: '/bilder/klar/elevens-landingsside.png', alt: 'Skjermbilde av elevens landingsside i Klar med dagens plan' },
];
---

<Side
  title="Prosjekter — Stian Glomsrød"
  description="Case: Klar, Companion, Lori Frisør og forløperne — problem, innsikt, valg, resultat, læring."
>
  <p class="kicker">Prosjekter</p>
  <h1>Prosjekter</h1>
  <p class="ingress">
    Samme arbeidsmåte går igjen i ganske ulike leveranser: et produkt, en
    langvarig utviklingsflyt og en overlevering til en kunde.
  </p>
  <p class="format" aria-hidden="true">
    problem <span>→</span> innsikt <span>→</span> valg <span>→</span> resultat
    <span>→</span> læring
  </p>

  <section class="hovedcase" id="klar" aria-labelledby="klar-tittel">
    <p class="case-tag">Hovedcase · Masterprosjekt · 2026</p>
    <h2 id="klar-tittel">Klar</h2>
    <p class="case-ingress">
      Digitalt hjelpemiddel for elever med eksekutive vansker, bygd med
      participatory design som metode.
    </p>
    <dl class="steg-liste">
      {klarSteg.map((s) => (
        <div class="steg">
          <dt>{s.steg}</dt>
          <dd>{s.tekst}</dd>
        </div>
      ))}
    </dl>
    <div class="galleri">
      {klarBilder.map((b, i) => (
        <button
          type="button"
          class="galleri-knapp"
          data-bilde={i}
          aria-label={`Vis større bilde: ${b.alt}`}
        >
          <img src={b.fil} alt={b.alt} loading="lazy" width="1920" height="871" />
        </button>
      ))}
    </div>
    <dialog id="lysboks" aria-label="Bildevisning">
      <button type="button" class="lb-knapp lb-lukk" data-lukk aria-label="Lukk bildevisningen">✕</button>
      <button type="button" class="lb-knapp lb-forrige" data-forrige aria-label="Forrige bilde">←</button>
      <figure class="lb-figur">
        <img id="lysboks-bilde" src="" alt="" />
        <figcaption>
          <span id="lysboks-tekst"></span>
          <span id="lysboks-teller" class="lb-teller"></span>
        </figcaption>
      </figure>
      <button type="button" class="lb-knapp lb-neste" data-neste aria-label="Neste bilde">→</button>
    </dialog>
    <p class="testbruker">
      Demoen har innlogging. Ta kontakt, så gir jeg deg en testbruker.
    </p>
    <p class="case-lenker">
      <a href={prosjekter.klar.demo} class="primaer" rel="noreferrer noopener">demo <span class="pil" aria-hidden="true">→</span></a>
      <a href={prosjekter.klar.repo} rel="noreferrer noopener">repo <span class="pil" aria-hidden="true">→</span></a>
    </p>
  </section>

  <section class="andre" aria-label="Flere prosjekter">
    <div class="kort-grid">
      <ProsjektKort
        tag="Dokumentert utviklingsflyt"
        tittel="Companion"
        tekst={prosjekter.companion.stack}
        note={prosjekter.companion.beskrivelse}
        lenker={[{ href: prosjekter.companion.repo, label: 'repo' }]}
      />
      <ProsjektKort
        tag="Overlevert til eier"
        tittel={prosjekter.lori.navn}
        tekst={prosjekter.lori.stack}
        note={prosjekter.lori.beskrivelse}
        lenker={[
          { href: prosjekter.lori.url, label: 'nettstedet', primaer: true },
          { href: prosjekter.lori.repo, label: 'repo' },
        ]}
      />
      <ProsjektKort
        tag="Forløperen til Klar"
        tittel={prosjekter.pdApp.navn}
        tekst={prosjekter.pdApp.beskrivelse}
        note="132 commits skrevet for hånd, før agentiske verktøy — et ekte tidsdokument."
        lenker={[
          { href: prosjekter.pdApp.frontend, label: 'frontend' },
          { href: prosjekter.pdApp.backend, label: 'backend' },
        ]}
      />
      <ProsjektKort
        tag="Grunnmuren"
        tittel="CS50x + Ordkryss"
        tekst={prosjekter.cs50x.beskrivelse}
        note="Sluttprosjektet: et kryssord som genereres og fylles ut. Et lite, ekte studentprosjekt."
        lenker={[
          { href: prosjekter.cs50x.sertifikat, label: 'sertifikat' },
          { href: prosjekter.cs50x.ordkryssDemo, label: 'demo' },
        ]}
      />
      <ProsjektKort
        tag="Bygget i åpen dialog med Claude"
        tittel={prosjekter.denneSiden.navn}
        tekst={prosjekter.denneSiden.beskrivelse}
        lenker={[
          { href: prosjekter.denneSiden.repo, label: 'repo' },
          { href: '/kolofon', label: 'slik ble siden til' },
        ]}
      />
      <ProsjektKort
        tag="Fremtidig startup"
        tittel={prosjekter.claudeFirst.navn}
        tekst={prosjekter.claudeFirst.beskrivelse}
        lenker={[{ href: prosjekter.claudeFirst.url, label: 'nettstedet' }]}
      />
    </div>
  </section>

  <p class="grense">
    Eksemplene viser arbeidsmåte og tekniske vurderinger, i prototypeskala.
  </p>
</Side>

<style>
  .kicker {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--dempet);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-3);
  }

  .ingress {
    color: var(--dempet);
    max-width: 68ch;
    margin: 0;
  }

  .format {
    font-family: var(--font-hd);
    font-size: 14px;
    color: var(--dempet);
    margin: var(--s-3) 0 0;
  }

  .format span {
    color: var(--dempet);
  }

  /* Fyller ramma — samme kant som kortgrid-en under, ingen sprikende
     høyrekanter mellom seksjonene. Tekstbredden begrenses per avsnitt. */
  .hovedcase {
    background: var(--flate);
    border: 1px solid var(--linje);
    border-radius: var(--radius-lg);
    box-shadow: var(--kort-skygge);
    padding: var(--s-5);
    margin-top: var(--s-6);
  }

  .case-tag {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: 12.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--dempet);
    margin: 0 0 var(--s-2);
  }

  h2 {
    font-size: 24px;
    margin: 0 0 var(--s-1);
  }

  .case-ingress {
    color: var(--dempet);
    margin: 0 0 var(--s-4);
  }

  .steg-liste {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }

  .steg {
    display: grid;
    grid-template-columns: 92px 1fr;
    gap: var(--s-3);
  }

  .steg dt {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: 12.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--dempet);
  }

  .steg dd {
    margin: 0;
    font-size: 15.5px;
    line-height: 1.6;
    color: var(--tekst);
    max-width: 62ch;
  }

  @media (max-width: 680px) {
    .steg {
      grid-template-columns: 1fr;
      gap: var(--s-1);
    }
  }

  .galleri {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--s-2);
    margin-top: var(--s-4);
  }

  .galleri-knapp {
    all: unset;
    cursor: pointer;
    border-radius: var(--radius-sm);
    transition: transform 160ms var(--ease);
  }

  .galleri-knapp:hover,
  .galleri-knapp:focus-visible {
    transform: scale(1.02);
  }

  .galleri-knapp:focus-visible {
    outline: 2px solid var(--salvie);
    outline-offset: 2px;
  }

  .galleri img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
    border: 1px solid var(--linje);
  }

  /* Lysboks: native <dialog> gir fokusfelle og Esc-lukking gratis */
  #lysboks {
    background: var(--bg);
    border: 1px solid var(--linje);
    border-radius: var(--radius-lg);
    padding: var(--s-5);
    max-width: min(92vw, 1200px);
    color: var(--tekst);
  }

  #lysboks::backdrop {
    background: rgba(10, 13, 12, 0.82);
  }

  .lb-figur {
    margin: 0;
  }

  #lysboks-bilde {
    display: block;
    max-width: 100%;
    max-height: 74vh;
    border-radius: var(--radius-sm);
    border: 1px solid var(--linje);
  }

  .lb-figur figcaption {
    display: flex;
    justify-content: space-between;
    gap: var(--s-4);
    margin-top: var(--s-3);
    font-size: 15px;
    color: var(--dempet);
  }

  .lb-teller {
    flex-shrink: 0;
  }

  .lb-knapp {
    all: unset;
    position: absolute;
    min-width: 44px;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    color: var(--tekst);
    background: var(--flate);
    border: 1px solid var(--linje);
    border-radius: 50%;
    cursor: pointer;
  }

  .lb-knapp:hover {
    border-color: var(--dempet);
  }

  .lb-knapp:focus-visible {
    outline: 2px solid var(--salvie);
    outline-offset: 2px;
  }

  .lb-lukk {
    top: var(--s-3);
    right: var(--s-3);
  }

  .lb-forrige {
    left: var(--s-3);
    top: 50%;
    transform: translateY(-50%);
  }

  .lb-neste {
    right: var(--s-3);
    top: 50%;
    transform: translateY(-50%);
  }

  .testbruker {
    font-size: 15px;
    color: var(--tekst);
    margin: var(--s-4) 0 0;
  }

  .case-lenker {
    display: flex;
    gap: var(--s-4);
    margin: var(--s-2) 0 0;
    font-family: var(--font-hd);
    font-size: 15px;
  }

  .case-lenker a {
    text-decoration: none;
  }

  .case-lenker a:hover,
  .case-lenker a:focus-visible {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .pil {
    display: inline-block;
    transition: transform var(--dur-mikro) var(--ease);
  }

  .case-lenker a:hover .pil,
  .case-lenker a:focus-visible .pil {
    transform: translateX(3px);
  }

  .case-lenker .primaer {
    color: var(--salvie);
  }

  .kort-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--s-3);
    margin-top: var(--s-4);
  }

  .grense {
    font-size: 15px;
    color: var(--dempet);
    margin-top: var(--s-5);
  }
</style>

<script>
  // Lysboks med frem/tilbake: <dialog> gir fokusfelle og Esc; piltaster
  // og knapper blar med wrap-around.
  const dialog = document.getElementById('lysboks') as HTMLDialogElement | null;
  const bildeEl = document.getElementById('lysboks-bilde') as HTMLImageElement | null;
  const tekstEl = document.getElementById('lysboks-tekst');
  const tellerEl = document.getElementById('lysboks-teller');
  const knapper = [...document.querySelectorAll<HTMLButtonElement>('.galleri-knapp')];
  const bilder = knapper.map((k) => {
    const img = k.querySelector('img');
    return { src: img?.getAttribute('src') ?? '', alt: img?.alt ?? '' };
  });

  let aktiv = 0;

  const vis = (indeks: number) => {
    aktiv = (indeks + bilder.length) % bilder.length;
    const b = bilder[aktiv];
    if (bildeEl) {
      bildeEl.src = b.src;
      bildeEl.alt = b.alt;
    }
    if (tekstEl) tekstEl.textContent = b.alt;
    if (tellerEl) tellerEl.textContent = `${aktiv + 1} av ${bilder.length}`;
  };

  knapper.forEach((k, i) =>
    k.addEventListener('click', () => {
      vis(i);
      dialog?.showModal();
    })
  );

  dialog?.querySelector('[data-lukk]')?.addEventListener('click', () => dialog.close());
  dialog?.querySelector('[data-forrige]')?.addEventListener('click', () => vis(aktiv - 1));
  dialog?.querySelector('[data-neste]')?.addEventListener('click', () => vis(aktiv + 1));

  dialog?.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') vis(aktiv - 1);
    if (e.key === 'ArrowRight') vis(aktiv + 1);
  });

  // Klikk på bakteppet lukker (klikk inne i dialogboksen treffer barn-elementer)
  dialog?.addEventListener('click', (e) => {
    if (e.target === dialog) dialog.close();
  });
</script>
