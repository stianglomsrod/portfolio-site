---
import Side from '../layouts/Side.astro';
import now from '../data/now.json';
import { hentSisteCommits } from '../lib/github';

/* Reisen v3: kuraterte milepæler + GitHub-aktivitet oversatt til klartekst —
   aldri rå commit-meldinger eller hasher. Erstatter CHANGELOG-formatet. */

const commits = await hentSisteCommits(4);

function klartekst(repo: string): string {
  if (repo.includes('portfolio-site') || repo.includes('stianglomsrod-no'))
    return 'Jobbet med denne siden';
  if (repo.includes('klar')) return 'Jobbet videre på Klar';
  if (repo.includes('nikkoprogging')) return 'Ryddet i Companion-appen';
  if (repo.includes('pd-app')) return 'Rørte ved forløperen til Klar';
  if (repo.includes('lori')) return 'Fulgte opp Lori Frisør-siden';
  return `Jobbet med ${repo.split('/')[1] ?? repo}`;
}

// Slå sammen like naboer («Jobbet med denne siden» × 3 → én oppføring)
const aktivitet = commits
  .map((c) => ({ tekst: klartekst(c.repo), tidspunkt: c.tidspunkt }))
  .filter((rad, i, alle) => i === 0 || rad.tekst !== alle[i - 1].tekst)
  .slice(0, 3);

const milepaeler = [
  { naar: 'nå', tekst: `I gang med ${now.kursStatus} i ${now.kurs}, og ${now.ki} med ${now.kiVerktoy}.`, levende: true },
  { naar: 'fra august', tekst: 'Blir også IKT-kontakt på Kongeveien skole.' },
  { naar: 'juni 2026', tekst: 'Leverte masteroppgaven. Klar sto ferdig som fungerende prototype.' },
  { naar: 'underveis i masteren', tekst: 'Bygde pd-app, forløperen til Klar: 132 commits skrevet for hånd.' },
  { naar: '2024', tekst: 'Fullførte CS50x hos Harvard. Ordkryss som sluttprosjekt.' },
  { naar: '2018', tekst: 'Lærer på Kongeveien skole — tok programmeringen inn i klasserommet.' },
  { naar: '2007', tekst: 'Introduksjon til objektorientert programmering i Java og spillprogrammering i Flash.' },
];
---

<Side
  title="Reisen — Stian Glomsrød"
  description="Kuraterte milepæler og levende aktivitet, i klartekst."
>
  <p class="label kicker">Reisen</p>
  <h1>Reisen</h1>
  <p class="ingress">
    Det som skjer nå, og veien hit. Aktiviteten hentes fra GitHub og
    oversettes til klartekst.
  </p>

  <section aria-labelledby="siste-tittel" class="blokk">
    <h2 class="label" id="siste-tittel">Siste oppføringer</h2>
    <ul class="liste">
      {aktivitet.map((rad) => (
        <li>
          <span class="tekst levende-rad">{rad.tekst}</span>
          <span class="naar" data-tidspunkt={rad.tidspunkt} data-parens="nei">
            {new Date(rad.tidspunkt).toLocaleDateString('nb-NO', { day: 'numeric', month: 'short' })}
          </span>
        </li>
      ))}
      {milepaeler.map((m) => (
        <li>
          <span class:list={['tekst', { 'levende-rad': m.levende }]}>{m.tekst}</span>
          <span class="naar">{m.naar}</span>
        </li>
      ))}
    </ul>
  </section>
</Side>

<style>
  .kicker {
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-3);
  }

  .ingress {
    color: var(--dempet);
    max-width: 66ch;
    margin: 0;
  }

  .blokk {
    background: var(--flate);
    border: 1px solid var(--linje);
    border-radius: var(--radius-lg);
    box-shadow: var(--kort-skygge);
    padding: var(--s-4) var(--s-5);
    margin-top: var(--s-5);
    max-width: 720px;
  }

  .blokk h2 {
    margin: 0 0 var(--s-2);
  }

  .liste {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .liste li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--s-4);
    padding: var(--s-3) 0;
    border-bottom: 1px solid var(--linje);
  }

  .liste li:last-child {
    border-bottom: none;
  }

  .tekst {
    font-size: 16px;
    line-height: 1.55;
    max-width: 52ch;
  }

  /* Salvie kun om det levende: rader drevet av now.json/GitHub */
  .levende-rad {
    color: var(--salvie);
  }

  .naar {
    font-size: 14px;
    color: var(--dempet);
    flex-shrink: 0;
  }
</style>

<script>
  import { settRelativeTider } from '../lib/relativ-tid';

  settRelativeTider();
</script>
