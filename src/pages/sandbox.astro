---
import Side from '../layouts/Side.astro';
import HueVelger from '../components/HueVelger.astro';

/* Verkstedet. Hue-parameteren bor her (og på 404).
   ENGELSK TVILLING: src/pages/en/sandbox.astro — endre begge. */
---

<Side
  title="/sandbox — Stian Glomsrød"
  description="Verkstedet: eksperimenter, verktøy og spillet «Skamløs pitch»."
>
  <p class="kicker">/sandbox</p>
  <h1>Sandbox</h1>
  <p class="dempet">
    Verkstedet mitt. Her dukker det opp alt fra ferdige til uferdige ting.
  </p>

  <div class="eks-grid">
    <a class="eksperiment" href="/sandbox/skamlos-pitch">
      <span class="eks-tag">Spill</span>
      <span class="eks-tittel">Skamløs Pitch: Kompetansebyen</span>
      <span class="eks-tekst">
        Et lite topp-ned-RPG om å bygge kompetanse. Spillet leser de samme
        datakildene som resten av siden.
      </span>
      <span class="eks-cta">spill <span class="pil" aria-hidden="true">→</span></span>
    </a>

    <a class="eksperiment" href="/sandbox/ordkryss">
      <span class="eks-tag">Verktøy</span>
      <span class="eks-tittel">Ordkryss</span>
      <span class="eks-tekst">
        Ordletingsark til utskrift, for lærere: tre retninger, bilder per
        ord, fasit og bannordfilter.
      </span>
      <span class="eks-cta">lag et ark <span class="pil" aria-hidden="true">→</span></span>
    </a>

    <a class="eksperiment" href="/sandbox/silhuett">
      <span class="eks-tag">Verktøy</span>
      <span class="eks-tittel">Silhuetter</span>
      <span class="eks-tekst">
        Skriveark til utskrift: elevene fyller bokstavene inn i ordets
        silhuett. Valgfritt bilde og ordbank.
      </span>
      <span class="eks-cta">lag et ark <span class="pil" aria-hidden="true">→</span></span>
    </a>

    <a class="eksperiment" href="/sandbox/ordbingo">
      <span class="eks-tag">Verktøy</span>
      <span class="eks-tittel">Ordbingo</span>
      <span class="eks-tekst">
        Unike bingobrett til hele klassen, til utskrift: velg brettstørrelse
        og antall. Valgfrie bilder og trekkelapper.
      </span>
      <span class="eks-cta">lag brett <span class="pil" aria-hidden="true">→</span></span>
    </a>

    <div class="full-rad">
      <HueVelger lang="nb" />
    </div>
  </div>
</Side>

<style>
  .kicker {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--hue-aksent);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-3);
  }

  .dempet {
    color: var(--dempet);
    max-width: 68ch;
  }

  /* Delt spor-regel: to spor som de fire kortene fyller i to hele rader,
     og modulen spenner hele raden — alle høyrekanter deler dermed samme
     kant. (auto-fit fungerte ikke her: raden med full-rad-elementet holdt
     et tomt spor i live, så kortene stoppet før kanten.) Håndheves av
     _baseline/qa/kant-sjekk.mjs. */
  .eks-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--s-3);
    margin-top: var(--s-5);
  }

  .full-rad {
    grid-column: 1 / -1;
  }

  @media (max-width: 900px) {
    .eks-grid {
      grid-template-columns: 1fr;
    }
  }

  .eksperiment {
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
    background: var(--flate);
    border: 1px solid var(--linje);
    border-radius: var(--radius-md);
    box-shadow: var(--kort-skygge);
    padding: var(--s-4) var(--s-4);
    text-decoration: none;
    transition: border-color 160ms, transform 160ms var(--ease), box-shadow 160ms var(--ease);
  }

  .eksperiment:hover,
  .eksperiment:focus-visible {
    border-color: var(--salvie);
    transform: translateY(-3px);
    box-shadow: var(--kort-skygge-hover);
  }

  .eks-tag {
    font-family: var(--font-hd);
    font-size: 12.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--hue-aksent);
  }

  .eks-tittel {
    font-size: 19px;
    font-weight: 700;
    color: var(--tekst);
  }

  .eks-tekst {
    font-size: 15.5px;
    line-height: 1.5;
    color: var(--dempet);
  }

  .eks-cta {
    font-family: var(--font-hd);
    font-size: 14.5px;
    color: var(--salvie);
    margin-top: auto;
  }

  .pil {
    display: inline-block;
    transition: transform var(--dur-mikro) var(--ease);
  }

  .eksperiment:hover .pil,
  .eksperiment:focus-visible .pil {
    transform: translateX(3px);
  }
</style>
