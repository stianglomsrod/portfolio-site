---
import Side from '../../layouts/Side.astro';
import AlfabetiseringVerktoy from '../../components/AlfabetiseringVerktoy.astro';

/* Alfabetisk rekkefølge i sandbox. ENGELSK TVILLING:
   src/pages/en/sandbox/abc-order.astro — endre begge. */
---

<Side
  title="Alfabetisk rekkefølge — lag sorteringsark til utskrift"
  description="Elevene skriver ordene i alfabetisk rekkefølge — æ, ø og å sorteres riktig i fasiten."
>
  <div class="al-side-hode">
    <p class="kicker">/sandbox · verktøy</p>
    <h1>Alfabetisk rekkefølge</h1>
    <p class="dempet">
      Lag sorteringsark: skriv inn ordene, og arket viser dem stokket med nummererte skrivelinjer under. Fasiten sorterer riktig — også æ, ø og å.
    </p>
  </div>
  <AlfabetiseringVerktoy lang="nb" />
</Side>

<style>
  .kicker {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--hue-aksent);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-3);
  }

  .dempet {
    color: var(--dempet);
    max-width: 68ch;
    margin: 0;
  }
</style>
