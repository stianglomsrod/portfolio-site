---
import Side from '../../layouts/Side.astro';
import GangetabellVerktoy from '../../components/GangetabellVerktoy.astro';

/* Gangetabellen i sandbox. ENGELSK TVILLING:
   src/pages/en/sandbox/times-tables.astro — endre begge. */
---

<Side
  title="Gangetabellen — lag utfyllingsark til utskrift"
  description="10 × 10-tabellen som utfyllingsark — tom eller delvis utfylt, med fasit."
>
  <div class="ga-side-hode">
    <p class="kicker">/sandbox · verktøy</p>
    <h1>Gangetabellen</h1>
    <p class="dempet">
      Lag gangetabell-ark: hele 10 × 10-tabellen som utfyllingsark, tom eller med en del av svarene på plass. Fasiten fyller alt.
    </p>
  </div>
  <GangetabellVerktoy lang="nb" />
</Side>

<style>
  .kicker {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--hue-aksent);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-3);
  }

  .dempet {
    color: var(--dempet);
    max-width: 68ch;
    margin: 0;
  }
</style>
