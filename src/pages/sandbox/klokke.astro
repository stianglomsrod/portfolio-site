---
import Side from '../../layouts/Side.astro';
import KlokkeVerktoy from '../../components/KlokkeVerktoy.astro';

/* Klokka i sandbox. ENGELSK TVILLING:
   src/pages/en/sandbox/clock.astro — endre begge. */
---

<Side
  title="Klokka — lag klokkeark til utskrift"
  description="Urskiver med visere å lese av — eller tomme skiver der elevene tegner viserne selv."
>
  <div class="kl-side-hode">
    <p class="kicker">/sandbox · verktøy</p>
    <h1>Klokka</h1>
    <p class="dempet">
      Lag klokkeark: velg om elevene skal lese av klokka eller tegne viserne, og hvor fin presisjonen skal være — hele timer, halve, kvarter eller femminutter. Fasit følger med.
    </p>
  </div>
  <KlokkeVerktoy lang="nb" />
</Side>

<style>
  .kicker {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--hue-aksent);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-3);
  }

  .dempet {
    color: var(--dempet);
    max-width: 68ch;
    margin: 0;
  }
</style>
