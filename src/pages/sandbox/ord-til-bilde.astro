---
import Side from '../../layouts/Side.astro';
import OrdTilBildeVerktoy from '../../components/OrdTilBildeVerktoy.astro';

/* Ord og bilde i sandbox. ENGELSK TVILLING:
   src/pages/en/sandbox/word-match.astro — endre begge. */
---

<Side
  title="Ord og bilde — lag koblingsark til utskrift"
  description="Ord i én kolonne, bilder i stokket rekkefølge i den andre — eleven trekker strek. Fasiten tegner strekene."
>
  <div class="ob-side-hode">
    <p class="kicker">/sandbox · verktøy</p>
    <h1>Ord og bilde</h1>
    <p class="dempet">
      Lag koblingsark: skriv ordene og lim på et bilde per ord (Ctrl + V). Arket viser ordene til venstre og bildene stokket til høyre — eleven trekker strek. Fasit-utskriften tegner strekene.
    </p>
  </div>
  <OrdTilBildeVerktoy lang="nb" />
</Side>

<style>
  .kicker {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--hue-aksent);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-3);
  }

  .dempet {
    color: var(--dempet);
    max-width: 68ch;
    margin: 0;
  }
</style>
