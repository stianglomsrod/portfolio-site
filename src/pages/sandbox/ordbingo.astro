---
import Side from '../../layouts/Side.astro';
import OrdbingoVerktoy from '../../components/OrdbingoVerktoy.astro';

/* Ordbingo i sandbox: unike bingobrett fra en ordliste, til utskrift.
   ENGELSK TVILLING: src/pages/en/sandbox/word-bingo.astro — endre begge. */
---

<Side
  title="Ordbingo — lag bingobrett til utskrift"
  description="Skriv inn ordene det spilles med, og få unike bingobrett til hele klassen — med valgfrie bilder og trekkelapper til å klippe opp."
>
  <div class="bi-side-hode">
    <p class="kicker">/sandbox · verktøy</p>
    <h1>Ordbingo</h1>
    <p class="dempet">
      Lag bingobrett til utskrift: skriv inn ordene det spilles med, velg
      brettstørrelse og antall, og verktøyet trekker unike brett til hele
      klassen — to per side med klippelinje. Bilde per ord og trekkelapper
      er valgfritt.
    </p>
  </div>
  <OrdbingoVerktoy lang="nb" />
</Side>

<style>
  .kicker {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--hue-aksent);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-3);
  }

  .dempet {
    color: var(--dempet);
    max-width: 68ch;
    margin: 0;
  }
</style>
