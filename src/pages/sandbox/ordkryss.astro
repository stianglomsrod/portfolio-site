---
import Side from '../../layouts/Side.astro';
import OrdkryssVerktoy from '../../components/OrdkryssVerktoy.astro';

/* Ordkryss i sandbox: ordletingsark til utskrift, for lærere.
   ENGELSK TVILLING: src/pages/en/sandbox/wordsearch.astro — endre begge. */
---

<Side
  title="Ordkryss — lag ordletingsark til utskrift"
  description="Skriv inn ordene elevene skal finne, velg retninger, skriv ut. Med bilder per ord, fasit og bannordfilter."
>
  <div class="ok-side-hode">
    <p class="kicker">/sandbox · verktøy</p>
    <h1>Ordkryss</h1>
    <p class="dempet">
      Lag ordletingsark til utskrift: skriv inn ordene elevene skal finne,
      velg retninger og trykk skriv ut.
    </p>
  </div>
  <OrdkryssVerktoy lang="nb" />
</Side>

<style>
  .kicker {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--hue-aksent);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-3);
  }

  .dempet {
    color: var(--dempet);
    max-width: 68ch;
    margin: 0;
  }
</style>
