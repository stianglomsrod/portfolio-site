---
import Side from '../../layouts/Side.astro';
import SporingVerktoy from '../../components/SporingVerktoy.astro';

/* Sporing i sandbox. ENGELSK TVILLING:
   src/pages/en/sandbox/tracing.astro — endre begge. */
---

<Side
  title="Sporing — lag skriftformingsark for håndskrift"
  description="Bokstaver i bokstavhus med grønt startpunkt og retningspiler på utsiden — modell, øving, så egen skriving."
>
  <div class="sp-side-hode">
    <p class="kicker">/sandbox · verktøy</p>
    <h1>Sporing</h1>
    <p class="dempet">
      Lag skriftformingsark: skriv bokstavene eller ordene, så tegnes de i et bokstavhus (loft, stue, kjeller) med grønt startpunkt og retningspiler på utsiden av bokstaven — én tydelig modell, så øving med litt hjelp, så på egen hånd. Valgfrie husfarger og tom øvelinje.
    </p>
  </div>
  <SporingVerktoy lang="nb" />
</Side>

<style>
  .kicker {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--hue-aksent);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-3);
  }

  .dempet {
    color: var(--dempet);
    max-width: 68ch;
    margin: 0;
  }
</style>
