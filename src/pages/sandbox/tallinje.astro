---
import Side from '../../layouts/Side.astro';
import TallinjeVerktoy from '../../components/TallinjeVerktoy.astro';

/* Tallinjer i sandbox. ENGELSK TVILLING:
   src/pages/en/sandbox/number-line.astro — endre begge. */
---

<Side
  title="Tallinjer — lag tallinjeark til utskrift"
  description="Tallinjer med hull elevene fyller inn — tell med 1, 2, 5 eller 10."
>
  <div class="ta-side-hode">
    <p class="kicker">/sandbox · verktøy</p>
    <h1>Tallinjer</h1>
    <p class="dempet">
      Lag tallinjeark: velg startverdi, hopp og hvor mange ruter som skal stå tomme. Linjene henger sammen, så arket dekker et sammenhengende tallrom. Fasit følger med.
    </p>
  </div>
  <TallinjeVerktoy lang="nb" />
</Side>

<style>
  .kicker {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--hue-aksent);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-3);
  }

  .dempet {
    color: var(--dempet);
    max-width: 68ch;
    margin: 0;
  }
</style>
