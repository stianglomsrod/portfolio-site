---
import Side from '../layouts/Side.astro';

/* README-format fra briefen: goals, guardrails, human_review — pluss
   flyten som flytskjema. Mønsteret er hentet fra styringsdokumentene i
   Klar (PROJECT_DNA, HANDOVER_STATE) og Companion (PLAN_AGENT_SLICES,
   handover-rapporter): små leveranser, harde gates, dokumentert
   overlevering.

   Flytskjemaet følger etablert symbolspråk (ISO 5807-tradisjonen):
   aktivitet = rektangel som munner ut i sin betingelse (diamant) på
   ryggraden. JA fortsetter nedover fra diamantens bunn; NEI går ut av
   en sidespiss, og pila føres helt fram til steget flyten går tilbake
   til (høyre- og venstrefelt). Strektypen skiller funksjon: heltrukket
   = fremover, stiplet = tilbake for å rette, prikket = ny syklus.
   Etiketter står alltid vannrett (lesbarhet). ENGELSK TVILLING:
   src/pages/en/how-i-work.astro — endre begge. */

const readme = [
  { nokkel: 'goals:', verdi: 'definert og skrevet ned før hver økt' },
  { nokkel: 'guardrails:', verdi: 'hva agenten ikke får gjøre, eksplisitt og håndhevbart' },
  { nokkel: 'human_review:', verdi: 'beslutninger, retning og stikkprøver ligger hos et menneske' },
];
---

<Side
  title="Slik jobber jeg — Stian Glomsrød"
  description="README for arbeidsmåten: goals, guardrails og menneske i loopen."
>
  <p class="kicker">README · SLIK JOBBER JEG</p>
  <h1>Slik jobber jeg</h1>
  <p class="ingress">
    AI-agenter gjør meg raskere, men de får ikke siste ord. Jeg jobber i en
    fast flyt der hvert steg har en eier og en tydelig grense.
  </p>

  <div class="readme" translate="no">
    {readme.map((r) => (
      <div class="readme-rad">
        <span class="nokkel">{r.nokkel}</span>
        <span class="verdi">{r.verdi}</span>
      </div>
    ))}
  </div>

  <section aria-labelledby="flyt-tittel">
    <h2 id="flyt-tittel">Flyten</h2>
    <p class="flyt-ingress">
      Arbeidet går videre når kriteriene er grønne, og tilbake når de ikke
      er det. Selve flyten endres også underveis, etter hvert som jeg lærer
      hva som virker.
    </p>
    <div class="flyt-omraade">
      <svg id="retur-svg" aria-hidden="true"></svg>
      <ol class="flyt">
        <li class="node-rad">
          <div class="node eier-menneske" data-node="0">
            <span class="node-nr" aria-hidden="true">1</span>
            <div class="node-innhold">
              <h3>Kontekst og krav</h3>
              <p>
                Mål, rammer og suksesskriterier skrives ned før noe bygges.
                Kravene kan endres underveis, men da som en dokumentert
                beslutning.
              </p>
            </div>
          </div>
          <div class="kobling" aria-hidden="true">
            <span class="kobling-linje"></span>
            <span class="kobling-pil">▼</span>
          </div>
        </li>

        <li class="node-rad">
          <div class="node eier-agent" data-node="1">
            <span class="node-nr" aria-hidden="true">2</span>
            <div class="node-innhold">
              <h3>Verktøy</h3>
              <p>
                Jeg lager egne skills til Claude for jobben og domenet
                produktet lever i, og varige regler agentene må følge, for
                eksempel for dokumentasjon og designprinsipper. Hva som
                sjekkes og håndheves, avhenger av konteksten.
              </p>
            </div>
          </div>
          <div class="kobling" aria-hidden="true">
            <span class="kobling-label">rigget</span>
            <span class="kobling-linje"></span>
            <span class="kobling-pil">▼</span>
          </div>
        </li>

        <li class="node-rad">
          <div class="node eier-agent" data-node="2">
            <span class="node-nr" aria-hidden="true">3</span>
            <div class="node-innhold">
              <h3>Arbeidsløkka</h3>
              <p>
                Agenten bygger i små, avgrensede leveranser: forsøk, valider
                mot kriteriene, korriger.
              </p>
            </div>
          </div>
          <div class="kobling kort" aria-hidden="true">
            <span class="kobling-linje"></span>
            <span class="kobling-pil">▼</span>
          </div>
          <div class="gate-rad">
            <div class="gate-side venstre"></div>
            <div class="gate">
              <svg class="gate-form" viewBox="0 0 176 62" aria-hidden="true">
                <polygon points="88,1 175,31 88,61 1,31" />
              </svg>
              <span class="gate-tekst">alt grønt?</span>
            </div>
            <div class="gate-side hoyre">
              <span class="retur-pill" data-rute="a">
                <b class="pill-tag">nei</b> korriger og kjør på nytt
                <span class="pill-maal">↺ 3</span>
              </span>
            </div>
          </div>
          <div class="kobling" aria-hidden="true">
            <span class="kobling-label">ja</span>
            <span class="kobling-linje"></span>
            <span class="kobling-pil">▼</span>
          </div>
        </li>

        <li class="node-rad">
          <div class="node eier-menneske" data-node="3">
            <span class="node-nr" aria-hidden="true">4</span>
            <div class="node-innhold">
              <h3>Sjekkpunkt</h3>
              <p>
                Her sitter mennesket: retning, avveininger og stikkprøver.
                Ny innsikt sender flyten tilbake, ikke videre.
              </p>
            </div>
          </div>
          <div class="kobling kort" aria-hidden="true">
            <span class="kobling-linje"></span>
            <span class="kobling-pil">▼</span>
          </div>
          <div class="gate-rad">
            <div class="gate-side venstre">
              <span class="retur-pill" data-rute="c">
                <b class="pill-tag">nei</b> verktøyet forbedres
                <span class="pill-maal">→ 2</span>
              </span>
            </div>
            <div class="gate">
              <svg class="gate-form" viewBox="0 0 176 62" aria-hidden="true">
                <polygon points="88,1 175,31 88,61 1,31" />
              </svg>
              <span class="gate-tekst">godkjent?</span>
            </div>
            <div class="gate-side hoyre">
              <span class="retur-pill" data-rute="b">
                <b class="pill-tag">nei</b> kravene justeres
                <span class="pill-maal">→ 1</span>
              </span>
            </div>
          </div>
          <div class="kobling" aria-hidden="true">
            <span class="kobling-label">ja</span>
            <span class="kobling-linje"></span>
            <span class="kobling-pil">▼</span>
          </div>
        </li>

        <li class="node-rad">
          <div class="node" data-node="4">
            <span class="node-nr" aria-hidden="true">5</span>
            <div class="node-innhold">
              <h3>Overlevering</h3>
              <p>
                Tilstanden skrives ned: hva som er gjort, hva som gjenstår,
                og neste steg. Neste økt eller en helt ny agent kan ta over
                uten muntlig kontekst.
              </p>
            </div>
          </div>
          <div class="syklus-rad">
            <span class="retur-pill syklus-pill" data-rute="d">
              <b class="pill-tag syklus-tag">⟲</b> neste økt, med full historikk
              <span class="pill-maal">→ 1</span>
            </span>
          </div>
        </li>
      </ol>
    </div>
    <p class="tegnforklaring" aria-hidden="true">
      <span><i class="strek hel"></i> videre</span>
      <span><i class="strek stiplet"></i> tilbake for å rette</span>
      <span><i class="strek prikket"></i> ny økt</span>
      <span><i class="eier-chip menneske"></i> mennesket eier</span>
      <span><i class="eier-chip agent"></i> agenten jobber</span>
    </p>
  </section>

  <section aria-labelledby="guardrails-tittel">
    <h2 id="guardrails-tittel">Guardrails i praksis</h2>
    <p class="broedtekst">
      Denne siden er selv bygget slik. Kravene står i egne dokumenter,
      sjekker kjører automatisk før hvert bygg, og beslutninger logges med
      dato og reverseringskommando.
    </p>
    <p class="broedtekst">
      Verktøyet er også blitt bedre underveis: når noe ble dårlig, ble
      regelen eller skillen som slapp det gjennom, strammet inn.
    </p>
    <p class="broedtekst">
      Arbeidsmåten er skrevet ned slik at et team kan plukke den opp og bruke
      den.
    </p>
  </section>
</Side>

<style>
  .kicker {
    font-family: var(--font-hd);
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    color: var(--dempet);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-3);
  }

  h2 {
    font-size: 18px;
    margin: var(--s-6) 0 var(--s-3);
  }

  .ingress {
    color: var(--dempet);
    max-width: 68ch;
    margin: 0;
  }

  .readme {
    background: var(--flate);
    border: 1px solid var(--linje);
    border-radius: var(--radius-md);
    padding: var(--s-4);
    margin-top: var(--s-4);
    /* Deler høyrekant med flyt-kolonnen under (100px venstrefelt + 620px
       ryggrad) — håndheves av kant-sjekk */
    max-width: 720px;
  }

  .readme-rad {
    display: flex;
    gap: var(--s-3);
    align-items: baseline;
    padding: 5px 0;
  }

  .nokkel {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: 13px;
    color: var(--tekst);
    width: 130px;
    flex-shrink: 0;
  }

  .verdi {
    font-size: 15px;
    color: var(--tekst);
  }

  .flyt-ingress {
    color: var(--dempet);
    max-width: 62ch;
    margin: 0 0 var(--s-4);
  }

  /* Agent-tonen er hue-forskjøvet fra aksenten (+80) så den skiller seg
     fra salvie i BEGGE temaer og roterer med paletten. Kun dekor (kant og
     aria-hidden tall) — ikke brødtekst, så L/C-kravet gjelder ikke her. */
  section {
    --eier-agent: oklch(58% 0.11 calc(var(--hue2) + 80));
  }

  /* Klassisk flytskjema: én ryggrad ovenfra og ned, beslutningsdiamantene
     PÅ ryggraden. Returlinjene rutes i felt på begge sider — symmetrisk. */
  .flyt-omraade {
    position: relative;
    max-width: 820px;
    padding-inline: 100px;
  }

  #retur-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    overflow: visible;
  }

  @media (max-width: 680px) {
    .flyt-omraade {
      padding-inline: 0;
    }

    .readme {
      max-width: 100%;
    }
  }

  .flyt {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 620px;
  }

  .node-rad {
    display: flex;
    flex-direction: column;
  }

  .node {
    display: flex;
    gap: var(--s-3);
    background: var(--flate);
    border: 1px solid var(--linje);
    border-left-width: 3px;
    border-radius: var(--radius-md);
    box-shadow: var(--kort-skygge);
    padding: var(--s-3) var(--s-4);
  }

  /* Eierfarger — sidens poeng er at hvert steg har en eier:
     salvie = mennesket (handlekraft), agent-tonen = agenten/verktøyet */
  .node.eier-menneske {
    border-left-color: var(--salvie);
  }

  .node.eier-menneske .node-nr {
    color: var(--salvie);
    border-color: var(--salvie);
  }

  .node.eier-agent {
    border-left-color: var(--eier-agent);
  }

  .node.eier-agent .node-nr {
    color: var(--eier-agent);
    border-color: var(--eier-agent);
  }

  .node-nr {
    font-family: var(--font-hd);
    font-weight: 700;
    font-size: 13.5px;
    color: var(--dempet);
    border: 1px solid var(--linje);
    border-radius: 50%;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .node-innhold h3 {
    font-size: 16px;
    margin: 0 0 var(--s-1);
  }

  .node-innhold p {
    font-size: 15px;
    line-height: 1.55;
    color: var(--dempet);
    margin: 0;
    max-width: 60ch;
  }

  /* Kobling på ryggraden: heltrukket = flyten fremover. JA-etiketten
     hører til diamantens bunnspiss — utgangen den beskriver. */
  .kobling {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2px 0;
  }

  .kobling-label {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: 12.5px;
    letter-spacing: 0.06em;
    color: var(--salvie);
    padding: 1px 0;
  }

  .kobling-linje {
    width: 2px;
    height: 10px;
    background: var(--linje);
  }

  .kobling.kort .kobling-linje {
    height: 7px;
  }

  .kobling-pil {
    color: var(--linje);
    font-size: 10px;
    line-height: 1;
  }

  /* Beslutningsraden: diamanten på ryggraden, NEI-etikettene ved
     sidespissene sine — pilene tegnes videre fra dem til målsteget. */
  .gate-rad {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--s-2);
  }

  .gate {
    position: relative;
    grid-column: 2;
    width: 158px;
    height: 56px;
    display: grid;
    place-items: center;
  }

  .gate-form {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .gate-form polygon {
    fill: var(--flate);
    stroke: var(--salvie);
    stroke-width: 1.3;
  }

  .gate-tekst {
    position: relative;
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: 13.5px;
    color: var(--tekst);
  }

  .gate-side {
    display: flex;
    align-items: center;
  }

  .gate-side.venstre {
    grid-column: 1;
    justify-content: flex-end;
  }

  .gate-side.hoyre {
    grid-column: 3;
    justify-content: flex-start;
  }

  /* Retur-etiketter: vannrette, sitter PÅ linja si (stiplet kant =
     samme språk som linja) */
  .retur-pill {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    font-family: var(--font-hd);
    font-size: 13px;
    color: var(--tekst);
    background: var(--flate-2);
    border: 1px dashed var(--linje);
    border-radius: var(--radius-sm);
    padding: 5px 10px;
    white-space: nowrap;
  }

  .pill-tag {
    font-weight: 700;
    font-size: 12px;
    color: var(--feil);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Målnummeret (→ 1) er redundant når pilene tegnes — vises kun på
     smale skjermer der linjefeltet ikke finnes */
  .pill-maal {
    display: none;
    font-weight: 600;
    color: var(--salvie);
  }

  @media (max-width: 680px) {
    .pill-maal {
      display: inline;
    }
  }

  .syklus-rad {
    display: flex;
    justify-content: flex-end;
    margin-top: var(--s-3);
  }

  .syklus-pill {
    border-style: dotted;
  }

  .syklus-tag {
    text-transform: none;
    color: var(--salvie);
  }

  /* Tegnforklaring: linjetyper og eierfarger betyr noe, så de forklares */
  .tegnforklaring {
    display: flex;
    gap: var(--s-5);
    flex-wrap: wrap;
    margin: var(--s-4) 0 0;
    font-family: var(--font-hd);
    font-size: 13px;
    color: var(--dempet);
  }

  .strek {
    display: inline-block;
    width: 24px;
    border-top: 2px solid var(--dempet);
    vertical-align: middle;
    margin-right: 6px;
  }

  .strek.stiplet {
    border-top-style: dashed;
  }

  .strek.prikket {
    border-top-style: dotted;
  }

  .eier-chip {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 3px;
    vertical-align: middle;
    margin-right: 6px;
  }

  .eier-chip.menneske {
    background: var(--salvie);
  }

  .eier-chip.agent {
    background: var(--eier-agent);
  }

  @media (max-width: 680px) {
    /* På smale skjermer bærer etikettene informasjonen alene (→ 1 osv.),
       og linjefeltene finnes ikke */
    .tegnforklaring {
      display: none;
    }

    .gate-rad {
      grid-template-columns: auto;
      justify-items: center;
      gap: var(--s-2);
    }

    .gate {
      grid-column: 1;
    }

    .gate-side.venstre,
    .gate-side.hoyre {
      grid-column: 1;
      justify-content: center;
    }

    .gate-side:empty {
      display: none;
    }

    .retur-pill {
      white-space: normal;
    }

    .syklus-rad {
      justify-content: center;
    }
  }

  .broedtekst {
    max-width: 68ch;
    line-height: 1.6;
    color: var(--tekst);
  }
</style>

<script>
  /* Returlinjene tegnes som ekte flytskjema-piler: fra diamantens
     sidespiss, gjennom etiketten sin, ut i sidefeltet og helt fram til
     steget flyten går tilbake til (pilhode inn i noden). Stiplet =
     tilbake for å rette, prikket = ny økt. Etikettene er HTML (alltid
     vannrette); SVG-en har bare linjer og pilhoder. På smale skjermer
     tegnes ingenting — etikettene oppgir målet selv (→ 1). */
  const omraade = document.querySelector<HTMLElement>('.flyt-omraade');
  const svg = document.getElementById('retur-svg');
  const noder = [...document.querySelectorAll<HTMLElement>('.flyt .node')];

  interface Rute {
    pill: string;
    til: number; // data-node på målet
    side: 'hoyre' | 'venstre'; // hvilken sidespiss/felt ruta bruker
    bane: number; // parallell bane i feltet (0 = innerst)
    inngang: number | 'bunn'; // px fra målnodens topp; 'bunn' = nederst
    prikket?: boolean;
  }

  const ruter: Rute[] = [
    { pill: 'a', til: 2, side: 'hoyre', bane: 0, inngang: 'bunn' },
    { pill: 'b', til: 0, side: 'hoyre', bane: 1, inngang: 26 },
    { pill: 'd', til: 0, side: 'hoyre', bane: 2, inngang: 48, prikket: true },
    { pill: 'c', til: 1, side: 'venstre', bane: 0, inngang: 30 },
  ];

  const NS = 'http://www.w3.org/2000/svg';

  function strek(d: string, prikket: boolean, svgEl: Element) {
    const linje = document.createElementNS(NS, 'path');
    linje.setAttribute('d', d);
    linje.setAttribute('fill', 'none');
    linje.setAttribute('stroke-width', '1.5');
    linje.setAttribute('stroke-dasharray', prikket ? '2 5' : '6 5');
    linje.setAttribute('stroke-linecap', 'round');
    linje.style.stroke = 'var(--dempet)';
    svgEl.appendChild(linje);
  }

  function tegn() {
    if (!omraade || !svg || noder.length < 5) return;
    svg.replaceChildren();
    if (omraade.clientWidth < 640) return;

    const boks = omraade.getBoundingClientRect();
    const flyt = omraade.querySelector<HTMLElement>('.flyt');
    if (!flyt) return;
    const flytBoks = flyt.getBoundingClientRect();
    const hoyreKant = flytBoks.right - boks.left;
    const venstreKant = flytBoks.left - boks.left;

    for (const rute of ruter) {
      const pill = omraade.querySelector<HTMLElement>(`[data-rute="${rute.pill}"]`);
      if (!pill) continue;
      const p = pill.getBoundingClientRect();
      const til = noder[rute.til].getBoundingClientRect();
      const y = p.top + p.height / 2 - boks.top;
      const inngang = rute.inngang === 'bunn' ? til.height - 16 : rute.inngang;
      const maalY = til.top - boks.top + inngang;
      const prikket = !!rute.prikket;

      /* Stubb fra diamantens sidespiss inn i etiketten, så pila leses
         som én sammenhengende utgang. Syklus-etiketten (d) har ingen
         diamant — pila starter i etiketten. */
      const gate = pill.closest('.gate-rad')?.querySelector('.gate');
      if (gate) {
        const g = gate.getBoundingClientRect();
        if (rute.side === 'hoyre') {
          strek(`M ${g.right - boks.left - 2} ${y} H ${p.left - boks.left}`, prikket, svg);
        } else {
          strek(`M ${g.left - boks.left + 2} ${y} H ${p.right - boks.left}`, prikket, svg);
        }
      }

      if (rute.side === 'hoyre') {
        const baneX = hoyreKant + 22 + rute.bane * 26;
        const sluttX = hoyreKant + 9;
        strek(
          `M ${p.right - boks.left + 4} ${y} H ${baneX} V ${maalY} H ${sluttX}`,
          prikket,
          svg
        );
        const pilhode = document.createElementNS(NS, 'path');
        pilhode.setAttribute('d', `M ${sluttX} ${maalY} l 8 -4.5 v 9 z`);
        pilhode.style.fill = 'var(--dempet)';
        svg.appendChild(pilhode);
      } else {
        const baneX = venstreKant - 22 - rute.bane * 26;
        const sluttX = venstreKant - 9;
        strek(
          `M ${p.left - boks.left - 4} ${y} H ${baneX} V ${maalY} H ${sluttX}`,
          prikket,
          svg
        );
        const pilhode = document.createElementNS(NS, 'path');
        pilhode.setAttribute('d', `M ${sluttX} ${maalY} l -8 -4.5 v 9 z`);
        pilhode.style.fill = 'var(--dempet)';
        svg.appendChild(pilhode);
      }
    }
  }

  tegn();
  if (omraade) new ResizeObserver(tegn).observe(omraade);
  document.fonts?.ready.then(tegn);
</script>
