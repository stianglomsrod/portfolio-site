---
import Side from '../layouts/Side.astro';

/* README-format fra briefen: goals, guardrails, human_review — pluss
   flyten som flytskjema. Mønsteret er hentet fra styringsdokumentene i
   Klar (PROJECT_DNA, HANDOVER_STATE) og Companion (PLAN_AGENT_SLICES,
   handover-rapporter): små leveranser, harde gates, dokumentert
   overlevering. Copy er lo-fi til endelig tekst. */

const readme = [
  { nokkel: 'goals:', verdi: 'definert og skrevet ned før hver økt' },
  { nokkel: 'guardrails:', verdi: 'hva agenten ikke får gjøre, eksplisitt og håndhevbart' },
  { nokkel: 'human_review:', verdi: 'beslutninger, retning og stikkprøver ligger hos et menneske' },
];

interface Node {
  navn: string;
  tekst: string;
  betingelse?: string; // label på pila VIDERE til neste node
  retur?: string[]; // løkke-/returveier ut av noden
}

const noder: Node[] = [
  {
    navn: 'Kontekst og krav',
    tekst:
      'Mål, rammer og suksesskriterier skrives ned før noe bygges. Kravene kan endres underveis, men da som en dokumentert beslutning.',
  },
  {
    navn: 'Verktøy',
    tekst:
      'Jeg lager egne skills til Claude for jobben og domenet produktet lever i, og varige regler agentene må følge, for eksempel for dokumentasjon og designprinsipper. Hva som sjekkes og håndheves, avhenger av konteksten.',
    betingelse: 'rigget',
  },
  {
    navn: 'Arbeidsløkka',
    tekst:
      'Agenten bygger i små, avgrensede leveranser: forsøk, valider mot kriteriene, korriger. Stopper valideringen arbeidet, går løkka en runde til.',
    betingelse: 'alt grønt',
    retur: ['ikke grønt: korriger og kjør på nytt'],
  },
  {
    navn: 'Sjekkpunkt',
    tekst:
      'Her sitter mennesket: retning, avveininger og stikkprøver. Ny innsikt kan bety at kravene må justeres. Da går flyten tilbake, ikke videre.',
    betingelse: 'godkjent',
    retur: [
      'ny innsikt: kravene justeres, og løkka kjøres på nytt',
      'noe ble dårlig: verktøyet og reglene forbedres, så feilen ikke skjer igjen',
    ],
  },
  {
    navn: 'Overlevering',
    tekst:
      'Tilstanden skrives ned: hva som er gjort, hva som gjenstår, og neste steg. Neste økt eller en helt ny agent kan ta over uten muntlig kontekst.',
    retur: ['neste økt starter på kontekst, med full historikk'],
  },
];
---

<Side
  title="Slik jobber jeg — Stian Glomsrød"
  description="README for arbeidsmåten: goals, guardrails og menneske i loopen."
>
  <p class="kicker">README · SLIK JOBBER JEG</p>
  <h1>Slik jobber jeg</h1>
  <p class="ingress">
    AI-agenter gjør meg raskere, men de får ikke siste ord. Jeg jobber i en
    fast flyt der hvert steg har en eier og en tydelig grense.
  </p>

  <div class="readme" translate="no">
    {readme.map((r) => (
      <div class="readme-rad">
        <span class="nokkel">{r.nokkel}</span>
        <span class="verdi">{r.verdi}</span>
      </div>
    ))}
  </div>

  <section aria-labelledby="flyt-tittel">
    <h2 id="flyt-tittel">Flyten</h2>
    <p class="flyt-ingress">
      Arbeidet går videre når kriteriene er grønne, og tilbake når de ikke
      er det.
    </p>
    <div class="flyt-omraade">
      <svg id="retur-svg" aria-hidden="true"></svg>
      <ol class="flyt">
      {noder.map((n, i) => (
        <li class="node-rad">
          <div class="node">
            <span class="node-nr" aria-hidden="true">{i + 1}</span>
            <div class="node-innhold">
              <h3>{n.navn}</h3>
              <p>{n.tekst}</p>
              {n.retur?.map((r) => (
                <p class="retur">
                  <span class="retur-pil" aria-hidden="true">↺</span>
                  {r}
                </p>
              ))}
            </div>
          </div>
          {i < noder.length - 1 && (
            <div class="kobling" aria-hidden="true">
              {n.betingelse && <span class="kobling-label">{n.betingelse}</span>}
              <span class="kobling-linje"></span>
              <span class="kobling-pil">▼</span>
            </div>
          )}
        </li>
      ))}
      </ol>
    </div>
  </section>

  <section aria-labelledby="guardrails-tittel">
    <h2 id="guardrails-tittel">Guardrails i praksis</h2>
    <p class="broedtekst">
      Denne siden er selv bygget slik. Hver iterasjon sjekkes mot en
      compliance-port før koden skrives, og en innholdssjekk kjører før hvert
      bygg: bygget feiler hvis spillet i /sandbox og siden er uenige om fakta.
      Beslutninger logges med dato og reverseringskommando.
    </p>
    <p class="broedtekst">
      Arbeidsmåten er skrevet ned slik at et team kan plukke den opp og bruke
      den.
    </p>
  </section>
</Side>

<style>
  .kicker {
    font-family: var(--font-hd);
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    color: var(--dempet);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-3);
  }

  h2 {
    font-size: 18px;
    margin: var(--s-6) 0 var(--s-3);
  }

  .ingress {
    color: var(--dempet);
    max-width: 68ch;
    margin: 0;
  }

  .readme {
    background: var(--flate);
    border: 1px solid var(--linje);
    border-radius: var(--radius-md);
    padding: var(--s-4);
    margin-top: var(--s-4);
    max-width: 560px;
  }

  .readme-rad {
    display: flex;
    gap: var(--s-3);
    align-items: baseline;
    padding: 5px 0;
  }

  .nokkel {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: 12.5px;
    color: var(--tekst);
    width: 130px;
    flex-shrink: 0;
  }

  .verdi {
    font-size: 14px;
    color: var(--tekst);
  }

  .flyt-ingress {
    color: var(--dempet);
    max-width: 62ch;
    margin: 0 0 var(--s-4);
  }

  /* Området rundt flyten har et felt til høyre der returpilene tegnes */
  .flyt-omraade {
    position: relative;
    max-width: 780px;
    padding-right: 160px;
  }

  #retur-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    overflow: visible;
  }

  @media (max-width: 680px) {
    .flyt-omraade {
      padding-right: 0;
    }
  }

  .flyt {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 620px;
  }

  .node-rad {
    display: flex;
    flex-direction: column;
  }

  .node {
    display: flex;
    gap: var(--s-4);
    background: var(--flate);
    border: 1px solid var(--linje);
    border-radius: var(--radius-md);
    padding: var(--s-4) var(--s-5);
  }

  .node-nr {
    font-family: var(--font-hd);
    font-weight: 700;
    font-size: 13px;
    color: var(--dempet);
    border: 1px solid var(--linje);
    border-radius: 50%;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .node-innhold h3 {
    font-size: 16px;
    margin: 0 0 var(--s-1);
  }

  .node-innhold p {
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--dempet);
    margin: 0;
    max-width: 56ch;
  }

  /* Retur-/løkkeveier: betinget vei UT av noden, tilbake i flyten */
  .retur {
    display: flex;
    align-items: baseline;
    gap: var(--s-2);
    margin-top: var(--s-3) !important;
    padding-top: var(--s-3);
    border-top: 1px dashed var(--linje);
    font-size: 13.5px;
    color: var(--tekst) !important;
  }

  .retur-pil {
    color: var(--salvie);
    font-size: 15px;
    flex-shrink: 0;
  }

  /* Kobling mellom noder: linje + pil, med betingelsen som label */
  .kobling {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2px 0;
  }

  .kobling-label {
    font-family: var(--font-hd);
    font-weight: 600;
    font-size: 11.5px;
    letter-spacing: 0.06em;
    color: var(--salvie);
    padding: 2px 0;
  }

  .kobling-linje {
    width: 2px;
    height: 14px;
    background: var(--linje);
  }

  .kobling-pil {
    color: var(--linje);
    font-size: 10px;
    line-height: 1;
  }

  .broedtekst {
    max-width: 68ch;
    line-height: 1.6;
    color: var(--tekst);
  }
</style>

<script>
  /* Returpiler i flytskjemaet: tegnes fra kortenes faktiske posisjoner,
     som logiske porter — betingelsen avgjør om flyten går videre (pilene
     i midten) eller tilbake (pilene her). På smale skjermer bærer
     returtekstene i kortene informasjonen alene. */
  const omraade = document.querySelector<HTMLElement>('.flyt-omraade');
  const svg = document.getElementById('retur-svg');
  const noder = [...document.querySelectorAll<HTMLElement>('.flyt .node')];

  /* startOffset = avstand fra kortets bunn der pila går ut — matcher
     rekkefølgen på returlinjene i kortet når det er flere. */
  const ruter = [
    { fra: 2, til: 2, label: 'ikke grønt', bane: 0, startOffset: 28 },
    { fra: 3, til: 1, label: 'verktøyet forbedres', bane: 1, startOffset: 24 },
    { fra: 3, til: 0, label: 'krav justeres', bane: 2, startOffset: 56 },
    { fra: 4, til: 0, label: 'neste økt', bane: 3, startOffset: 28 },
  ];

  const NS = 'http://www.w3.org/2000/svg';

  function tegn() {
    if (!omraade || !svg || noder.length < 5) return;
    svg.replaceChildren();
    if (omraade.clientWidth < 640) return;

    const boks = omraade.getBoundingClientRect();

    for (const rute of ruter) {
      const fra = noder[rute.fra].getBoundingClientRect();
      const til = noder[rute.til].getBoundingClientRect();

      const startX = fra.right - boks.left;
      const startY = fra.bottom - boks.top - rute.startOffset;
      const baneX = startX + 26 + rute.bane * 30;
      const sluttY = til.top - boks.top + 26 + rute.bane * 14;
      const sluttX = til.right - boks.left + 9;

      const linje = document.createElementNS(NS, 'path');
      linje.setAttribute(
        'd',
        `M ${startX} ${startY} H ${baneX} V ${sluttY} H ${sluttX}`
      );
      linje.setAttribute('fill', 'none');
      linje.setAttribute('stroke-width', '1.5');
      linje.setAttribute('stroke-dasharray', '5 4');
      linje.style.stroke = 'var(--dempet)';
      svg.appendChild(linje);

      const pil = document.createElementNS(NS, 'path');
      pil.setAttribute('d', `M ${sluttX} ${sluttY} l 8 -4.5 v 9 z`);
      pil.style.fill = 'var(--dempet)';
      svg.appendChild(pil);

      const tekst = document.createElementNS(NS, 'text');
      const midtY = (startY + sluttY) / 2;
      tekst.setAttribute('x', String(baneX + 12));
      tekst.setAttribute('y', String(midtY));
      tekst.setAttribute('text-anchor', 'middle');
      tekst.setAttribute(
        'transform',
        `rotate(-90 ${baneX + 12} ${midtY})`
      );
      tekst.textContent = rute.label;
      tekst.style.fill = 'var(--salvie)';
      tekst.style.font = "600 11.5px 'Hanken Grotesk', sans-serif";
      tekst.style.letterSpacing = '0.05em';
      svg.appendChild(tekst);
    }
  }

  tegn();
  if (omraade) new ResizeObserver(tegn).observe(omraade);
  document.fonts?.ready.then(tegn);
</script>
